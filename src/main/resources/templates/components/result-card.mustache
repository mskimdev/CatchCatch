<article class="cc-card cc-result-card">
    <a class="cc-result-card__poster" href="concerts/{{id}}">
        <img src="{{posterUrl}}" alt="{{title}} 포스터">
    </a>
    <div class="cc-result-card__body">
        <span class="cc-concert-card__category">{{#category}}{{category}}{{/category}}{{^category}}콘서트{{/category}}</span>
        <h3 class="cc-result-card__title"><a href="concerts/{{id}}">{{title}}</a></h3>
        <p class="cc-result-card__line">{{dateRange}}</p>
        <p class="cc-result-card__line">{{venueName}}</p>
        <p class="cc-result-card__line">{{region}}</p>
        <p class="cc-rating"><span class="cc-rating__star">★</span> {{rating}} ({{reviewCount}})</p>
        {{#exclusive}}<span class="cc-badge">단독판매</span>{{/exclusive}}
    </div>
    <button class="cc-heart" type="button" data-concert-id="{{id}}" aria-label="관심 공연 등록" aria-pressed="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>
</article>
