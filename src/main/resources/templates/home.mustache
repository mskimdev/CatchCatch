{{# sessionUser }}
    {{> layout/header}}
{{/ sessionUser}}

{{^ sessionUser }}
    {{> layout/header-login }}
{{/ sessionUser }}
<link rel="stylesheet" href="/css/home.css">
<main class="cc-main">
    <div class="cc-container">

        <section class="cc-hero" aria-label="콘서트 광고 배너">
            <div class="cc-hero__track" data-carousel-track>
                {{#heroBanners}}
                    <article class="cc-hero__slide" style="--hero-img: url('{{imageUrl}}')">
                        <div class="cc-hero__content">
                            <p class="cc-hero__eyebrow">{{eyebrow}}</p>
                            <h1 class="cc-hero__title">{{title}} <em>{{highlight}}</em></h1>
                            <p class="cc-hero__desc">{{description}}</p>
                            <a class="cc-btn cc-btn--primary" href="{{linkUrl}}">{{buttonText}} →</a>
                        </div>
                    </article>
                {{/heroBanners}}

                {{^heroBanners}}
                    <article class="cc-hero__slide" style="--hero-img: url('/images/sample/banner-main.svg')">
                        <div class="cc-hero__content">
                            <p class="cc-hero__eyebrow">함께하는 순간, 잊지 못할 감동</p>
                            <h1 class="cc-hero__title">2026 전국투어 콘서트 <em>티켓 오픈 시작!</em></h1>
                            <p class="cc-hero__desc">지금 CatchCatch에서 만나보세요</p>
                            <a class="cc-btn cc-btn--primary" href="/concerts/1">공연 보러가기 →</a>
                        </div>
                    </article>
                {{/heroBanners}}
            </div>
        </section>

        <section class="cc-section">
            <div class="cc-section__head">
                <h2 class="cc-section__title">오픈 예정 <span class="cc-section__count">New</span></h2>
                <a class="cc-more" href="/concerts?status=coming-soon">전체보기 ›</a>
            </div>
            <div class="cc-open-grid">
                {{#comingSoonConcerts}}
                    <a class="cc-card cc-open-card" href="/concerts/{{id}}">
                        <div class="cc-open-card__meta">
                            <span class="cc-badge cc-badge--fill" style="background-color: #ff4757;">오픈예정</span>
                            {{dateRange}}
                            <span class="cc-open-card__small">{{badge}}</span>
                        </div>
                        <p class="cc-open-card__title">{{title}}</p>
                    </a>
                {{/comingSoonConcerts}}

                {{^comingSoonConcerts}}
                    <div style="padding: 20px; color: #999;">현재 오픈 예정인 콘서트가 없습니다.</div>
                {{/comingSoonConcerts}}
            </div>
        </section>

        <section class="cc-section">
            <div class="cc-section__head">
                <h2 class="cc-section__title">인기 콘서트</h2>
                <a class="cc-more" href="/concerts?sort=popular">전체보기 ›</a>
            </div>
            <div class="cc-concert-grid">
                {{#popularConcerts}}
                    <article class="cc-card cc-concert-card">
                        <a class="cc-concert-card__poster" href="/concerts/{{id}}">
                            {{#posterUrl}}<img src="{{posterUrl}}" alt="{{title}} 포스터">{{/posterUrl}}
                            {{^posterUrl}}
                                <div style="width: 100%; height: 100%; background: #e9ecef; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: #999;">
                                    NO IMAGE
                                </div>{{/posterUrl}}
                        </a>
                        <div class="cc-concert-card__body">
                            <span class="cc-concert-card__category">{{category}}</span>
                            <h3 class="cc-concert-card__title"><a href="/concerts/{{id}}">{{title}}</a></h3>
                            <p class="cc-concert-card__meta">📅 <span>{{dateRange}}</span></p>
                            <p class="cc-concert-card__meta">📍 <span>{{venueName}} ({{region}})</span></p>
                            <div class="cc-concert-card__foot"><span class="cc-badge">{{badge}}</span></div>
                        </div>
                        <button class="cc-heart" type="button">♡</button>
                    </article>
                {{/popularConcerts}}

                {{^popularConcerts}}
                    <div style="padding: 20px; color: #999;">현재 인기 콘서트 정보가 없습니다.</div>
                {{/popularConcerts}}
            </div>
        </section>

        <section class="cc-section">
            <div class="cc-section__head">
                <h2 class="cc-section__title">추천 콘서트</h2>
                <a class="cc-more" href="/concerts?sort=recommend">전체보기 ›</a>
            </div>
            <div class="cc-concert-grid">
                {{#recommendConcerts}}
                    <article class="cc-card cc-concert-card">
                        <a class="cc-concert-card__poster" href="/concerts/{{id}}">
                            {{#posterUrl}}<img src="{{posterUrl}}" alt="{{title}} 포스터">{{/posterUrl}}
                            {{^posterUrl}}
                                <div style="width: 100%; height: 100%; background: #e9ecef; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: #999;">
                                    NO IMAGE
                                </div>{{/posterUrl}}
                        </a>
                        <div class="cc-concert-card__body">
                            <span class="cc-concert-card__category">{{category}}</span>
                            <h3 class="cc-concert-card__title"><a href="/concerts/{{id}}">{{title}}</a></h3>
                            <p class="cc-concert-card__meta">📅 <span>{{dateRange}}</span></p>
                            <p class="cc-concert-card__meta">📍 <span>{{venueName}} ({{region}})</span></p>
                            <div class="cc-concert-card__foot"><span class="cc-badge">{{badge}}</span></div>
                        </div>
                        <button class="cc-heart" type="button">♡</button>
                    </article>
                {{/recommendConcerts}}

                {{^recommendConcerts}}
                    <div style="padding: 20px; color: #999;">추천 콘서트가 없습니다.</div>
                {{/recommendConcerts}}
            </div>
        </section>
    </div>
</main>
{{> layout/footer}}