{{> layout/header}}

<link rel="stylesheet" href="/css/information.css">

<main class="cc-main">
    <div class="cc-container cc-info-page">

        <section class="cc-info-hero cc-info-hero--event">
            <div>
                <p class="cc-info-hero__eyebrow">CATCHCATCH EVENT</p>
                <h1>이벤트</h1>
                <p>공연을 기다리는 시간까지 즐거워지는 CatchCatch의 혜택을 만나보세요.</p>
            </div>

            <div class="cc-info-hero__icon" aria-hidden="true">
                <svg viewBox="0 0 64 64" fill="none">
                    <path d="M12 26h40v28H12z"/>
                    <path d="M8 18h48v12H8zM32 18v36"/>
                    <path d="M32 18c-9 0-14-3-14-8 0-4 4-6 7-4 4 2 7 12 7 12ZM32 18c9 0 14-3 14-8 0-4-4-6-7-4-4 2-7 12-7 12Z"/>
                </svg>
            </div>
        </section>

        <section class="cc-info-section">
            <div class="cc-info-section__head">
                <div>
                    <p class="cc-info-kicker">{{kicker}}</p>
                    <h2>{{pageTitle}} </h2>
                </div>

                <form class="cc-info-filter" action="/events" method="get">
                    <button class="{{#ongoingActive}}is-active{{/ongoingActive}}"
                            type="submit"
                            name="status"
                            value="ongoing">
                        진행 중
                    </button>

                    <button class="{{#upcomingActive}}is-active{{/upcomingActive}}"
                            type="submit"
                            name="status"
                            value="upcoming">
                        예정
                    </button>

                    <button class="{{#endedActive}}is-active{{/endedActive}}"
                            type="submit"
                            name="status"
                            value="ended">
                        종료
                    </button>
                </form>
            </div>

            <div class="cc-event-grid">
                {{#eventList}}
                    <a class="cc-card cc-event-card" href="/events/{{id}}">
                        <div class="cc-event-visual cc-event-visual--violet">
                            <span>EVENT</span>
                            <strong>
                                {{rewardPoint}}P<br>
                            </strong>
                            <b>+</b>
                        </div>

                        <div class="cc-event-card__body">
                            <span class="cc-badge cc-badge--fill">{{statusLabel}}</span>
                            <h3>{{title}}</h3>
                            <p>{{description}}</p>
                            <small>이벤트 기간 : {{startDate}} - {{endDate}}</small>
                        </div>
                    </a>
                {{/eventList}}

                {{^eventList}}
                    <div class="cc-empty-event">
                        <h3>조회된 이벤트가 없습니다.</h3>
                        <p>현재 선택한 상태의 이벤트가 없습니다.</p>
                    </div>
                {{/eventList}}
            </div>
        </section>

    </div>
</main>

{{> layout/footer}}