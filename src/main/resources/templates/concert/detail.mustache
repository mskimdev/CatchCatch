{{> layout/header}}
<link rel="stylesheet" href="/css/concert-detail.css">

<main class="cc-main cc-detail-main">
    <div class="cc-container cc-detail-page">
        {{#concert}}
            <!-- (기존 상세정보 UI 코드 생략 없이 동일하게 유지) -->
            <div class="cc-detail-content">
                <section class="cc-detail-hero">
                    <div class="cc-poster-large">
                        <img src="{{posterUrl}}" alt="{{title}} 포스터">
                    </div>

                    <article class="cc-detail-info">
                        <div class="cc-detail-category">{{category}}</div>
                        <div class="cc-detail-title-row">
                            <h1 class="cc-detail-title">{{title}}</h1>
                            <div class="cc-detail-actions">
                                <button type="button" class="cc-icon-btn" aria-label="관심 등록">♡</button>
                                <button type="button" class="cc-icon-btn" aria-label="공유">⇧</button>
                            </div>
                        </div>
                        <div class="cc-detail-tags">
                            <span class="cc-badge cc-badge--fill">{{category}}</span>
                            <span class="cc-badge cc-badge--gray">{{genre}}</span>
                        </div>
                        <div class="cc-info-list">
                            <div class="cc-info-row"><span class="cc-info-row__label">📅 공연기간</span><span>{{dateRange}}</span></div>
                            <div class="cc-info-row"><span class="cc-info-row__label">📍 공연장</span><span>{{venueName}}</span></div>
                            <div class="cc-info-row"><span class="cc-info-row__label">⏱ 관람연령</span><span>{{ageLimit}}</span></div>
                            <div class="cc-info-row"><span class="cc-info-row__label">🕒 관람시간</span><span>{{runtime}}</span></div>
                            <div class="cc-info-row"><span class="cc-info-row__label">🏷 주최/주관</span><span>{{organizer}}</span></div>
                            <div class="cc-info-row"><span class="cc-info-row__label">☎ 문의</span><span>{{contact}}</span></div>
                        </div>
                        <div class="cc-price-list">
                            <h3>가격정보</h3>
                            {{#prices}}
                                <div class="cc-price-row">
                                    <span><i class="cc-dot cc-dot--{{gradeClass}}"></i>{{gradeName}}</span>
                                    <strong>{{priceText}}</strong>
                                </div>
                            {{/prices}}
                        </div>
                    </article>
                </section>

                <!-- 탭 네비게이션 -->
                <nav class="cc-tabs" aria-label="공연 상세 탭">
                    <a class="cc-tab is-active" href="#detail">상세정보</a>
                    <a class="cc-tab" href="#venue">공연장 안내</a>
                    <a class="cc-tab" href="#refund">취소/환불</a>
                    <a class="cc-tab" href="#review">후기 {{reviewCount}}</a>
                </nav>

                <!-- 상세 정보 섹션 -->
                <section id="detail" class="cc-detail-banner" style="--detail-img: url('{{detailBannerUrl}}')">
                    <div class="cc-detail-banner__content">
                        <h2>{{detailTitle}}</h2>
                        <p>{{detailDescription1}}</p>
                        <p>{{detailDescription2}}</p>
                    </div>
                </section>

                <!-- 동적으로 리뷰가 렌더링될 빈 껍데기 컨테이너 -->
                <section id="review-container" class="cc-review-section mt-5" style="display: none;">
                    <!-- JS의 renderReviews()가 여기에 HTML을 그려줍니다 -->
                </section>
            </div>

            <aside class="cc-detail-sidebar">
                <div class="cc-card cc-quick-booking">
                    <h3>빠른 예매</h3>
                    <form class="bookingStartForm" action="/booking/start" method="post">
                        <input type="hidden" name="concertId" id="hiddenConcertId" value="{{id}}">
                        {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}">{{/_csrf}}

                        <!-- 예매 폼 UI 유지 -->
                        <div class="cc-booking-panel">
                            <section class="cc-booking-section" data-booking-section>
                                <button class="cc-booking-section__head" type="button" data-section-toggle>
                                    <span class="cc-section-title">관람일</span>
                                    <span class="cc-selected-summary" data-selected-date-summary></span>
                                    <span class="cc-toggle-icon" aria-hidden="true"></span>
                                </button>
                                <div class="cc-booking-section__body">
                                    <select class="cc-select bookingDateSelect" id="sessionDate" name="sessionDate" hidden>
                                        <option value="">날짜를 선택해주세요</option>
                                        {{#dates}}<option value="{{value}}">{{label}}</option>{{/dates}}
                                    </select>
                                    <div class="cc-calendar-picker" data-calendar-for="sessionDate">
                                        <div class="cc-calendar-nav">
                                            <button type="button" class="cc-calendar-arrow" data-calendar-prev aria-label="이전 달">‹</button>
                                            <strong class="cc-calendar-title">날짜 선택</strong>
                                            <button type="button" class="cc-calendar-arrow" data-calendar-next aria-label="다음 달">›</button>
                                        </div>
                                        <div class="cc-calendar-week">
                                            <span>일</span><span>월</span><span>화</span><span>수</span><span>목</span><span>금</span><span>토</span>
                                        </div>
                                        <div class="cc-calendar-grid"></div>
                                    </div>
                                </div>
                            </section>

                            <section class="cc-booking-section cc-booking-section--session" data-booking-section>
                                <button class="cc-booking-section__head" type="button" data-section-toggle>
                                    <span class="cc-section-title">회차</span>
                                    <span class="cc-selected-summary" data-selected-session-summary></span>
                                    <span class="cc-toggle-icon" aria-hidden="true"></span>
                                </button>
                                <div class="cc-booking-section__body">
                                    <select class="cc-select bookingSessionSelect" id="sessionId" name="sessionId" hidden>
                                        <option value="">회차를 선택해주세요</option>
                                        {{#sessions}}<option value="{{id}}">{{label}}</option>{{/sessions}}
                                    </select>
                                    <div class="cc-session-card-list" data-session-picker-for="sessionId">
                                        {{#sessions}}
                                            <button type="button" class="cc-session-card" data-session-value="{{id}}">
                                                <strong>{{label}}</strong>
                                            </button>
                                        {{/sessions}}
                                    </div>
                                    <div class="cc-seat-remain">VIP석 <b>108</b> / R석 <b>137</b> / S석 <b class="is-zero">0석</b></div>
                                </div>
                            </section>
                        </div>
                        <button class="cc-btn cc-btn--primary cc-btn--full cc-booking-submit" type="submit">예매하기</button>
                    </form>
                </div>
            </aside>
        {{/concert}}
    </div>
</main>

<!-- ⭐️ 리뷰 작성 모달 창 (Bootstrap 기반) -->
<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="reviewModalLabel">관람 후기 작성</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="reviewForm">
                    <!-- 테스트용: 마이페이지 연동 전까지 예매 ID를 직접 입력받음 -->
                    <div class="mb-3">
                        <label for="reviewBookingId" class="form-label fw-bold">예매 번호 (ID)</label>
                        <input type="number" class="form-control" id="reviewBookingId" required placeholder="예: 1 (본인의 예매 번호 입력)">
                        <small class="text-muted">※ 실제 환경에서는 마이페이지에서 자동으로 넘어옵니다.</small>
                    </div>
                    <div class="mb-3">
                        <label for="reviewRating" class="form-label fw-bold">평점</label>
                        <select class="form-select" id="reviewRating" required>
                            <option value="5.0">⭐⭐⭐⭐⭐ (5.0점)</option>
                            <option value="4.5">⭐⭐⭐⭐.5 (4.5점)</option>
                            <option value="4.0">⭐⭐⭐⭐ (4.0점)</option>
                            <option value="3.0">⭐⭐⭐ (3.0점)</option>
                            <option value="2.0">⭐⭐ (2.0점)</option>
                            <option value="1.0">⭐ (1.0점)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="reviewContent" class="form-label fw-bold">후기 내용</label>
                        <textarea class="form-control" id="reviewContent" rows="4" required placeholder="공연 관람 후기를 자유롭게 남겨주세요. (최대 1000자)"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">취소</button>
                <button type="button" class="btn btn-primary" id="btn-submit-review">등록하기</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        initTabsAndReviews();       // 탭 및 리뷰 로직
        initReviewSubmit();         // 리뷰 작성 모달 이벤트
        initCalendarPicker();
        initSessionPicker();
        initBookingSectionToggle();
        initBookingStartSubmit();
    });

    // =========================================================================
    // [1. 탭 및 리뷰 로직 (수정된 URL 매핑 포함)]
    // =========================================================================
    function initTabsAndReviews() {
        const tabs = document.querySelectorAll('.cc-tab');
        const detailSection = document.getElementById('detail');
        const reviewContainer = document.getElementById('review-container');
        const concertId = document.getElementById('hiddenConcertId')?.value;
        const hasReviewsParam = window.location.search.includes('reviews');

        function activateTab(tabType) {
            tabs.forEach(t => t.classList.remove('is-active'));
            if (tabType === 'review') {
                const reviewTab = Array.from(tabs).find(t => t.getAttribute('href') === '#review');
                if (reviewTab) reviewTab.classList.add('is-active');
                if (detailSection) detailSection.style.display = 'none';
                if (reviewContainer) {
                    reviewContainer.style.display = 'block';
                    if (reviewContainer.innerHTML.trim() === '') fetchConcertReviews(concertId, 0);
                }
            } else {
                const detailTab = Array.from(tabs).find(t => t.getAttribute('href') === '#detail');
                if (detailTab) detailTab.classList.add('is-active');
                if (reviewContainer) reviewContainer.style.display = 'none';
                if (detailSection) detailSection.style.display = 'block';
            }
        }

        if (hasReviewsParam) activateTab('review');

        tabs.forEach(tab => {
            tab.addEventListener('click', function(e) {
                e.preventDefault();
                const targetHref = this.getAttribute('href');
                if (targetHref === '#review') {
                    history.pushState(null, '', window.location.pathname + '?reviews');
                    activateTab('review');
                } else if (targetHref === '#detail') {
                    history.pushState(null, '', window.location.pathname);
                    activateTab('detail');
                }
            });
        });

        // "후기 작성" 버튼 클릭 이벤트 위임 (동적 렌더링된 버튼 처리)
        document.addEventListener('click', function(e) {
            if (e.target && e.target.id === 'btn-write-review') {
                // 모달 띄우기 (Bootstrap JS 활용)
                const reviewModal = new bootstrap.Modal(document.getElementById('reviewModal'));
                reviewModal.show();
            }
        });
    }

    // ⭐️ 서버 API 통신 (경로 일치 완료: /api/concert/...)
    async function fetchConcertReviews(concertId, page = 0) {
        if (!concertId) return;
        try {
            // 수정된 주소: /api/concert/{concertId}/reviews
            const response = await apiGet(`/api/concert/${concertId}/reviews?page=${page}&size=5`);
            if (response && response.data) {
                renderReviews(response.data);
            }
        } catch (error) {
            console.error("리뷰 로드 실패:", error);
            if(window.CcUI) CcUI.toast('리뷰를 불러오는 중 오류가 발생했습니다.');
        }
    }

    function renderReviews(data) {
        const reviewContainer = document.getElementById('review-container');
        if (!reviewContainer) return;

        if (!data.reviews || data.reviews.length === 0) {
            reviewContainer.innerHTML = `
                <div class="d-flex justify-content-end mb-3">
                    <button class="btn btn-outline-primary px-4" id="btn-write-review">✍️ 첫 후기 작성하기</button>
                </div>
                <div class="card shadow-sm"><div class="card-body p-5 text-center text-muted">
                    <i class="far fa-comment-dots fa-3x mb-3 text-light"></i>
                    <h5>아직 등록된 후기가 없습니다.</h5>
                    <p>첫 번째 후기의 주인공이 되어주세요!</p>
                </div></div>`;
            return;
        }

        let html = `
            <div class="card shadow-sm cc-review-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
                        <div>
                            <h4 class="fw-bold mb-1">관람 후기</h4>
                            <div class="d-flex align-items-center mt-2">
                                <span class="text-warning fs-4 me-2">★</span>
                                <span class="fs-4 fw-bold">${(data.averageRating || 0).toFixed(1)}</span>
                                <span class="text-muted ms-2 mt-1">(${data.totalReviewCount}개의 후기)</span>
                            </div>
                        </div>
                        <button class="btn btn-outline-primary px-4" id="btn-write-review">✍️ 후기 작성</button>
                    </div>
                    <div class="list-group list-group-flush">
        `;

        data.reviews.forEach(review => {
            html += `
                <div class="list-group-item px-0 py-4 border-bottom">
                    <div class="d-flex justify-content-between mb-2">
                        <div class="d-flex align-items-center">
                            <span class="fw-bold me-2">${review.maskedUsername}</span>
                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill" style="font-size: 0.75rem;">
                                실제 관람객
                            </span>
                        </div>
                        <span class="text-muted small">${review.createdAt}</span>
                    </div>
                    <div class="text-warning mb-2 fw-bold">평점: ${review.rating}점</div>
                    <p class="mb-0 text-dark" style="line-height: 1.6;">${review.content}</p>
                </div>
            `;
        });

        html += `</div></div></div>`;
        reviewContainer.innerHTML = html;
    }

    // =========================================================================
    // [2. 후기 작성 데이터 전송 (apiPost 활용)]
    // =========================================================================
    function initReviewSubmit() {
        const btnSubmit = document.getElementById('btn-submit-review');

        btnSubmit?.addEventListener('click', async function() {
            const concertId = document.getElementById('hiddenConcertId')?.value;
            const bookingId = document.getElementById('reviewBookingId').value;
            const rating = document.getElementById('reviewRating').value;
            const content = document.getElementById('reviewContent').value;

            // 1. 프론트엔드 유효성 검사
            if(!bookingId || !rating || !content.trim()) {
                CcUI.alert('알림', '모든 항목을 입력해주세요.', 'warning');
                return;
            }

            // 2. DTO 구조에 맞춘 JSON 객체 생성
            const reqDTO = {
                bookingId: parseInt(bookingId),
                rating: parseFloat(rating),
                content: content
            };

            // 3. API 전송 (팀 공통 모듈 apiPost 사용 -> 내부에서 JSON.stringify 처리)
            try {
                const res = await apiPost(`/api/concert/${concertId}/reviews`, reqDTO);

                // 성공 시 응답 처리 (팀의 Resp 구조에 맞춤)
                if (res && res.code === 1) {
                    CcUI.toast('후기가 성공적으로 등록되었습니다.');

                    // 모달 창 닫기
                    const reviewModalEl = document.getElementById('reviewModal');
                    const modalInstance = bootstrap.Modal.getInstance(reviewModalEl);
                    if (modalInstance) modalInstance.hide();

                    // 폼 초기화 및 리뷰 목록 리로딩
                    document.getElementById('reviewForm').reset();
                    fetchConcertReviews(concertId, 0);
                } else {
                    CcUI.alert('오류', res.msg || '리뷰 등록에 실패했습니다.', 'error');
                }
            } catch (error) {
                console.error('리뷰 등록 에러:', error);
                // api.js 내부에서 처리되지만, 만약 튕겨 나올 경우 대비
            }
        });
    }

    // (이하 생략: 기존 initCalendarPicker 등 예매 폼 로직은 동일하게 유지)
    // 달력 및 세션 피커 함수들은 원본과 동일
    function initCalendarPicker() { /* 생략 */ }
    function initSessionPicker() { /* 생략 */ }
    function filterSessionsByDate(form, selectedDate) { /* 생략 */ }
    function updateSessionSummary(sessionSelect, sessionSummary) { /* 생략 */ }
    function initBookingSectionToggle() { /* 생략 */ }
    function initBookingStartSubmit() { /* 생략 */ }
</script>

{{> layout/footer}}