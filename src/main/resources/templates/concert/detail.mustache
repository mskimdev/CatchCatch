{{> layout/header}}
<link rel="stylesheet" href="/css/concert-detail.css">
<main class="cc-main">
    <div class="cc-container">
        {{#concert}}
        <section class="cc-detail-hero">
            <div class="cc-poster-large"><img src="{{posterUrl}}" alt="{{title}} 포스터"></div>
            <article class="cc-detail-info">
                <div class="cc-detail-category">{{category}}</div>
                <div class="cc-detail-title-row">
                    <h1 class="cc-detail-title">{{title}}</h1>
                    <div class="cc-detail-actions">
                        <button type="button" class="cc-icon-btn" aria-label="관심 등록">♡</button>
                        <button type="button" class="cc-icon-btn" aria-label="공유">⇧</button>
                    </div>
                </div>
                <div class="cc-detail-tags">
                    <span class="cc-badge cc-badge--fill">{{category}}</span>
                    <span class="cc-badge cc-badge--gray">{{genre}}</span>
                </div>
                <div class="cc-info-list">
                    <div class="cc-info-row"><span class="cc-info-row__label">📅 공연기간</span><span>{{dateRange}}</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">📍 공연장</span><span>{{venueName}}</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">⏱ 관람연령</span><span>{{ageLimit}}</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">🕒 관람시간</span><span>{{runtime}}</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">🏷 주최/주관</span><span>{{organizer}}</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">☎ 문의</span><span>{{contact}}</span></div>
                </div>
                <div class="cc-price-list">
                    <h3>가격정보</h3>
                    {{#prices}}
                    <div class="cc-price-row"><span><i class="cc-dot cc-dot--{{gradeClass}}"></i>{{gradeName}}</span><strong>{{priceText}}</strong></div>
                    {{/prices}}
                </div>
            </article>
            <aside class="cc-card cc-quick-booking">
                <h3>빠른 예매</h3>
                <form action="/booking/start" method="post">
                    <input type="hidden" name="concertId" value="{{id}}">
                    {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}">{{/_csrf}}
                    <div class="cc-field"><label for="sessionId">회차 선택</label><select class="cc-select" id="sessionId" name="sessionId"><option value="">회차를 선택해주세요</option>{{#sessions}}<option value="{{id}}">{{label}}</option>{{/sessions}}</select></div>
                    <div class="cc-field"><label for="sessionDate">날짜 선택</label><select class="cc-select" id="sessionDate" name="sessionDate"><option value="">날짜를 선택해주세요</option>{{#dates}}<option value="{{value}}">{{label}}</option>{{/dates}}</select></div>
                    <div class="cc-price-box"><strong>가격 요약</strong><div class="cc-price-box__row"><span>선택한 좌석 등급</span><b>-</b></div><div class="cc-price-box__row"><span>티켓 금액</span><b>0원</b></div></div>
                    <button class="cc-btn cc-btn--primary cc-btn--full" type="submit">예매하기</button>
                </form>
            </aside>
        </section>
        <nav class="cc-tabs" aria-label="공연 상세 탭">
            <a class="cc-tab is-active" href="#detail">상세정보</a><a class="cc-tab" href="#venue">공연장 안내</a><a class="cc-tab" href="#refund">취소/환불</a><a class="cc-tab" href="#review">후기 {{reviewCount}}</a>
        </nav>
        <section id="detail" class="cc-detail-banner" style="--detail-img: url('{{detailBannerUrl}}')"><div class="cc-detail-banner__content"><h2>{{detailTitle}}</h2><p>{{detailDescription1}}</p><p>{{detailDescription2}}</p></div></section>
        {{/concert}}

        {{^concert}}
        <section class="cc-detail-hero">
            <div class="cc-poster-large"><img src="/images/sample/poster-legend-seoul.svg" alt="무명전설 포스터"></div>
            <article class="cc-detail-info">
                <div class="cc-detail-category">콘서트</div>
                <div class="cc-detail-title-row"><h1 class="cc-detail-title">2026 무명전설 전국투어 콘서트 - 서울</h1><div class="cc-detail-actions"><button type="button" class="cc-icon-btn">♡</button><button type="button" class="cc-icon-btn">⇧</button></div></div>
                <div class="cc-detail-tags"><span class="cc-badge cc-badge--fill">콘서트</span><span class="cc-badge cc-badge--gray">록/메탈</span></div>
                <div class="cc-info-list">
                    <div class="cc-info-row"><span class="cc-info-row__label">📅 공연기간</span><span>2026.06.27 (토) ~ 2026.06.28 (일)</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">📍 공연장</span><span>올림픽공원 올림픽홀</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">⏱ 관람연령</span><span>만 7세 이상 관람가</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">🕒 관람시간</span><span>150분(인터미션 20분)</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">🏷 주최/주관</span><span>CatchCatch</span></div>
                    <div class="cc-info-row"><span class="cc-info-row__label">☎ 문의</span><span>1588-1234 (평일 10:00 ~ 18:00)</span></div>
                </div>
                <div class="cc-price-list">
                    <h3>가격정보</h3>
                    <div class="cc-price-row"><span><i class="cc-dot cc-dot--vip"></i>VIP석</span><strong>154,000원</strong></div>
                    <div class="cc-price-row"><span><i class="cc-dot cc-dot--r"></i>R석</span><strong>132,000원</strong></div>
                    <div class="cc-price-row"><span><i class="cc-dot cc-dot--s"></i>S석</span><strong>110,000원</strong></div>
                    <div class="cc-price-row"><span><i class="cc-dot cc-dot--a"></i>A석</span><strong>88,000원</strong></div>
                </div>
            </article>
            <aside class="cc-card cc-quick-booking">
                <h3>빠른 예매</h3>
                <form action="/booking/start" method="post">
                    <input type="hidden" name="concertId" value="1">
                    <div class="cc-field"><label for="sessionId">회차 선택</label><select class="cc-select" id="sessionId" name="sessionId"><option value="">회차를 선택해주세요</option><option value="1">1회차 2026.06.27 (토) 18:00</option><option value="2">2회차 2026.06.28 (일) 17:00</option></select></div>
                    <div class="cc-field"><label for="sessionDate">날짜 선택</label><select class="cc-select" id="sessionDate" name="sessionDate"><option value="">날짜를 선택해주세요</option><option>2026.06.27 (토)</option><option>2026.06.28 (일)</option></select></div>
                    <div class="cc-price-box"><strong>가격 요약</strong><div class="cc-price-box__row"><span>선택한 좌석 등급</span><b>-</b></div><div class="cc-price-box__row"><span>티켓 금액</span><b>0원</b></div></div>
                    <button class="cc-btn cc-btn--primary cc-btn--full" type="submit">예매하기</button>
                </form>
            </aside>
        </section>
        <nav class="cc-tabs" aria-label="공연 상세 탭"><a class="cc-tab is-active" href="#detail">상세정보</a><a class="cc-tab" href="#venue">공연장 안내</a><a class="cc-tab" href="#refund">취소/환불</a><a class="cc-tab" href="#review">후기 1,248</a></nav>
        <section id="detail" class="cc-detail-banner" style="--detail-img: url('/images/sample/detail-banner.svg')"><div class="cc-detail-banner__content"><h2>전설의 무대가 다시 시작된다!</h2><p>더 강렬하게, 더 뜨겁게 돌아온 무명전설의 전국투어!</p><p>2026년, 서울에서 그 감동을 함께하세요.</p></div></section>
        {{/concert}}
    </div>
</main>
{{> layout/footer}}
