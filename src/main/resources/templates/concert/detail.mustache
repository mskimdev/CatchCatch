{{> layout/header}}
<link rel="stylesheet" href="/css/concert-detail.css">

<main class="cc-main cc-detail-main">
    <div class="cc-container cc-detail-page">
        {{#concert}}
            <div class="cc-detail-content">
                <section class="cc-detail-hero">
                    <div class="cc-poster-large">
                        <img src="{{posterUrl}}" alt="{{title}} 포스터">
                    </div>

                    <article class="cc-detail-info">
                        <div class="cc-detail-category">{{category}}</div>

                        <div class="cc-detail-title-row">
                            <h1 class="cc-detail-title">{{title}}</h1>
                            <div class="cc-detail-actions">
                                <button type="button" class="cc-icon-btn" aria-label="관심 등록">♡</button>
                                <button type="button" class="cc-icon-btn" aria-label="공유">⇧</button>
                            </div>
                        </div>

                        <div class="cc-detail-tags">
                            <span class="cc-badge cc-badge--fill">{{category}}</span>
                            <span class="cc-badge cc-badge--gray">{{genre}}</span>
                        </div>

                        <div class="cc-info-list">
                            <div class="cc-info-row">
                                <span class="cc-info-row__label">📅 공연기간</span>
                                <span>{{dateRange}}</span>
                            </div>
                            <div class="cc-info-row">
                                <span class="cc-info-row__label">📍 공연장</span>
                                <span>{{venueName}}</span>
                            </div>
                            <div class="cc-info-row">
                                <span class="cc-info-row__label">⏱ 관람연령</span>
                                <span>{{ageLimit}}</span>
                            </div>
                            <div class="cc-info-row">
                                <span class="cc-info-row__label">🕒 관람시간</span>
                                <span>{{runtime}}</span>
                            </div>
                            <div class="cc-info-row">
                                <span class="cc-info-row__label">🏷 주최/주관</span>
                                <span>{{organizer}}</span>
                            </div>
                            <div class="cc-info-row">
                                <span class="cc-info-row__label">☎ 문의</span>
                                <span>{{contact}}</span>
                            </div>
                        </div>

                        <div class="cc-price-list">
                            <h3>가격정보</h3>
                            {{#prices}}
                                <div class="cc-price-row">
                                    <span>
                                        <i class="cc-dot cc-dot--{{gradeClass}}"></i>{{gradeName}}
                                    </span>
                                    <strong>{{priceText}}</strong>
                                </div>
                            {{/prices}}
                        </div>
                    </article>
                </section>

                <nav class="cc-tabs" aria-label="공연 상세 탭">
                    <a class="cc-tab is-active" href="#detail">상세정보</a>
                    <a class="cc-tab" href="#venue">공연장 안내</a>
                    <a class="cc-tab" href="#refund">취소/환불</a>
                    <a class="cc-tab" href="#review">후기 {{reviewCount}}</a>
                </nav>

                <section id="detail" class="cc-detail-banner" style="--detail-img: url('{{detailBannerUrl}}')">
                    <div class="cc-detail-banner__content">
                        <h2>{{detailTitle}}</h2>
                        <p>{{detailDescription1}}</p>
                        <p>{{detailDescription2}}</p>
                    </div>
                </section>
            </div>

            <aside class="cc-detail-sidebar">
                <div class="cc-card cc-quick-booking">
                    <h3>빠른 예매</h3>

                    <form class="bookingStartForm"
                          action="/booking/start"
                          method="post"
                          target="bookingPopup">

                        <input type="hidden" name="concertId" value="{{id}}">

                        {{#_csrf}}
                            <input type="hidden" name="{{parameterName}}" value="{{token}}">
                        {{/_csrf}}

                        <div class="cc-booking-panel">
                            <section class="cc-booking-section" data-booking-section>
                                <button class="cc-booking-section__head" type="button" data-section-toggle>
                                    <span class="cc-section-title">관람일</span>
                                    <span class="cc-selected-summary" data-selected-date-summary></span>
                                    <span class="cc-toggle-icon" aria-hidden="true"></span>
                                </button>

                                <div class="cc-booking-section__body">
                                    <select class="cc-select bookingDateSelect" id="sessionDate" name="sessionDate" hidden>
                                        <option value="">날짜를 선택해주세요</option>
                                        {{#dates}}
                                            <option value="{{value}}">{{label}}</option>
                                        {{/dates}}
                                    </select>

                                    <div class="cc-calendar-picker" data-calendar-for="sessionDate">
                                        <div class="cc-calendar-nav">
                                            <button type="button" class="cc-calendar-arrow" data-calendar-prev aria-label="이전 달">‹</button>
                                            <strong class="cc-calendar-title">날짜 선택</strong>
                                            <button type="button" class="cc-calendar-arrow" data-calendar-next aria-label="다음 달">›</button>
                                        </div>

                                        <div class="cc-calendar-week">
                                            <span>일</span>
                                            <span>월</span>
                                            <span>화</span>
                                            <span>수</span>
                                            <span>목</span>
                                            <span>금</span>
                                            <span>토</span>
                                        </div>

                                        <div class="cc-calendar-grid"></div>
                                    </div>
                                </div>
                            </section>

                            <section class="cc-booking-section cc-booking-section--session" data-booking-section>
                                <button class="cc-booking-section__head" type="button" data-section-toggle>
                                    <span class="cc-section-title">회차</span>
                                    <span class="cc-selected-summary" data-selected-session-summary></span>
                                    <span class="cc-toggle-icon" aria-hidden="true"></span>
                                </button>

                                <div class="cc-booking-section__body">
                                    <select class="cc-select bookingSessionSelect" id="sessionId" name="sessionId" hidden>
                                        <option value="">회차를 선택해주세요</option>
                                        {{#sessions}}
                                            <option value="{{id}}">{{label}}</option>
                                        {{/sessions}}
                                    </select>

                                    <div class="cc-session-card-list" data-session-picker-for="sessionId">
                                        {{#sessions}}
                                            <button type="button"
                                                    class="cc-session-card"
                                                    data-session-value="{{id}}">
                                                <strong>{{label}}</strong>
                                            </button>
                                        {{/sessions}}
                                    </div>

                                    <div class="cc-seat-remain">
                                        VIP석 <b>108</b> / R석 <b>137</b> / S석 <b class="is-zero">0석</b> / A석 <b>19</b> / B석 <b>56</b>
                                    </div>
                                </div>
                            </section>
                        </div>

                        <button class="cc-btn cc-btn--primary cc-btn--full cc-booking-submit" type="submit">
                            예매하기
                        </button>

                        <div class="cc-price-box">
                            <strong>가격 요약</strong>
                            <div class="cc-price-box__row">
                                <span>선택한 좌석 등급</span>
                                <b>-</b>
                            </div>
                            <div class="cc-price-box__row">
                                <span>티켓 금액</span>
                                <b>0원</b>
                            </div>
                        </div>
                    </form>
                </div>
            </aside>
        {{/concert}}

