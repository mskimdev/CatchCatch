{{> layout/header}}
<main class="cc-main">
    <div class="cc-container cc-list-layout">
        <aside class="cc-card cc-sidebar" aria-label="검색 필터">
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">상태 <span>⌃</span></div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item is-active" href="/concerts?status=all">전체 <span>✓</span></a>
                    <a class="cc-filter-item" href="/concerts?status=open-soon">오픈 예정</a>
                    <a class="cc-filter-item" href="/concerts?status=available">예매 가능</a>
                    <a class="cc-filter-item" href="/concerts?status=deadline">종료 임박</a>
                </nav>
            </section>
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">장르 <span>⌃</span></div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item is-active" href="/concerts?genre=all">전체 <span>✓</span></a>
                    <a class="cc-filter-item" href="/concerts?genre=concert">콘서트</a>
                    <a class="cc-filter-item" href="/concerts?genre=festival">페스티벌</a>
                    <a class="cc-filter-item" href="/concerts?genre=musical">뮤지컬</a>
                    <a class="cc-filter-item" href="/concerts?genre=classic">클래식</a>
                    <a class="cc-filter-item" href="/concerts?genre=fanmeeting">팬미팅</a>
                    <a class="cc-filter-item" href="/concerts?genre=etc">기타</a>
                </nav>
            </section>
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">지역 <span>⌃</span></div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item is-active" href="/concerts?region=all">전체 <span>✓</span></a>
                    <a class="cc-filter-item" href="/concerts?region=seoul">서울</a>
                    <a class="cc-filter-item" href="/concerts?region=gyeonggi">경기</a>
                    <a class="cc-filter-item" href="/concerts?region=incheon">인천</a>
                    <a class="cc-filter-item" href="/concerts?region=busan">부산</a>
                    <a class="cc-filter-item" href="/concerts?region=daegu">대구</a>
                </nav>
            </section>
        </aside>

        <section class="cc-results">
            <div class="cc-results-head">
                <h1 class="cc-results-title">콘서트 검색 결과 <span class="cc-accent-text">{{#resultCount}}{{resultCount}}{{/resultCount}}{{^resultCount}}128{{/resultCount}}건</span></h1>
                <a class="cc-more" href="/concerts">초기화 ↻</a>
            </div>
            <div class="cc-chip-row">
                <a class="cc-chip is-active" href="/concerts">전체 {{#resultCount}}{{resultCount}}{{/resultCount}}{{^resultCount}}128{{/resultCount}}</a>
                <a class="cc-chip" href="/concerts?status=open-soon">오픈 예정 {{#openSoonCount}}{{openSoonCount}}{{/openSoonCount}}{{^openSoonCount}}24{{/openSoonCount}}</a>
                <a class="cc-chip" href="/concerts?status=available">예매 가능 {{#availableCount}}{{availableCount}}{{/availableCount}}{{^availableCount}}78{{/availableCount}}</a>
                <a class="cc-chip" href="/concerts?status=deadline">종료 임박 {{#deadlineCount}}{{deadlineCount}}{{/deadlineCount}}{{^deadlineCount}}26{{/deadlineCount}}</a>
            </div>

            <div class="cc-result-grid">
                {{#concerts}}
                    {{> components/result-card}}
                {{/concerts}}
                {{^concerts}}
