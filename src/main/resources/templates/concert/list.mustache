{{> layout/header}}
<link rel="stylesheet" href="/css/concert-list.css">
<main class="cc-main">
    <div class="cc-container cc-list-layout">
        <aside class="cc-card cc-sidebar" aria-label="검색 필터">
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">상태 <span>⌃</span></div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item is-active" href="/concerts?concertStatus=all">전체 <span>✓</span></a>
                    <a class="cc-filter-item" href="/concerts?concertStatus=open-soon">오픈 예정</a>
                    <a class="cc-filter-item" href="/concerts?concertStatus=available">예매 가능</a>
                    <a class="cc-filter-item" href="/concerts?concertStatus=deadline">종료 임박</a>
                </nav>
            </section>
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">장르 <span>⌃</span></div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item is-active" href="/concerts?genre=all">전체 <span>✓</span></a>
                    <a class="cc-filter-item" href="/concerts?genre=concert">콘서트</a>
                    <a class="cc-filter-item" href="/concerts?genre=festival">페스티벌</a>
                    <a class="cc-filter-item" href="/concerts?genre=musical">뮤지컬</a>
                    <a class="cc-filter-item" href="/concerts?genre=classic">클래식</a>
                    <a class="cc-filter-item" href="/concerts?genre=fanmeeting">팬미팅</a>
                    <a class="cc-filter-item" href="/concerts?genre=etc">기타</a>
                </nav>
            </section>
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">지역 <span>⌃</span></div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item is-active" href="/concerts?region=all">전체 <span>✓</span></a>
                    <a class="cc-filter-item" href="/concerts?region=seoul">서울</a>
                    <a class="cc-filter-item" href="/concerts?region=gyeonggi">경기</a>
                    <a class="cc-filter-item" href="/concerts?region=incheon">인천</a>
                    <a class="cc-filter-item" href="/concerts?region=busan">부산</a>
                    <a class="cc-filter-item" href="/concerts?region=daegu">대구</a>
                </nav>
            </section>
        </aside>

        <section class="cc-results">
            <div class="cc-results-head">
                <h1 class="cc-results-title">콘서트 검색 결과 <span class="cc-accent-text">{{#resultCount}}{{resultCount}}{{/resultCount}}{{^resultCount}}128{{/resultCount}}건</span></h1>
                <a class="cc-more" href="/concerts">초기화 ↻</a>
            </div>
            <div class="cc-chip-row">
                <a class="cc-chip is-active" href="/concerts">전체 {{#resultCount}}{{resultCount}}{{/resultCount}}{{^resultCount}}128{{/resultCount}}</a>
                <a class="cc-chip" href="/concerts?concertStatus=open-soon">오픈 예정 {{#openSoonCount}}{{openSoonCount}}{{/openSoonCount}}{{^openSoonCount}}24{{/openSoonCount}}</a>
                <a class="cc-chip" href="/concerts?concertStatus=available">예매 가능 {{#availableCount}}{{availableCount}}{{/availableCount}}{{^availableCount}}78{{/availableCount}}</a>
                <a class="cc-chip" href="/concerts?concertStatus=deadline">종료 임박 {{#deadlineCount}}{{deadlineCount}}{{/deadlineCount}}{{^deadlineCount}}26{{/deadlineCount}}</a>
            </div>

            <div class="cc-result-grid">
                {{#concerts}}
                    <article class="cc-card cc-result-card">
                        <a class="cc-result-card__poster" href="/concerts/{{id}}">
                            {{#posterUrl}}
                                <img src="{{posterUrl}}" alt="{{title}} 포스터">
                            {{/posterUrl}}
                            {{^posterUrl}}
                                <div style="width: 100%; height: 100%; background: #e9ecef; display: flex; align-items: center; justify-content: center; border-radius: 5px;">NO IMAGE</div>
                            {{/posterUrl}}
                        </a>
                        <div class="cc-result-card__body">
                            <span class="cc-concert-card__category">콘서트</span>
                            <h3 class="cc-result-card__title">
                                <a href="/concerts/{{id}}">{{title}}</a>
                            </h3>
                            <p class="cc-result-card__line">👩‍🎤 {{artist}}</p>
                            <p class="cc-result-card__line">📍 {{name}} ({{address}})</p>

                            <p class="cc-rating"><span class="cc-rating__star">★</span> 4.9</p>
                            <span class="cc-badge">예매가능</span>
                        </div>
                        <button class="cc-heart" type="button">♡</button>
                    </article>
                {{/concerts}}

                {{^concerts}}
                    <div style="text-align: center; padding: 50px; width: 100%; color: #666;">
                        현재 예매 가능한 콘서트가 없습니다.
                    </div>
                {{/concerts}}
            </div>
        </section>
    </div>
</main>
{{> layout/footer}}
