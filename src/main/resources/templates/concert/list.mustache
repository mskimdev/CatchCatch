{{> layout/header}}
<link rel="stylesheet" href="/css/concert-list.css">
<main class="cc-main">
    <div class="cc-container cc-list-layout">
        <aside class="cc-card cc-sidebar" aria-label="검색 필터">
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">상태 </div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item cc-filter-status" href="/concerts?status=all">전체</a>
                    <a class="cc-filter-item cc-filter-status" href="/concerts?status=COMING_SOON">오픈 예정</a>
                    <a class="cc-filter-item cc-filter-status" href="/concerts?status=OPEN">예매 가능</a>
                    <a class="cc-filter-item cc-filter-status" href="/concerts?status=CLOSED_SOON">종료 임박</a>
                </nav>
            </section>
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">장르 </div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item cc-filter-genre" href="/concerts?genre=all">전체 </a>
                    <a class="cc-filter-item cc-filter-genre" href="/concerts?genre=concert">콘서트</a>
                    <a class="cc-filter-item cc-filter-genre" href="/concerts?genre=festival">페스티벌</a>
                    <a class="cc-filter-item cc-filter-genre" href="/concerts?genre=musical">뮤지컬</a>
                    <a class="cc-filter-item cc-filter-genre" href="/concerts?genre=classic">클래식</a>
                    <a class="cc-filter-item cc-filter-genre" href="/concerts?genre=fanmeeting">팬미팅</a>
                    <a class="cc-filter-item cc-filter-genre" href="/concerts?genre=etc">기타</a>
                </nav>
            </section>
            <section class="cc-filter-group">
                <div class="cc-filter-group__head">지역 </div>
                <nav class="cc-filter-list">
                    <a class="cc-filter-item cc-filter-region" href="/concerts?region=all">전체</a>
                    <a class="cc-filter-item cc-filter-region" href="/concerts?region=seoul">서울</a>
                    <a class="cc-filter-item cc-filter-region" href="/concerts?region=gyeonggi">경기</a>
                    <a class="cc-filter-item cc-filter-region" href="/concerts?region=incheon">인천</a>
                    <a class="cc-filter-item cc-filter-region" href="/concerts?region=busan">부산</a>
                    <a class="cc-filter-item cc-filter-region" href="/concerts?region=daegu">대구</a>
                </nav>
            </section>
        </aside>

        <section class="cc-results">
            <div class="cc-results-head">
                <h1 class="cc-results-title">{{searchTitle}} 검색 결과 <span class="cc-accent-text">{{resultCount}}건</span></h1>
                <a class="cc-more" href="/concerts">초기화 ↻</a>
            </div>
            <div class="cc-chip-row">
                <a class="cc-chip cc-chip-status" href="/concerts?status=all">전체 {{totalCount}}</a>
                <a class="cc-chip cc-chip-status" href="/concerts?status=COMING_SOON">오픈 예정 {{openSoonCount}}</a>
                <a class="cc-chip cc-chip-status" href="/concerts?status=OPEN">예매 가능 {{availableCount}}</a>
                <a class="cc-chip cc-chip-status" href="/concerts?status=CLOSED_SOON">종료 임박 {{deadlineCount}}</a>
            </div>

            <div class="cc-result-grid">
                {{#concerts}}
                    {{> components/result-card}}
                {{/concerts}}

                {{^concerts}}
                    <div style="grid-column: 1 / -1; text-align: center; padding: 100px 0; color: #888;">
                        <div style="font-size: 48px; margin-bottom: 16px;">🔍</div>
                        <h3 style="font-size: 20px; font-weight: bold; margin-bottom: 8px;">조건에 맞는 공연이 없습니다.</h3>
                        <p>다른 장르나 지역 필터를 선택해 보세요!</p>
                    </div>
                {{/concerts}}
            </div>
        </section>
    </div>
</main>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const urlParams = new URLSearchParams(window.location.search);

        const currentStatus = urlParams.get('status') || 'all';
        const currentGenre = urlParams.get('genre') || 'all';
        const currentRegion = urlParams.get('region') || 'all';

        // 모든 is-active 초기화 (HTML에 하드코딩된 것 제거)
        document.querySelectorAll('.cc-filter-item, .cc-chip').forEach(el => el.classList.remove('is-active'));

        // 현재 URL 파라미터 값과 일치하는 a 태그를 찾아 is-active 클래스 추가
        document.querySelectorAll(`.cc-filter-status[href*="status=${currentStatus}"]`).forEach(el => el.classList.add('is-active'));
        document.querySelectorAll(`.cc-filter-genre[href*="genre=${currentGenre}"]`).forEach(el => el.classList.add('is-active'));
        document.querySelectorAll(`.cc-filter-region[href*="region=${currentRegion}"]`).forEach(el => el.classList.add('is-active'));
        document.querySelectorAll(`.cc-chip-status[href*="status=${currentStatus}"]`).forEach(el => el.classList.add('is-active'));
    });
</script>

{{> layout/footer}}
