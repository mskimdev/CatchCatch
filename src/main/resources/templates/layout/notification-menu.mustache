<div class="cc-notification-wrap">
    <button type="button"
            id="notification-toggle"
            class="cc-notification-toggle"
            aria-label="알림"
            aria-haspopup="true"
            aria-expanded="false">
        <svg class="cc-notification-icon"
             viewBox="0 0 24 24"
             fill="none"
             stroke="currentColor"
             stroke-width="2">
            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 8-3 8h18s-3-1-3-8"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>

        <span id="notification-badge"
              class="cc-notification-badge"
              style="display:none;"></span>
    </button>

    <div id="notification-dropdown" class="cc-notification-dropdown">
        <div class="cc-notification-dropdown__head">
            <strong>알림센터</strong>
<!--            <button type="button" class="cc-notification-dropdown__setting">⚙</button>-->
        </div>

        <div class="cc-notification-dropdown__tabs">
            <button type="button" class="active" data-tab="notification">알림</button>
            <button type="button" data-tab="chat">대화</button>
        </div>

        <div class="cc-notification-dropdown__filters" data-tab-panel="notification">
            <button type="button" class="active" data-filter="ALL">전체</button>
            <button type="button" data-filter="BOOKING_CONFIRMED">예매완료</button>
            <button type="button" data-filter="BOOKING_CANCELED">예매취소</button>
            <button type="button" data-filter="POINT_EARNED,POINT_EXPIRED">포인트</button>
            <button type="button" data-filter="CONCERT_OPENED">공연오픈</button>
            <button type="button" data-filter="INQUIRY_REPLY">1:1 문의</button>
        </div>

        <div class="cc-notification-dropdown__filters" data-tab-panel="chat" style="display:none;">
            <button type="button" class="active" data-filter="CHAT_REPLY">1:1 채팅</button>
        </div>

        <div id="notification-list" class="cc-notification-dropdown__list">
            <div class="cc-notification-empty">알림을 불러오는 중입니다.</div>
        </div>
    </div>
</div>