<!-- FAB -->
<div class="cc-fab-wrap" id="cc-fab">
  <button class="cc-fab-main" id="cc-fab-main" aria-label="도움말 메뉴 열기" aria-expanded="false">
    <span class="cc-fab-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
    </span>
  </button>

  <div class="cc-fab-menu" role="menu">
    <!-- 1:1 채팅 -->
    <div class="cc-fab-item">
      <span class="cc-fab-item__label">1:1 채팅</span>
      <button class="cc-fab-item__btn cc-fab-item__btn--chat" id="cc-fab-chat" aria-label="1:1 채팅 열기" role="menuitem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </button>
    </div>

    <!-- AI 답변 -->
    <div class="cc-fab-item">
      <span class="cc-fab-item__label">AI 답변</span>
      <button class="cc-fab-item__btn cc-fab-item__btn--ai" id="cc-fab-ai" aria-label="AI 챗봇 열기" role="menuitem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a2 2 0 0 1 2 2v1h2a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2V4a2 2 0 0 1 2-2z"/>
          <circle cx="9" cy="11" r="1"/><circle cx="15" cy="11" r="1"/>
          <path d="M9 15s1 1 3 1 3-1 3-1"/>
        </svg>
      </button>
    </div>
  </div>
