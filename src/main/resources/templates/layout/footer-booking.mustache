<script>
    function closeBookingWindow() {
        if (window.opener && !window.opener.closed) {
            window.close();
            return;
        }

        const goConcerts = confirm("이 창은 브라우저에서 직접 열린 페이지라 자동으로 닫을 수 없습니다.\n콘서트 목록으로 이동할까요?");

        if (goConcerts) {
            location.href = "/concerts";
        }
    }

    function openMyBookingAndClose() {
        if (window.opener && !window.opener.closed) {
            window.opener.location.href = "/mypage/bookings";
            window.close();
            return;
        }

        location.href = "/mypage/bookings";
    }

    document.addEventListener("DOMContentLoaded", function () {
        const agreeAll = document.querySelector("#payAgreeAll");
        const agreeItems = Array.from(document.querySelectorAll(".pay-agree-item"));

        if (agreeAll && agreeItems.length > 0) {
            agreeAll.addEventListener("change", function () {
                agreeItems.forEach(function (item) {
                    item.checked = agreeAll.checked;
                });
            });

            agreeItems.forEach(function (item) {
                item.addEventListener("change", function () {
                    agreeAll.checked = agreeItems.every(function (checkbox) {
                        return checkbox.checked;
                    });
                });
            });
        }

        document.querySelectorAll(".cc-pay-method").forEach(function (label) {
            label.addEventListener("click", function () {
                document.querySelectorAll(".cc-pay-method").forEach(function (item) {
                    item.classList.remove("is-active");
                });

                label.classList.add("is-active");

                const radio = label.querySelector('input[type="radio"]');

                if (radio) {
                    radio.checked = true;
                }
            });
        });
    });
</script>
