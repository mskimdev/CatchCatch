<!doctype html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#pageTitle}}{{pageTitle}} | {{/pageTitle}}CatchCatch 관리자</title>

    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/admin-header.css">

    {{#pageCss}}
        <link rel="stylesheet" href="{{pageCss}}">
    {{/pageCss}}
</head>

<body class="cc-page cc-admin-page">

<header class="cc-header admin-header">
    <div class="cc-container">
        <div class="cc-header__top admin-header__top">

            <a class="cc-logo admin-logo" href="/admin/venues">
                CatchCatch <span>관리자 콘솔</span>
            </a>

            <form class="cc-searchbar admin-searchbar"
                  action="{{searchAction}}"
                  method="get"
                  role="search">

                <span class="admin-search-chip">{{searchLabel}}</span>

                <input class="cc-searchbar__input"
                       type="search"
                       name="keyword"
                       value="{{keyword}}"
                       placeholder="{{searchPlaceholder}}">

                <button type="submit" class="cc-icon-btn admin-search-btn" aria-label="검색">
                    <svg class="cc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="7"/>
                        <path d="M20 20l-3.5-3.5"/>
                    </svg>
                </button>
            </form>

            <div class="cc-header__actions admin-actions">
                <a class="admin-text-link" href="/">사용자 화면</a>

                {{#createUrl}}
                    <a class="cc-signup-link admin-header-save-btn" href="{{createUrl}}">
                        {{createLabel}}
                    </a>
                {{/createUrl}}

                <form action="/logout" method="post" style="margin:0;">
                    {{#_csrf}}
                        <input type="hidden" name="{{parameterName}}" value="{{token}}">
                    {{/_csrf}}
                    <button type="submit" class="cc-icon-btn admin-logout-btn" aria-label="로그아웃">
                        로그아웃
                    </button>
                </form>
            </div>

        </div>
    </div>

    <nav class="cc-header__nav admin-nav" aria-label="관리자 메뉴">
        <div class="cc-container cc-nav-row admin-nav-row">
            <a class="admin-nav__link {{#activeVenue}}is-active{{/activeVenue}}" href="/admin/venues">
                공연장 관리
            </a>
            <a class="admin-nav__link {{#activeConcert}}is-active{{/activeConcert}}" href="/admin/concerts">
                콘서트 관리
            </a>
            <a class="admin-nav__link {{#activeBooking}}is-active{{/activeBooking}}" href="/admin/bookings">
                예매 관리
            </a>
            <a class="admin-nav__link {{#activeUser}}is-active{{/activeUser}}" href="/admin/users">
                회원 관리
            </a>
            <a class="admin-nav__link {{#activeInquiry}}is-active{{/activeInquiry}}" href="/admin/inquiries">
                문의 관리
            </a>
        </div>
    </nav>
</header>