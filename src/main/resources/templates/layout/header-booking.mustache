<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>{{#pageTitle}}{{pageTitle}} | {{/pageTitle}}CatchCatch</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/catchcatch-purple.css">
    <link rel="stylesheet" href="/css/booking-header.css">
    <link rel="stylesheet" href="/css/booking-info.css">
    <link rel="stylesheet" href="/css/booking-seat.css">
    <link rel="stylesheet" href="/css/booking-complete.css">
</head>

<body>

<header class="cc-booking-header">
    <div class="cc-booking-header__inner">

        <div class="cc-stepper" aria-label="예매 진행 단계">

            <div class="cc-step {{#stepInfo}}is-active{{/stepInfo}}{{#stepInfoDone}}is-done{{/stepInfoDone}}">
                <span class="cc-step__num">
                    {{#stepInfoDone}}✓{{/stepInfoDone}}{{^stepInfoDone}}1{{/stepInfoDone}}
                </span>
                <span class="cc-step__text">예매정보</span>
            </div>

            <span class="cc-step-line"></span>

            <div class="cc-step {{#stepSeat}}is-active{{/stepSeat}}{{#stepSeatDone}}is-done{{/stepSeatDone}}">
                <span class="cc-step__num">
                    {{#stepSeatDone}}✓{{/stepSeatDone}}{{^stepSeatDone}}2{{/stepSeatDone}}
                </span>
                <span class="cc-step__text">좌석선택</span>
            </div>

            <span class="cc-step-line"></span>

            <div class="cc-step {{#stepComplete}}is-active{{/stepComplete}}">
                <span class="cc-step__num">3</span>
                <span class="cc-step__text">완료</span>
            </div>

        </div>

    </div>
</header>