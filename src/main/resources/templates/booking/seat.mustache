{{> layout/header-booking}}

<main class="cc-booking-shell">
    <section class="cc-booking-popup">

        <header class="cc-booking-top">
            <div class="cc-booking-title">
                <strong>좌석 선택</strong>
                <span>{{concertTitle}}</span>
            </div>

            <select class="cc-booking-session-select" aria-label="공연 회차">
                {{#sessions}}
                    <option value="{{id}}" {{#selected}}selected{{/selected}}>
                        {{sessionDateText}}
                    </option>
                {{/sessions}}

                {{^sessions}}
                    <option selected>{{sessionDateText}}</option>
                {{/sessions}}
            </select>
        </header>

        <section class="cc-booking-body">
            <section class="cc-booking-map-area">

                <section id="zoneView" class="cc-zone-view is-active">
                    <div class="cc-stage-label" aria-hidden="true">
                        {{#stageName}}{{stageName}}{{/stageName}}
                        {{^stageName}}무대{{/stageName}}
                    </div>

                    <div id="zoneButtonLayer" class="cc-zone-button-layer" aria-label="구역 선택"></div>

                    <div class="cc-bottom-guide">
                        <span id="mainGuideText">
                            구역을 먼저 선택해주세요.
                        </span>
                        <button type="button" id="foldGuideBtn" class="cc-guide-fold-btn">⌃</button>
                    </div>
                </section>

                <section id="seatView" class="cc-seat-view">
                    <div class="cc-seat-view-head">
                        <button type="button" id="backToZoneBtn" class="cc-back-zone-btn">
                            전체 구역 보기
                        </button>

                        <div>
                            <strong id="seatViewTitle">좌석 선택</strong>
                            <span id="seatViewSubText">구역을 선택해주세요.</span>
                        </div>
                    </div>

                    <div id="seatCanvas" class="cc-seat-canvas" aria-label="좌석 선택"></div>

                    <div class="cc-bottom-guide">
                        <span id="seatGuideText">
                            좌석을 선택해주세요.
                        </span>
                        <button type="button" id="clearSeatsBtn" class="cc-guide-reset-btn">
                            선택 초기화
                        </button>
                    </div>
                </section>

            </section>

            <aside class="cc-booking-side">
                <section class="cc-side-card cc-mini-card">
                    <div class="cc-brand">
                        <b>CatchCatch</b>
                        <span>티켓</span>
                    </div>

                    <div id="miniMap" class="cc-mini-map"></div>

                    <button type="button" id="openFullMapBtn" class="cc-full-map-btn">
                        좌석도 전체보기 〉
                    </button>
                </section>

                <section class="cc-side-card cc-grade-card">
                    <div class="cc-grade-head">
                        <h3>좌석등급/잔여석</h3>
                        <button type="button" id="refreshSeatBtn">새로고침</button>
                    </div>

                    <div id="gradeList" class="cc-grade-list"></div>
                </section>

                <section class="cc-side-card cc-selected-card">
                    <h3>선택 좌석</h3>

                    <div class="cc-timer">
                        <span>좌석 보관 시간</span>
                        <b data-countdown="600">10:00</b>
                    </div>

                    <div id="selectedSeatList" class="cc-selected-list">
                        <div class="cc-empty-selected">
                            선택된 좌석이 없습니다.
                        </div>
                    </div>

                    <div class="cc-total">
                        <span id="selectedCountText">총 0석</span>
                        <strong id="totalPriceText">0원</strong>
                    </div>
                </section>

                <form action="/booking/complete"
                      method="post"
                      id="bookingCompleteForm"
                      class="cc-complete-form">

                    <input type="hidden" name="seatIds" id="selectedSeatIds">
                    <div id="selectedSeatInputs"></div>

                    <input type="hidden" name="sessionId" value="{{sessionId}}">
                    <input type="hidden" name="concertId" value="{{concertId}}">

                    <button type="submit" id="bookingCompleteBtn" class="cc-complete-btn" disabled>
                        좌석 선택 완료
                    </button>
                </form>
            </aside>
        </section>

    </section>

    <script>
        (() => {
            const rawSeats =
        {{#seat.seatsJson}}
            {{{seat.seatsJson}}}
        {{/seat.seatsJson}}
        {{^seat.seatsJson}}
            []
        {{/seat.seatsJson}};

            const rawZones =
        {{#seat.zoneButtonsJson}}
            {{{seat.zoneButtonsJson}}}
        {{/seat.zoneButtonsJson}}
        {{^seat.zoneButtonsJson}}
            []
        {{/seat.zoneButtonsJson}};

            window.CATCHCATCH_BOOKING = {
                concertId: "{{concertId}}",
                sessionId: "{{sessionId}}",
                maxSelectCount: 4,
                seatImageUrl: "{{seat.seatImageUrl}}",
                zoneImageUrl: "{{seat.zoneImageUrl}}",
                seats: Array.isArray(rawSeats) ? rawSeats : [],
                zones: Array.isArray(rawZones) ? rawZones : []
            };
        })();
    </script>

    <script src="/js/booking/seat.js?v=20260624"></script>
</main>

{{> layout/footer}}