{{> layout/header-booking}}

<main class="cc-main">
    <div class="cc-container cc-seat-container">

        <section class="cc-seat-layout cc-seat-layout--wide">

            <section class="cc-card cc-seat-map-card">
                <div class="cc-seat-redesign cc-seat-redesign--wide"
                     id="bookingSeatApp"
                     data-max-select="4"
                     data-concert-id="{{concertId}}"
                     data-session-id="{{sessionId}}">

                    <section class="cc-zone-overview cc-zone-overview--large">
                        <div class="cc-zone-overview__head">
                            <strong>좌석 선택</strong>
                            <span>CatchCatch Concert</span>
                        </div>

                        <div class="cc-zone-overview__image-box cc-zone-overview__image-box--large">
                            <div id="seatImageHoverLayer"
                                 class="cc-seat-image-hover-layer"
                                 aria-label="구역 선택">
                            </div>
                        </div>

                        <div class="cc-zone-tabs" aria-label="좌석 등급 선택">
                            {{#seat.gradeTabs}}
                                <button type="button"
                                        class="cc-zone-tab {{#active}}is-active{{/active}}"
                                        data-grade="{{grade}}">
                                    {{gradeName}}
                                </button>
                            {{/seat.gradeTabs}}

                            {{^seat.gradeTabs}}
                                <button type="button"
                                        class="cc-zone-tab is-active"
                                        data-grade="">
                                    좌석 없음
                                </button>
                            {{/seat.gradeTabs}}
                        </div>

                        <div class="cc-zone-legend cc-zone-legend--row">
                            <div>
                                <i class="cc-seat-sample cc-seat-sample--available"></i>
                                예매 가능
                            </div>
                            <div>
                                <i class="cc-seat-sample cc-seat-sample--selected"></i>
                                선택 좌석
                            </div>
                            <div>
                                <i class="cc-seat-sample cc-seat-sample--sold"></i>
                                예매 불가
                            </div>
                        </div>
                    </section>

                    <section class="cc-zone-detail">
                        <div class="cc-zone-detail__top">
                            <div>
                                <h3 id="zoneTitle">좌석 선택</h3>
                                <p id="zoneSubText">구역을 선택해주세요.</p>
                            </div>
                        </div>

                        <div id="zoneSeatGrid"
                             class="cc-zone-seat-grid"
                             aria-label="좌석 선택">
                        </div>

                        <div class="cc-zone-bottom">
                            <button type="button"
                                    class="cc-small-btn"
                                    id="resetZoneBtn">
                                좌석 다시 선택
                            </button>

                            <span id="seatHoverInfo">
                                좌석을 선택해주세요.
                            </span>
                        </div>
                    </section>

                </div>
            </section>

            <aside class="cc-seat-side">

                <div class="cc-card cc-selected-card">
                    <h3>선택 좌석</h3>

                    <div class="cc-timer">
                        <span>좌석 보관 시간</span>
                        <b data-countdown="600">10:00</b>
                    </div>

                    <div class="cc-selected-list">
                        <div class="cc-selected-seat">
                            <div>
                                <div class="cc-selected-seat__name">
                                    선택된 좌석이 없습니다.
                                </div>
                                <div class="cc-selected-seat__price">
                                    좌석을 선택하면 여기에 표시됩니다.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="cc-total">
                        <span>총 0석</span>
                        <strong class="cc-total__price">0원</strong>
                    </div>

                    <div class="cc-seat-actions">
                        <a class="cc-seat-prev"
                           href="/booking/info">
                            이전
                        </a>

                        <form action="/booking/complete"
                              method="post"
                              class="cc-complete-form cc-payment-form">

                            <input type="hidden"
                                   name="seatIds"
                                   id="selectedSeatIds">

                            <div id="selectedSeatInputs"></div>

                            <input type="hidden"
                                   name="sessionId"
                                   value="{{sessionId}}">

                            <input type="hidden"
                                   name="concertId"
                                   value="{{concertId}}">

                            <button type="submit"
                                    class="cc-seat-complete-btn">
                                예매 완료
                            </button>
                        </form>
                    </div>
                </div>

                <div class="cc-card cc-notice-card">
                    <h3>유의사항</h3>
                    <ul>
                        <li>보관 시간이 초과되면 선택 좌석이 해제됩니다.</li>
                        <li>좌석은 최대 4석까지 선택할 수 있습니다.</li>
                        <li>이미 예매된 좌석은 선택할 수 없습니다.</li>
                    </ul>
                </div>

            </aside>

        </section>

        <script>
            (() => {
                const rawSeats =
            {{#seat.seatsJson}}
                {{{seat.seatsJson}}}
            {{/seat.seatsJson}}
            {{^seat.seatsJson}}
                []
            {{/seat.seatsJson}};

                function normalizeGrade(value) {
                    const raw = String(value || "").trim().toUpperCase();

                    if (raw === "VIP") return "VIP";
                    if (raw.includes("STANDING")) return "STANDING";
                    if (raw === "R" || raw === "R석") return "R";
                    if (raw === "S" || raw === "S석") return "S";
                    if (raw === "A" || raw === "A석") return "A";
                    if (raw === "B" || raw === "B석") return "B";

                    return raw || "A";
                }

                function gradeName(grade) {
                    if (!grade) return "좌석";
                    if (grade === "VIP") return "VIP";
                    if (grade === "STANDING") return "STANDING석";
                    return `${grade}석`;
                }

                function normalizeStatus(value) {
                    const raw = String(value || "AVAILABLE").trim().toUpperCase();

                    if (raw === "AVAILABLE") return "AVAILABLE";
                    if (raw === "OBSTRUCTED") return "UNAVAILABLE";
                    if (raw === "REMOVED") return "UNAVAILABLE";
                    if (raw === "SOLD") return "SOLD";
                    if (raw === "RESERVED") return "RESERVED";
                    if (raw === "BOOKED") return "BOOKED";
                    if (raw === "PENDING") return "PENDING";
                    if (raw === "CONFIRMED") return "CONFIRMED";

                    return raw;
                }

                function toNumber(value, fallback) {
                    const number = Number(value);
                    return Number.isFinite(number) ? number : fallback;
                }

                function makeSeatNumber(seat, rowName, seatNo) {
                    return seat.seatNumber
                        || seat.name
                        || `${seat.floor || 1}층 ${seat.sectionName || seat.section || "A"}구역 ${rowName}열 ${seatNo}번`;
                }

                window.CATCHCATCH_SEATS = Array.isArray(rawSeats)
                    ? rawSeats.map((seat) => {
                        const grade = normalizeGrade(seat.grade || seat.gradeCode || seat.seatGrade);
                        const rowName = seat.rowName || seat.row || seat.seatRow || "A";
                        const seatNo = seat.seatNo || seat.seatNumberOnly || seat.no || seat.number || seat.seatCol || seat.col || 1;
                        const status = normalizeStatus(seat.status || seat.seatStatus);

                        return {
                            ...seat,

                            id: seat.id || seat.seatId || `${seat.floor || 1}-${seat.sectionName || seat.section || "A"}-${rowName}-${seatNo}`,

                            floor: toNumber(seat.floor, 1),
                            sectionName: seat.sectionName || seat.section || "A",

                            rowName,
                            row: rowName,
                            seatRow: rowName,

                            seatNo,
                            number: seatNo,
                            no: seatNo,
                            seatCol: toNumber(seat.seatCol || seat.col || seatNo, 1),

                            seatNumber: makeSeatNumber(seat, rowName, seatNo),

                            grade,
                            gradeCode: grade,
                            gradeName: seat.gradeName || gradeName(grade),

                            price: toNumber(seat.price || seat.seatPrice, 0),

                            status,
                            bookingStatus: seat.bookingStatus || seat.booking_status || "",

                            x: toNumber(seat.x || seat.xLabel, 0),
                            y: toNumber(seat.y || seat.yLabel, 0),
                            xLabel: toNumber(seat.xLabel || seat.x, 0),
                            yLabel: toNumber(seat.yLabel || seat.y, 0),

                            size: toNumber(seat.size, 14),
                            angle: toNumber(seat.angle, 0)
                        };
                    })
                    : [];

                window.CATCHCATCH_SEAT_META = {
                    concertId: "{{concertId}}",
                    sessionId: "{{sessionId}}",
                    maxSelectCount: 4,
                    defaultSeatSize: 14,
                    defaultSeatAngle: 0
                };
            })();
        </script>

        <script src="/js/booking/seat.js?v=20260624"></script>

    </div>
</main>

{{> layout/footer}}