{{> layout/header-booking}}

<main class="cc-booking-seat-main">
    <div class="cc-seat-popup" id="bookingSeatApp" data-max-select="4" data-concert-id="{{concertId}}" data-session-id="{{sessionId}}">
        <header class="cc-seat-topbar">
            <div class="cc-seat-topbar__title">좌석 선택</div>
            <div class="cc-seat-topbar__concert">{{#bookingTitle}}{{bookingTitle}}{{/bookingTitle}}{{^bookingTitle}}CatchCatch Concert{{/bookingTitle}}</div>
            <select class="cc-seat-topbar__session" aria-label="공연 회차">
                <option>2027.01.09 (토) 18:00</option>
            </select>
        </header>

        <section class="cc-seat-body">
            <section class="cc-seat-map-panel">
                <p class="cc-seat-notice">무대는 예매 편의를 위해 표기된 것으로 실제 무대와 다를 수 있습니다.</p>

                <div class="cc-map-stage" id="overviewStage">
                    <div class="cc-map-image-wrap" id="mapImageWrap">
                        <img id="seatmapImage"
                             class="cc-map-image"
                             src="/temp/seatmap/seat/seatmap-image.png"
                             alt="좌석도">
                        <svg id="zoneOverlay"
                             class="cc-zone-overlay"
                             aria-label="구역 선택"></svg>
                    </div>

                    <div class="cc-seat-grid-view" id="seatGridView" hidden>
                        <div class="cc-seat-grid-head">
                            <button type="button" class="cc-seat-grid-back" id="backToMapBtn">좌석도 보기</button>
                            <div>
                                <strong id="seatGridTitle">구역 좌석</strong>
                                <span id="seatGridSub">좌석을 선택해주세요.</span>
                            </div>
                        </div>
                        <div id="realSeatGrid" class="cc-real-seat-grid" aria-label="좌석 행열"></div>
                    </div>

                    <div class="cc-bottom-guide" id="bottomGuide">
                        <span id="bottomGuideText">구역을 먼저 선택해주세요 <small>(화면을 직접 선택하거나 우측 좌석등급을 선택해주세요)</small></span>
                        <button type="button" class="cc-guide-reset-btn" id="resetSelectionBtn">초기화</button>
                    </div>
                </div>
            </section>

            <aside class="cc-seat-side-panel">
                <h1 class="cc-seat-brand">CatchCatch</h1>

                <div class="cc-mini-map-box">
                    <div class="cc-mini-map" id="miniMapWrap">
                        <img id="miniSeatmapImage" src="/temp/seatmap/seat/seatmap-image.png" alt="미니 좌석도">
                        <svg id="miniZoneOverlay" class="cc-mini-zone-overlay" aria-hidden="true"></svg>
                    </div>
                    <button type="button" class="cc-full-map-btn" id="showFullMapBtn">좌석도 전체보기 〉</button>
                </div>

                <section class="cc-grade-panel">
                    <div class="cc-grade-panel__head">
                        <h2>좌석등급/잔여석 <span>ⓘ</span></h2>
                        <button type="button" id="refreshZoneBtn">새로고침</button>
                    </div>
                    <div class="cc-grade-list" id="gradeList"></div>
                </section>

                <section class="cc-selected-panel">
                    <h3>선택 좌석</h3>
                    <div id="selectedSeatList" class="cc-selected-seat-list">선택된 좌석이 없습니다.</div>
                </section>

                <form action="/booking/complete" method="post" id="seatCompleteForm" class="cc-seat-submit-form">
                    <input type="hidden" name="seatIds" id="selectedSeatIds">
                    <div id="selectedSeatInputs"></div>
                    <input type="hidden" name="sessionId" value="{{sessionId}}">
                    <input type="hidden" name="concertId" value="{{concertId}}">
                    <button type="submit" class="cc-seat-complete-btn" id="seatCompleteBtn" disabled>
                        좌석 선택 완료 <span>〉</span>
                    </button>
                </form>
            </aside>
        </section>
    </div>

    <script>
        (() => {
            const rawSeats =
            {{#seat.seatsJson}}
                {{{seat.seatsJson}}}
            {{/seat.seatsJson}}
            {{^seat.seatsJson}}
                []
            {{/seat.seatsJson}};

            window.CATCHCATCH_SEATS = Array.isArray(rawSeats) ? rawSeats : [];
            window.CATCHCATCH_SEAT_META = {
                concertId: "{{concertId}}",
                sessionId: "{{sessionId}}",
                maxSelectCount: 4,
                projectId: "seat",
                seatmapImageUrl: "/temp/seatmap/seat/seatmap-image.png",
                bookingButtonsUrl: "/temp/seatmap/seat/booking-buttons.json"
            };
        })();
    </script>

    <script src="/js/booking/seat.js?v=2026063002"></script>
    {{#errorMessage}}
        <script>
            window.addEventListener('load', function() {
                const errorMsg = "{{errorMessage}}";
            if (errorMsg && errorMsg.trim() !== "") {
                CcUI.alert(errorMsg);
            }
        });
        </script>
    {{/errorMessage}}
</main>

{{> layout/footer}}
