{{> layout/header-booking}}

<main class="cc-main">
    <div class="cc-container cc-seat-container">

        <section class="cc-seat-layout cc-seat-layout--wide">

            <!-- 좌석 선택 영역 -->
            <section class="cc-card cc-seat-map-card">
                <div class="cc-seat-redesign cc-seat-redesign--wide">

                    <!-- 전체 좌석도 -->
                    <section class="cc-zone-overview cc-zone-overview--large">
                        <div class="cc-zone-overview__head">
                            <strong>전체 좌석도</strong>
                            <span>등급을 선택하면 좌석이 표시됩니다.</span>
                        </div>

                        <div class="cc-zone-overview__image-box cc-zone-overview__image-box--large">
                            <img src="/images/sample/seat.jpg"
                                 alt="전체 좌석도"
                                 class="cc-zone-overview__image">

                            <div id="seatImageHoverLayer" class="cc-seat-image-hover-layer"></div>
                        </div>

                        <div class="cc-zone-tabs" aria-label="좌석 등급 선택">
                            {{#seat.gradeTabs}}
                                <button type="button"
                                        class="cc-zone-tab {{#active}}is-active{{/active}}"
                                        data-grade="{{grade}}">
                                    {{gradeName}}
                                </button>
                            {{/seat.gradeTabs}}

                            {{^seat.gradeTabs}}
                                <button type="button"
                                        class="cc-zone-tab is-active"
                                        data-grade="">
                                    좌석 없음
                                </button>
                            {{/seat.gradeTabs}}
                        </div>

                        <div class="cc-zone-legend cc-zone-legend--row">
                            <div>
                                <i class="cc-seat-sample cc-seat-sample--available"></i>
                                예매 가능
                            </div>
                            <div>
                                <i class="cc-seat-sample cc-seat-sample--selected"></i>
                                선택 좌석
                            </div>
                            <div>
                                <i class="cc-seat-sample cc-seat-sample--sold"></i>
                                매진
                            </div>
                        </div>
                    </section>

                    <!-- 선택 등급 좌석 -->
                    <section class="cc-zone-detail">
                        <div class="cc-zone-detail__top">
                            <div>
                                <h3 id="zoneTitle">좌석 등급</h3>
                                <p id="zoneSubText">좌석을 선택해주세요.</p>
                            </div>

                            <div class="cc-zone-stage">STAGE</div>
                        </div>

                        <div id="zoneSeatGrid"
                             class="cc-zone-seat-grid"
                             aria-label="좌석 선택"></div>

                        <div class="cc-zone-bottom">
                            <button type="button"
                                    class="cc-small-btn"
                                    id="resetZoneBtn">
                                좌석 다시 선택
                            </button>

                            <span id="seatHoverInfo">
                                최대 4석까지 선택할 수 있습니다.
                            </span>
                        </div>
                    </section>

                </div>
            </section>

            <!-- 오른쪽 선택 좌석 -->
            <aside class="cc-seat-side">

                <div class="cc-card cc-selected-card">
                    <h3>선택 좌석</h3>

                    <div class="cc-timer">
                        <span>좌석 보관 시간</span>
                        <b data-countdown="600">10:00</b>
                    </div>

                    <div class="cc-selected-list">
                        <div class="cc-selected-seat">
                            <div>
                                <div class="cc-selected-seat__name">
                                    선택된 좌석이 없습니다.
                                </div>
                                <div class="cc-selected-seat__price">
                                    좌석을 선택하면 표시됩니다.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="cc-total">
                        <span>총 0석</span>
                        <strong class="cc-total__price">0원</strong>
                    </div>

                    <div class="cc-seat-actions">
                        <a class="cc-seat-prev"
                           href="/booking/info">
                            이전
                        </a>

                        <form action="/booking/complete"
                              method="post"
                              class="cc-complete-form">
                            <input type="hidden"
                                   name="seatIds"
                                   id="selectedSeatIds">

                            <input type="hidden"
                                   name="sessionId"
                                   value="{{sessionId}}">

                            <input type="hidden"
                                   name="concertId"
                                   value="{{concertId}}">

                            <button type="submit"
                                    class="cc-seat-complete-btn">
                                예매 완료
                            </button>
                        </form>
                    </div>
                </div>

                <div class="cc-card cc-notice-card">
                    <h3>유의사항</h3>
                    <ul>
                        <li>보관 시간이 초과되면 선택 좌석이 해제됩니다.</li>
                        <li>좌석은 최대 4석까지 선택할 수 있습니다.</li>
                    </ul>
                </div>

            </aside>

        </section>

        <script>
            window.CATCHCATCH_SEATS = {{{seat.seatsJson}}};
        </script>

        <script src="/js/booking-seat.js?v=20260610"></script>

    </div>
</main>

{{> layout/footer}}