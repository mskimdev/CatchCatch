{{> layout/header}}
<link rel="stylesheet" href="/css/booking-seat.css">
<main class="cc-main">
    <div class="cc-container">
        <div class="cc-stepper" aria-label="예매 진행 단계">
            <div class="cc-step is-done"><span class="cc-step__num">✓</span>예매정보</div><span class="cc-step-line"></span>
            <div class="cc-step is-active"><span class="cc-step__num">2</span>좌석선택</div><span class="cc-step-line"></span>
            <div class="cc-step"><span class="cc-step__num">3</span>결제</div><span class="cc-step-line"></span>
            <div class="cc-step"><span class="cc-step__num">4</span>완료</div>
        </div>

        <section class="cc-seat-layout">
            <aside>
                <div class="cc-card cc-booking-summary">
                    <div class="cc-booking-summary__dark">
                        <span class="cc-badge cc-badge--fill">단독판매</span>
                        <h2>{{#concert.title}}{{concert.title}}{{/concert.title}}{{^concert.title}}2026 무명전설 전국투어 콘서트 - 서울{{/concert.title}}</h2>
                        <p class="cc-booking-summary__line">📅 {{#sessionText}}{{sessionText}}{{/sessionText}}{{^sessionText}}2026.06.27 (토) 18:00{{/sessionText}}</p>
                        <p class="cc-booking-summary__line">📍 {{#venueText}}{{venueText}}{{/venueText}}{{^venueText}}서울 · 올림픽공원 올림픽홀{{/venueText}}</p>
                        <div class="cc-booking-summary__poster"><img src="{{#concert.posterUrl}}{{concert.posterUrl}}{{/concert.posterUrl}}{{^concert.posterUrl}}/images/sample/poster-legend-seoul.svg{{/concert.posterUrl}}" alt="공연 포스터"></div>
                    </div>
                </div>
                <div class="cc-card cc-booking-info">
                    <h3>예매 정보</h3>
                    <div class="cc-mini-row"><b>관람일시</b><span>{{#sessionText}}{{sessionText}}{{/sessionText}}{{^sessionText}}2026.06.27 (토) 18:00{{/sessionText}}</span></div>
                    <div class="cc-mini-row"><b>관람장소</b><span>{{#venueName}}{{venueName}}{{/venueName}}{{^venueName}}올림픽공원 올림픽홀{{/venueName}}</span></div>
                    <div class="cc-mini-row"><b>관람등급</b><span>만 7세 이상</span></div>
                    <div class="cc-mini-row"><b>관람시간</b><span>120분</span></div>
                    <div class="cc-mini-row"><b>매수제한</b><span>회차당 1인 4매</span></div>
                </div>
            </aside>

            <section class="cc-card cc-seat-map-card">
                <div class="cc-seat-map-head">
                    <div class="cc-grade-list">
                        <h3>좌석 등급</h3>
                        {{#grades}}
                        <div class="cc-grade-row"><i class="cc-dot cc-dot--{{gradeClass}}"></i><span>{{name}}<small>{{priceText}}</small></span></div>
                        {{/grades}}
                        {{^grades}}
                        <div class="cc-grade-row"><i class="cc-dot cc-dot--vip"></i><span>VIP<small>154,000원</small></span></div>
                        <div class="cc-grade-row"><i class="cc-dot cc-dot--r"></i><span>R<small>121,000원</small></span></div>
                        <div class="cc-grade-row"><i class="cc-dot cc-dot--s"></i><span>S<small>99,000원</small></span></div>
                        <div class="cc-grade-row"><i class="cc-dot cc-dot--a"></i><span>A<small>77,000원</small></span></div>
                        {{/grades}}
                    </div>
                    <div class="cc-stage">STAGE</div>
                    <div class="cc-seat-status">
                        <div><i class="cc-dot cc-dot--vip"></i>선택 좌석</div>
                        <div><i class="cc-dot cc-dot--gray"></i>예매 가능</div>
                        <div><i class="cc-dot cc-dot--a"></i>임시 보관</div>
                        <div><i class="cc-dot cc-dot--gray"></i>매진</div>
                    </div>
                </div>
                <div class="cc-arena" aria-label="좌석 배치도">
                    {{#seatZones}}
                    <section class="cc-zone cc-zone--{{zoneClass}}">
                        <span class="cc-zone__name">{{name}}</span>
                        <div class="cc-zone__dots">
                            {{#seats}}<button type="button" class="cc-seat-dot cc-seat-dot--{{gradeClass}} {{statusClass}} {{#selected}}cc-seat-dot--selected{{/selected}}" data-seat-id="{{id}}" aria-label="{{seatNumber}}">{{#selected}}✓{{/selected}}</button>{{/seats}}
                        </div>
                    </section>
                    {{/seatZones}}
                    {{^seatZones}}
                    <section class="cc-zone cc-zone--g"><span class="cc-zone__name">가</span><div class="cc-zone__dots"><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button type="button" class="cc-seat-dot cc-seat-dot--sold" aria-label="좌석"></button><button typ