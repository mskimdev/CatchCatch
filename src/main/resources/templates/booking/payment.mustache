{{> layout/header}}
<link rel="stylesheet" href="/css/booking-payment.css">
<main class="cc-main">
    <div class="cc-container">
        <div class="cc-stepper" aria-label="예매 진행 단계">
            <div class="cc-step is-done"><span class="cc-step__num">✓</span>예매정보</div><span class="cc-step-line"></span>
            <div class="cc-step is-done"><span class="cc-step__num">✓</span>좌석선택</div><span class="cc-step-line"></span>
            <div class="cc-step is-active"><span class="cc-step__num">3</span>결제</div><span class="cc-step-line"></span>
            <div class="cc-step"><span class="cc-step__num">4</span>완료</div>
        </div>

        <section class="cc-payment-layout">
            <!-- 왼쪽: 예매 정보 요약 + 결제 수단 -->
            <div class="cc-payment-main">
                <div class="cc-card cc-payment-section">
                    <h3>예매 정보 확인</h3>
                    <div class="cc-payment-concert">
                        <img class="cc-payment-poster" src="{{#posterUrl}}{{posterUrl}}{{/posterUrl}}{{^posterUrl}}/images/sample/poster-legend-seoul.svg{{/posterUrl}}" alt="공연 포스터">
                        <div class="cc-payment-concert__info">
                            <p class="cc-payment-concert__title">{{#concertTitle}}{{concertTitle}}{{/concertTitle}}{{^concertTitle}}2026 무명전설 전국투어 콘서트 - 서울{{/concertTitle}}</p>
                            <p class="cc-payment-concert__line">📅 {{#sessionText}}{{sessionText}}{{/sessionText}}{{^sessionText}}2026.06.27 (토) 18:00{{/sessionText}}</p>
                            <p class="cc-payment-concert__line">📍 {{#venueText}}{{venueText}}{{/venueText}}{{^venueText}}서울 · 올림픽공원 올림픽홀{{/venueText}}</p>
                        </div>
                    </div>
                    <table class="cc-payment-table">
                        <thead>
                            <tr><th>좌석</th><th>등급</th><th>금액</th></tr>
                        </thead>
                        <tbody>
                            {{#selectedSeats}}
                            <tr>
                                <td>{{seatNumber}}</td>
                                <td><i class="cc-dot cc-dot--{{gradeClass}}"></i> {{grade}}</td>
                                <td>{{priceText}}</td>
                            </tr>
                            {{/selectedSeats}}
                            {{^selectedSeats}}
                            <tr>
                                <td>나구역 12열 15번</td>
                                <td><i class="cc-dot cc-dot--vip"></i> VIP</td>
                                <td>154,000원</td>
                            </tr>
                            <tr>
                                <td>나구역 12열 16번</td>
                                <td><i class="cc-dot cc-dot--vip"></i> VIP</td>
                                <td>154,000원</td>
                            </tr>
                            {{/selectedSeats}}
                        </tbody>
                    </table>
                </div>

                <div class="cc-card cc-payment-section">
                    <h3>예매자 정보</h3>
                    <div class="cc-info-list">
                        <div class="cc-info-row"><span class="cc-info-row__label">이름</span><span>{{#userName}}{{userName}}{{/userName}}{{^userName}}홍길동{{/userName}}</span></div>
                        <div class="cc-info-row"><span class="cc-info-row__label">연락처</span><span>{{#userPhone}}{{userPhone}}{{/userPhone}}{{^userPhone}}010-1234-5678{{/userPhone}}</span></div>
                        <div class="cc-info-row"><span class="cc-info-row__label">이메일</span><span>{{#userEmail}}{{userEmail}}{{/userEmail}}{{^userEmail}}user@example.com{{/userEmail}}</span></div>
                    </div>
                </div>

                <div class="cc-card cc-payment-section">
                    <h3>결제 수단</h3>
                    <form id="paymentForm" action="/booking/payment/confirm" method="post">
                        {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}">{{/_csrf}}
                        <input type="hidden" name="bookingId" value="{{bookingId}}">
                        <input type="hidden" name="merchantUid" value="{{merchantUid}}">
                        <input type="hidden" name="amount" value="{{#totalPrice}}{{totalPrice}}{{/totalPrice}}{{^totalPrice}}308000{{/totalPrice}}">

                        <div class="cc-pay-methods">
                            <label class="cc-pay-method is-active">
                                <input type="radio" name="method" value="card" checked>
                                <span class="cc-pay-method__icon">💳</span>
                                <span>신용/체크카드</span>
                            </label>
                            <label class="cc-pay-method">
                                <input type="radio" name="method" value="kakaopay">
                                <span class="cc-pay-method__icon" style="background:#fee500;color:#3c1e1e">K</span>
                                <span>카카오페이</span>
                            </label>
                            <label class="cc-pay-method">
                                <input type="radio" name="method" value="tosspay">
                                <span class="cc-pay-method__icon" style="background:#0064ff;color:#fff">T</span>
                                <span>토스페이</span>
                            </label>
                            <label class="cc-pay-method">
                                <input type="radio" name="method" value="vbank">
                                <span class="cc-pay-method__icon">🏦</span>
                                <span>무통장 입금</span>
                            </label>
                        </div>

                        <div class="cc-register-agree" style="margin-top:20px">
                            <label class="cc-check" style="font-weight:950;padding-bottom:10px;border-bottom:1px solid var(--cc-line);margin-bottom:10px;display:flex">
                                <input type="checkbox" id="payAgreeAll"> 구매조건 전체 동의
                            </label>
                            <div class="cc-register-agree__items">
                                <label class="cc-check" style="font-size:14px;color:var(--cc-subtext);display:flex;align-items:center">
                                    <input type="checkbox" class="pay-agree-item" required> [필수] 개인정보 수집·이용 동의
                                </label>
                                <label class="cc-check" style="font-size:14px;color:var(--cc-subtext);display:flex;align-items:center">
                                    <input type="checkbox" class="pay-agree-item" required> [필수] 결제 서비스 이용약관 동의
                                </label>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- 오른쪽: 결제 금액 요약 -->
            <aside>
                <div class="cc-card cc-payment-summary">
                    <h3>결제 금액</h3>
                    <div class="cc-price-box__row"><span>티켓 금액</span><b>{{#ticketPriceText}}{{ticketPriceText}}{{/ticketPriceText}}{{^ticketPriceText}}308,000원{{/ticketPriceText}}</b></div>
                    <div class="cc-price-box__row"><span>예매 수수료</span><b>{{#feeText}}{{feeText}}{{/feeText}}{{^feeText}}0원{{/feeText}}</b></div>
                    <div class="cc-payment-total">
                        <span>최종 결제 금액</span>
                        <strong class="cc-total__price">{{#totalPriceText}}{{totalPriceText}}{{/totalPriceText}}{{^totalPriceText}}308,000원{{/totalPriceText}}</strong>
                    </div>
                    <button class="cc-btn cc-btn--primary cc-btn--full" type="submit" form="paymentForm">
                        결제하기
                    </button>
                    <a class="cc-btn cc-btn--outline cc-btn--full" style="margin-top:10px"
                       href="/booking/seat?concertId={{#concertId}}{{concertId}}{{/concertId}}{{^concertId}}1{{/concertId}}">
                        이전 단계
                    </a>
                </div>

                <div class="cc-card cc-notice-card" style="margin-top:14px">
                    <h3>ⓘ 유의사항</h3>
                    <ul>
                        <li>예매 완료 후 취소 시 취소 수수료가 발생할 수 있습니다.</li>
                        <li>무통장 입금 선택 시 당일 23:59까지 입금해야 예매가 완료됩니다.</li>
                        <li>본인 명의 결제 수단만 사용 가능합니다.</li>
                    </ul>
                </div>
            </aside>
        </section>
    </div>
</main>

{{> layout/footer}}