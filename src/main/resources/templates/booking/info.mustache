{{> layout/header-booking}}
<link rel="stylesheet" href="/css/booking-info.css">

<main class="cc-main cc-info-page">
    <div class="cc-info-container">

        {{#concert}}
            <section class="cc-info-hero">

                <aside class="cc-info-poster-card">
                    {{#category}}
                        <span class="cc-badge cc-badge--fill">{{category}}</span>
                    {{/category}}

                    <div class="cc-info-poster">
                        <img src="{{posterUrl}}" alt="{{title}} 포스터">
                    </div>
                </aside>

                <section class="cc-info-panel">

                    <div class="cc-info-head">
                        <p class="cc-info-label">예매 정보 확인</p>

                        <h1>{{title}}</h1>

                        <div class="cc-info-tags">
                            {{#category}}
                                <span class="cc-mini-badge">{{category}}</span>
                            {{/category}}

                            {{#genre}}
                                <span class="cc-mini-badge is-muted">{{genre}}</span>
                            {{/genre}}
                        </div>

                        <p class="cc-info-sub">
                            선택한 공연과 관람 회차를 확인한 뒤 좌석을 선택해주세요.
                        </p>
                    </div>

                    <div class="cc-info-summary">
                        <div class="cc-info-summary-item is-wide">
                            <span>관람일시</span>
                            <strong>{{sessionText}}</strong>
                        </div>

                        <div class="cc-info-summary-item is-wide">
                            <span>공연장</span>
                            <strong>{{venueName}}</strong>
                        </div>

                        <div class="cc-info-summary-item">
                            <span>관람등급</span>
                            <strong>{{ageLimit}}</strong>
                        </div>

                        <div class="cc-info-summary-item">
                            <span>관람시간</span>
                            <strong>{{runtime}}</strong>
                        </div>

                        <div class="cc-info-summary-item">
                            <span>매수제한</span>
                            <strong>회차당 1인 4매</strong>
                        </div>

                        {{#organizer}}
                            <div class="cc-info-summary-item">
                                <span>주최/주관</span>
                                <strong>{{organizer}}</strong>
                            </div>
                        {{/organizer}}

                        {{#contact}}
                            <div class="cc-info-summary-item">
                                <span>문의</span>
                                <strong>{{contact}}</strong>
                            </div>
                        {{/contact}}
                    </div>

                    <div class="cc-info-price-box">
                        <div class="cc-info-price-head">
                            <h2>좌석 등급별 가격</h2>
                            <span>다음 단계에서 좌석 선택</span>
                        </div>

                        <div class="cc-info-price-list">
                            {{#prices}}
                                <div class="cc-info-price-chip">
                                    <span>
                                        <i class="cc-dot cc-dot--{{gradeClass}}"></i>{{gradeName}}
                                    </span>
                                    <strong>{{priceText}}</strong>
                                </div>
                            {{/prices}}

                            {{^prices}}
                                <p class="cc-info-empty">등록된 좌석 가격 정보가 없습니다.</p>
                            {{/prices}}
                        </div>
                    </div>

                    <div class="cc-info-bottom">
                        <p>좌석 선택 후 10분 이내에 결제를 완료해야 합니다.</p>

                        <div class="cc-info-actions">
                            <a class="cc-info-back" href="/concerts/{{id}}">
                                이전
                            </a>

                            <form action="/booking/seat" method="get">
                                <input type="hidden" name="concertId" value="{{id}}">
                                <input type="hidden" name="sessionId" value="{{sessionId}}">

                                <button class="cc-info-next" type="submit">
                                    좌석 선택하기
                                </button>
                            </form>
                        </div>
                    </div>

                </section>

            </section>
        {{/concert}}

        {{^concert}}
            <section class="cc-info-panel">
                <div class="cc-info-head">
                    <p class="cc-info-label">예매 정보 확인</p>
                    <h1>공연 정보를 찾을 수 없습니다.</h1>
                    <p class="cc-info-sub">요청한 공연이 존재하지 않거나 삭제된 공연입니다.</p>
                </div>

                <div class="cc-info-bottom">
                    <p>공연 상세 페이지로 돌아가 다시 예매를 진행해주세요.</p>

                    <div class="cc-info-actions">
                        <a class="cc-info-back" href="/concerts">
                            공연 목록으로
                        </a>
                    </div>
                </div>
            </section>
        {{/concert}}

    </div>
</main>

{{> layout/footer}}