{{> layout/header}}

<div class="cc-stepper" aria-label="예매 진행 단계">
    <div class="cc-step is-active"><span class="cc-step__num">1</span>예매정보</div>
    <span class="cc-step-line"></span>
    <div class="cc-step"><span class="cc-step__num">2</span>좌석선택</div>
    <span class="cc-step-line"></span>
    <div class="cc-step"><span class="cc-step__num">3</span>결제</div>
    <span class="cc-step-line"></span>
    <div class="cc-step"><span class="cc-step__num">4</span>완료</div>
</div>

<section class="cc-info-layout">

    <!-- 왼쪽 공연 요약 -->
    <aside class="cc-info-left">
        <div class="cc-card cc-booking-summary">
            <div class="cc-booking-summary__dark">
                <span class="cc-badge cc-badge--fill">단독판매</span>

                <h2>
                    {{#concert.title}}{{concert.title}}{{/concert.title}}
                    {{^concert.title}}테스트 콘서트{{/concert.title}}
                </h2>

                <p class="cc-booking-summary__line">
                    📅
                    {{#sessionText}}{{sessionText}}{{/sessionText}}
                    {{^sessionText}}2026.06.27 (토) 18:00{{/sessionText}}
                </p>

                <p class="cc-booking-summary__line">
                    📍
                    {{#venueText}}{{venueText}}{{/venueText}}
                    {{^venueText}}서울 · 올림픽공원 올림픽홀{{/venueText}}
                </p>

                <div class="cc-booking-summary__poster">
                    <img
                            src="{{#concert.posterUrl}}{{concert.posterUrl}}{{/concert.posterUrl}}{{^concert.posterUrl}}/images/sample/poster-legend-seoul.svg{{/concert.posterUrl}}"
                            alt="공연 포스터">
                </div>
            </div>
        </div>
    </aside>

    <!-- 중앙 예매 정보 확인 -->
    <section class="cc-card cc-info-main">
        <div class="cc-info-main__head">
            <div>
                <h2>예매 정보 확인</h2>
                <p>선택한 공연과 관람 회차를 확인한 뒤 좌석을 선택해주세요.</p>
            </div>
        </div>

        <div class="cc-info-section">
            <h3>공연 정보</h3>

            <div class="cc-info-grid">
                <div class="cc-info-item">
                    <b>공연명</b>
                    <span>
                        {{#concert.title}}{{concert.title}}{{/concert.title}}
                        {{^concert.title}}테스트 콘서트{{/concert.title}}
                    </span>
                </div>

                <div class="cc-info-item">
                    <b>공연장</b>
                    <span>
                        {{#venueName}}{{venueName}}{{/venueName}}
                        {{^venueName}}올림픽공원 올림픽홀{{/venueName}}
                    </span>
                </div>

                <div class="cc-info-item">
                    <b>관람등급</b>
                    <span>
                        {{#concert.ageLimit}}{{concert.ageLimit}}{{/concert.ageLimit}}
                        {{^concert.ageLimit}}만 7세 이상{{/concert.ageLimit}}
                    </span>
                </div>

                <div class="cc-info-item">
                    <b>관람시간</b>
                    <span>
                        {{#concert.runtime}}{{concert.runtime}}{{/concert.runtime}}
                        {{^concert.runtime}}120분{{/concert.runtime}}
                    </span>
                </div>
            </div>
        </div>

        <div class="cc-info-section">
            <h3>선택 회차</h3>

            <div class="cc-selected-session-box">
                <div>
                    <strong>
                        {{#sessionText}}{{sessionText}}{{/sessionText}}
                        {{^sessionText}}2026.06.27 (토) 18:00{{/sessionText}}
                    </strong>
                    <p>해당 회차의 좌석을 다음 단계에서 선택합니다.</p>
                </div>

                <span class="cc-session-badge">선택 완료</span>
            </div>
        </div>

        <div class="cc-info-section">
            <h3>좌석 등급별 가격</h3>

            <div class="cc-price-list cc-price-list--booking">
                {{#prices}}
                    <div class="cc-price-row">
                        <span>
                            <i class="cc-dot cc-dot--{{gradeClass}}"></i>{{gradeName}}
                        </span>
                        <strong>{{priceText}}</strong>
                    </div>
                {{/prices}}

                {{^prices}}
                    <div class="cc-price-row">
                        <span><i class="cc-dot cc-dot--vip"></i>VIP석</span>
                        <strong>165,000원</strong>
                    </div>
                    <div class="cc-price-row">
                        <span><i class="cc-dot cc-dot--r"></i>R석</span>
                        <strong>132,000원</strong>
                    </div>
                    <div class="cc-price-row">
                        <span><i class="cc-dot cc-dot--s"></i>S석</span>
                        <strong>110,000원</strong>
                    </div>
                    <div class="cc-price-row">
                        <span><i class="cc-dot cc-dot--a"></i>A석</span>
                        <strong>88,000원</strong>
                    </div>
                    <div class="cc-price-row">
                        <span><i class="cc-dot cc-dot--b"></i>B석</span>
                        <strong>66,000원</strong>
                    </div>
                {{/prices}}
            </div>
        </div>
    </section>

    <!-- 오른쪽 진행 카드 -->
    <aside class="cc-info-right">
        <div class="cc-card cc-info-confirm-card">
            <h3>예매 진행</h3>

            <div class="cc-mini-row">
                <b>선택 공연</b>
                <span>
                    {{#concert.title}}{{concert.title}}{{/concert.title}}
                    {{^concert.title}}테스트 콘서트{{/concert.title}}
                </span>
            </div>

            <div class="cc-mini-row">
                <b>관람일시</b>
                <span>
                    {{#sessionText}}{{sessionText}}{{/sessionText}}
                    {{^sessionText}}2026.06.27 (토) 18:00{{/sessionText}}
                </span>
            </div>

            <div class="cc-mini-row">
                <b>매수제한</b>
                <span>회차당 1인 4매</span>
            </div>

            <div class="cc-info-divider"></div>

            <form action="/booking/seat" method="get">
                <input type="hidden" name="concertId"
                       value="{{#concert.id}}{{concert.id}}{{/concert.id}}{{^concert.id}}{{concertId}}{{/concert.id}}">

                <input type="hidden" name="sessionId"
                       value="{{#sessionId}}{{sessionId}}{{/sessionId}}{{^sessionId}}1{{/sessionId}}">

                <button class="cc-btn cc-btn--primary cc-btn--full" type="submit">
                    좌석 선택하기
                </button>
            </form>

            <a class="cc-btn cc-btn--outline cc-btn--full cc-prev-link"
               href="/concerts/{{#concert.id}}{{concert.id}}{{/concert.id}}{{^concert.id}}{{concertId}}{{/concert.id}}">
                이전 단계
            </a>
        </div>

        <div class="cc-card cc-notice-card">
            <h3>유의사항</h3>
            <ul>
                <li>좌석은 다음 단계에서 선택할 수 있습니다.</li>
                <li>좌석은 최대 4석까지 선택할 수 있습니다.</li>
                <li>좌석 선택 후 10분 이내에 결제를 진행해야 합니다.</li>
                <li>무통장 입금 선택 시 예매 당일 23:59까지 입금해야 예매가 완료됩니다.</li>
            </ul>
        </div>
    </aside>

</section>

{{> layout/footer}}