{{> layout/header}}

<style>
    .ticket-verify-page {
        min-height: 100vh;
        background-color: #f7f4ff;
        padding: 40px 16px;
    }

    .ticket-verify-container {
        max-width: 480px;
        margin: 0 auto;
    }

    .ticket-verify-card {
        padding: 28px 24px;
        border-radius: 16px;
        background-color: #fff;
        border: 1px solid #eee;
        box-shadow: 0 6px 24px rgba(80, 45, 140, 0.12);
    }

    .ticket-verify-card h2 {
        margin: 0 0 20px;
        font-size: 24px;
        font-weight: 800;
        color: #222;
    }

    .ticket-verify-message {
        padding: 14px 16px;
        margin-bottom: 22px;
        border-radius: 10px;
        background-color: #f4f0ff;
        color: #6d28d9;
        font-size: 18px;
        font-weight: 800;
        text-align: center;
    }

    .ticket-verify-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 12px 0;
        border-bottom: 1px solid #eee;
        font-size: 15px;
    }

    .ticket-verify-row span {
        color: #777;
        flex-shrink: 0;
    }

    .ticket-verify-row strong {
        text-align: right;
        color: #222;
        font-weight: 700;
    }

    .ticket-check-in-btn {
        width: 100%;
        height: 48px;
        margin-top: 24px;
        border: none;
        border-radius: 10px;
        background-color: #6d28d9;
        color: #fff;
        font-size: 16px;
        font-weight: 800;
        cursor: pointer;
    }

    .ticket-check-in-btn:hover {
        background-color: #5b21b6;
    }
</style>

<main class="ticket-verify-page">
    <div class="ticket-verify-container">
        <section class="ticket-verify-card">
            <h2>입장권 확인</h2>

            {{#result}}
                <div class="ticket-verify-message">
                    {{message}}
                </div>

                <div class="ticket-verify-row">
                    <span>예매번호</span>
                    <strong>{{bookingNumber}}</strong>
                </div>

                <div class="ticket-verify-row">
                    <span>공연명</span>
                    <strong>{{concertTitle}}</strong>
                </div>

                <div class="ticket-verify-row">
                    <span>공연장</span>
                    <strong>{{venueName}}</strong>
                </div>

                <div class="ticket-verify-row">
                    <span>예매자</span>
                    <strong>{{username}}</strong>
                </div>

                {{#valid}}
                    {{^checkedIn}}
                        <button type="button"
                                class="ticket-check-in-btn js-check-in"
                                data-token="{{token}}">
                            입장 처리
                        </button>
                    {{/checkedIn}}
                {{/valid}}
            {{/result}}
        </section>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.querySelector('.js-check-in');

        if (!btn) return;

        btn.addEventListener('click', async () => {
            const token = btn.dataset.token;

            const ok = confirm('입장 처리하시겠습니까?');
            if (!ok) return;

            const response = await fetch(`/api/staff/tickets/check-in?token=${encodeURIComponent(token)}`, {
                method: 'POST'
            });

            if (!response.ok) {
                const message = await response.text();
                alert(message);
                return;
            }

            alert('입장 처리되었습니다.');
            location.reload();
        });
    });
</script>

{{> layout/footer}}