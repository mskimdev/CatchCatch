{{> layout/header}}

<main class="cc-main">
    <div class="cc-container">
        <section class="cc-detail-card">
            <h2>입장권 확인</h2>

            {{#result}}
                <p><strong>{{message}}</strong></p>

                <div class="cc-detail-row">
                    <span>예매번호</span>
                    <strong>{{bookingNumber}}</strong>
                </div>

                <div class="cc-detail-row">
                    <span>공연명</span>
                    <strong>{{concertTitle}}</strong>
                </div>

                <div class="cc-detail-row">
                    <span>공연장</span>
                    <strong>{{venueName}}</strong>
                </div>

                <div class="cc-detail-row">
                    <span>예매자</span>
                    <strong>{{username}}</strong>
                </div>

                {{#valid}}
                    {{^checkedIn}}
                        <button type="button"
                                class="cc-payment-detail-btn js-check-in"
                                data-token="{{token}}">
                            입장 처리
                        </button>
                    {{/checkedIn}}
                {{/valid}}
            {{/result}}
        </section>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.querySelector('.js-check-in');

        if (!btn) return;

        btn.addEventListener('click', async () => {
            const token = btn.dataset.token;

            const ok = confirm('입장 처리하시겠습니까?');
            if (!ok) return;

            const response = await fetch(`/api/staff/tickets/check-in?token=${encodeURIComponent(token)}`, {
                method: 'POST'
            });

            if (!response.ok) {
                const message = await response.text();
                alert(message);
                return;
            }

            alert('입장 처리되었습니다.');
            location.reload();
        });
    });
</script>

{{> layout/footer}}