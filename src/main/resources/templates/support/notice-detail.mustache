{{> layout/header}}

<link rel="stylesheet" href="/css/support-faq.css">
<link rel="stylesheet" href="/css/support-notice.css">

<div class="cc-container cc-main">

    <h1 class="cc-customer__title">고객센터</h1>

    <div class="cc-customer">

        {{> support/layout/sidebar}}

        <main class="cc-notice-content">

            <div class="cc-content-header">
                <h2>공지사항</h2>
                <a class="cc-back-btn" href="/support/notices">목록으로</a>
            </div>

            {{#notice}}
            <div class="cc-notice-detail">
                <div class="cc-notice-detail__header">
                    {{#isPinned}}<span class="cc-notice-badge">공지</span>{{/isPinned}}
                    <h3 class="cc-notice-detail__title">{{title}}</h3>
                    <div class="cc-notice-detail__meta">
                        <span class="cc-notice-detail__date">{{createdAt}}</span>
                        <span class="cc-notice-detail__view">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            {{viewCount}}
                        </span>
                    </div>
                </div>
                <div class="cc-notice-detail__body">{{content}}</div>
            </div>
            {{/notice}}

        </main>

    </div>
</div>

{{> layout/footer}}
