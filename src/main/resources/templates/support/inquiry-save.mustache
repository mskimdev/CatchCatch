{{> layout/header}}

<link rel="stylesheet" href="/css/support-faq.css">
<link rel="stylesheet" href="/css/support-inquiry.css">

<div class="cc-container cc-main">

    <h1 class="cc-customer__title">고객센터</h1>

    <div class="cc-customer">

        {{> support/layout/sidebar}}

        <main class="cc-inquiry-content">

            <div class="cc-content-header">
                <h2>1:1 문의하기</h2>
                <p>문의 내용을 남겨주시면 영업일 기준 1~2일 내 답변 드립니다.</p>
            </div>

            <form class="cc-inquiry-form" action="/support/inquiries" method="post">

                <div class="cc-inquiry-form__row">
                    <label class="cc-inquiry-form__label" for="category">문의 유형 <span class="cc-inquiry-form__required">*</span></label>
                    <select class="cc-inquiry-form__select" id="category" name="category" required>
                        <option value="">선택해 주세요</option>
                        <option value="TICKET">예매/취소</option>
                        <option value="PAYMENT">결제</option>
                        <option value="USER">회원</option>
                        <option value="ETC">기타</option>
                    </select>
                </div>

                <div class="cc-inquiry-form__row">
                    <label class="cc-inquiry-form__label" for="title">제목 <span class="cc-inquiry-form__required">*</span></label>
                    <input class="cc-inquiry-form__input" type="text" id="title" name="title"
                           placeholder="문의 제목을 입력해 주세요" maxlength="100" required>
                </div>

                <div class="cc-inquiry-form__row">
                    <label class="cc-inquiry-form__label" for="content">문의 내용 <span class="cc-inquiry-form__required">*</span></label>
                    <textarea class="cc-inquiry-form__textarea" id="content" name="content"
                              placeholder="문의 내용을 자세히 입력해 주세요 (최대 2000자)" maxlength="2000" required></textarea>
                    <span class="cc-inquiry-form__counter"><span id="contentLength">0</span> / 2000</span>
                </div>

                <div class="cc-inquiry-form__row">
                    <label class="cc-inquiry-form__label">공개 범위</label>
                    <div class="cc-inquiry-notify">
                        <label class="cc-inquiry-notify__item">
                            <input type="checkbox" name="isPublic" value="true">
                            <span>공개</span>
                            <span class="cc-inquiry-notify__desc">비공개가 기본값입니다. 체크 시 다른 사용자도 열람할 수 있습니다.</span>
                        </label>
                    </div>
                </div>

                <div class="cc-inquiry-form__row">
                    <label class="cc-inquiry-form__label">답변 수신 방법</label>
                    <div class="cc-inquiry-notify">
                        <label class="cc-inquiry-notify__item">
                            <input type="checkbox" name="notifyEmail" value="true">
                            <span>이메일로 답변받기</span>
                        </label>
                        <label class="cc-inquiry-notify__item {{^hasPhone}}is-disabled{{/hasPhone}}">
                            <input type="checkbox" name="notifySms" value="true" {{^hasPhone}}disabled{{/hasPhone}}>
                            <span>문자로 답변받기</span>
                            {{^hasPhone}}
                                <span class="cc-inquiry-notify__warn">전화번호를 입력하셔야 받을 수 있습니다</span>
                                <a class="cc-inquiry-notify__link" href="/users/mypage">전화번호 입력하러 가기</a>
                            {{/hasPhone}}
                        </label>
                    </div>
                </div>

                <div class="cc-inquiry-form__actions">
                    <a class="cc-btn cc-btn--outline" href="/support/inquiries">취소</a>
                    <button class="cc-btn cc-btn--primary" type="submit">문의 등록</button>
                </div>

            </form>

        </main>

    </div>
</div>

<script src="/js/support/inquiry-save.js"></script>
{{> layout/footer}}