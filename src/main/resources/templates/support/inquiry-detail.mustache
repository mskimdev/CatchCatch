{{> layout/header}}

<link rel="stylesheet" href="/css/customercenter-faq.css">
<link rel="stylesheet" href="/css/customercenter-inquiry.css">

<div class="cc-container cc-main">

    <h1 class="cc-customer__title">고객센터</h1>

    <div class="cc-customer">

        <aside class="cc-side-menu">
            <a href="/support/faqs" class="cc-side-menu__item">FAQ</a>
            <a href="/support/inquiries/save" class="cc-side-menu__item">1:1 문의하기</a>
            <a href="/support/inquiries" class="cc-side-menu__item is-active">1:1 문의 내역</a>
            <a href="/support/notices" class="cc-side-menu__item">공지사항</a>
        </aside>

        <main class="cc-inquiry-content">

            <div class="cc-content-header">
                <h2>문의 상세</h2>
                <a class="cc-back-btn" href="/support/inquiries">목록으로</a>
            </div>

            {{#inquiry}}
            <div class="cc-inquiry-detail">
                <div class="cc-inquiry-detail__header">
                    <div class="cc-inquiry-detail__meta">
                        <span class="cc-inquiry-category">{{categoryLabel}}</span>
                        <span class="cc-inquiry-status {{statusClass}}">{{statusLabel}}</span>
                    </div>
                    <h3 class="cc-inquiry-detail__title">{{title}}</h3>
                    <div class="cc-inquiry-detail__info">
                        <span class="cc-inquiry-detail__author">{{username}}</span>
                        <span class="cc-inquiry-detail__date">{{createdAt}}</span>
                    </div>
                </div>

                <div class="cc-inquiry-detail__body">{{content}}</div>

                {{#hasReply}}
                <div class="cc-inquiry-detail__reply">
                    <div class="cc-inquiry-detail__reply-label">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        관리자 답변
                    </div>
                    <div class="cc-inquiry-detail__reply-body">{{reply}}</div>
                </div>
                {{/hasReply}}
                {{^hasReply}}
                <div class="cc-inquiry-detail__reply--pending">
                    아직 답변이 등록되지 않았습니다.
                </div>
                {{/hasReply}}
            </div>
            {{/inquiry}}

        </main>

    </div>
</div>

{{> layout/footer}}
