{{> layout/header}}

<link rel="stylesheet" href="/css/customercenter-faq.css">

<div class="cc-container cc-main">

    <h1 class="cc-customer__title">고객센터</h1>

    <div class="cc-customer">

        <aside class="cc-side-menu">
            <a href="/support/faqs" class="cc-side-menu__item is-active">FAQ</a>
            <a href="/support/inquiries/save" class="cc-side-menu__item">1:1 문의하기</a>
            <a href="/support/inquiries" class="cc-side-menu__item">1:1 문의 내역</a>
            <a href="/support/notices" class="cc-side-menu__item">공지사항</a>
        </aside>

        <main class="cc-faq-content">

            <div class="cc-content-header">
                <h2>FAQ</h2>
            </div>

            <form class="cc-faq-search" action="/support/faqs" method="get">
                <select name="category">
                    <option value="">전체</option>
                    <option value="MEMBER">회원</option>
                    <option value="BOOKING">예매</option>
                    <option value="PAYMENT">결제</option>
                    <option value="CANCEL_REFUND">취소/환불</option>
                    <option value="EVENT">이벤트/혜택</option>
                    <option value="SERVICE">서비스/기타</option>
                </select>

                <input type="text" name="keyword" placeholder="궁금한 점을 검색해 보세요" value="{{keyword}}">
                <button type="submit">검색</button>
            </form>

            <div class="cc-faq-tabs">
                <a href="/support/faqs" class="cc-faq-tab {{#isAll}}is-active{{/isAll}}">전체</a>
                <a href="/support/faqs?category=MEMBER" class="cc-faq-tab {{#isMember}}is-active{{/isMember}}">회원</a>
                <a href="/support/faqs?category=BOOKING" class="cc-faq-tab {{#isBooking}}is-active{{/isBooking}}">예매</a>
                <a href="/support/faqs?category=PAYMENT" class="cc-faq-tab {{#isPayment}}is-active{{/isPayment}}">결제</a>
                <a href="/support/faqs?category=CANCEL_REFUND" class="cc-faq-tab {{#isCancelRefund}}is-active{{/isCancelRefund}}">취소/환불</a>
                <a href="/support/faqs?category=EVENT" class="cc-faq-tab {{#isEvent}}is-active{{/isEvent}}">이벤트/혜택</a>
                <a href="/support/faqs?category=SERVICE" class="cc-faq-tab {{#isService}}is-active{{/isService}}">서비스/기타</a>
            </div>

            <table class="cc-faq-table">
                <thead>
                <tr>
                    <th>카테고리</th>
                    <th>제목</th>
                    <th>등록일</th>
                </tr>
                </thead>

                <tbody>
                {{#faqs}}
                    <tr>
                        <td>{{category.label}}</td>
                        <td>{{question}}</td>
                        <td>{{formattedCreatedAt}}</td>
                    </tr>
                {{/faqs}}

                {{^faqs}}
                    <tr>
                        <td colspan="3" class="cc-empty-message">등록된 FAQ가 없습니다.</td>
                    </tr>
                {{/faqs}}
                </tbody>
            </table>

            <div class="cc-pagination">
                <a href="#">≪</a>
                <a href="#">‹</a>
                <a href="#" class="is-active">1</a>
                <a href="#">›</a>
                <a href="#">≫</a>
            </div>

        </main>

    </div>
</div>

{{> layout/footer}}
