{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <!-- 페이지 헤더 -->
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">대시보드</h1>
                    <div class="btn-group" role="group" id="periodBtnGroup">
                        <button type="button" data-period="TODAY" class="btn btn-sm {{#summary.periodIsToday}}btn-primary{{/summary.periodIsToday}}{{^summary.periodIsToday}}btn-outline-primary{{/summary.periodIsToday}}">오늘</button>
                        <button type="button" data-period="WEEK"  class="btn btn-sm {{#summary.periodIsWeek}}btn-primary{{/summary.periodIsWeek}}{{^summary.periodIsWeek}}btn-outline-primary{{/summary.periodIsWeek}}">최근 7일</button>
                        <button type="button" data-period="MONTH" class="btn btn-sm {{#summary.periodIsMonth}}btn-primary{{/summary.periodIsMonth}}{{^summary.periodIsMonth}}btn-outline-primary{{/summary.periodIsMonth}}">최근 30일</button>
                    </div>
                </div>

                <!-- KPI 카드 1행: 기간 필터 집계 지표 -->
                <div class="row">
                    <!-- 매출 -->
                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-success shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">매출</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-sales">{{summary.totalSalesAmountFormatted}}원</div>
                                        <div class="mt-1 small {{#summary.salesUp}}text-success{{/summary.salesUp}}{{^summary.salesUp}}text-danger{{/summary.salesUp}}" id="kpi-sales-diff">
                                            {{summary.diffLabel}} 대비 {{summary.salesAmountDiffFormatted}}원
                                        </div>
                                    </div>
                                    <div class="col-auto"><i class="fas fa-won-sign fa-2x text-gray-300"></i></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 예매 완료 -->
                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-primary shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">예매 완료</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-booking">{{summary.bookingCount}}건</div>
                                        <div class="mt-1 small {{#summary.bookingUp}}text-success{{/summary.bookingUp}}{{^summary.bookingUp}}text-danger{{/summary.bookingUp}}" id="kpi-booking-diff">
                                            {{summary.diffLabel}} 대비 {{summary.bookingCountDiffFormatted}}건
                                        </div>
                                    </div>
                                    <div class="col-auto"><i class="fas fa-ticket-alt fa-2x text-gray-300"></i></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 취소율 -->
                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-warning shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">취소율</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-cancel-rate">{{summary.cancelRate}}%</div>
                                        <div class="mt-1 small text-gray-500" id="kpi-canceled-count">취소 {{summary.canceledCount}}건</div>
                                    </div>
                                    <div class="col-auto"><i class="fas fa-undo-alt fa-2x text-gray-300"></i></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 결제 이탈(PENDING) -->
                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-left-secondary shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">결제 이탈 (PENDING)</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-pending">{{summary.pendingCount}}건</div>
                                        <div class="mt-1 small text-gray-500">결제 미완료 건수</div>
                                    </div>
                                    <div class="col-auto"><i class="fas fa-hourglass-half fa-2x text-gray-300"></i></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- KPI 카드 2행: 실시간 지표 -->
                <div class="row">
                    <!-- 대기열 트래픽 -->
                    <div class="col-xl-4 col-md-4 mb-4">
                        <div class="card border-left-info shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">대기열 트래픽</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalWaitingCount">{{queueStats.totalWaitingCount}}</div>
                                        <div class="mt-1 small text-gray-500">동접자 <span id="totalEnteredCount">{{queueStats.totalEnteredCount}}</span>명 · 활성 회차 <span id="activeSessionCount">{{queueStats.activeSessionCount}}</span>개</div>
                                    </div>
                                    <div class="col-auto"><i class="fas fa-users fa-2x text-gray-300"></i></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 현재 접속자 -->
                    <div class="col-xl-4 col-md-4 mb-4">
                        <div class="card border-left-success shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">현재 접속자 (로그인)</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="activeUserCount">{{queueStats.activeUserCount}}</div>
                                        <div class="mt-1 small text-gray-500">실시간 로그인 세션 수</div>
                                    </div>
                                    <div class="col-auto"><i class="fas fa-user-check fa-2x text-gray-300"></i></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 시스템 에러 -->
                    <div class="col-xl-4 col-md-4 mb-4">
                        <div class="card border-left-danger shadow h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">시스템 에러 (1시간)</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800" id="kpi-system-error">{{systemErrorStats.recentErrorCount}}건</div>
                                        <div class="mt-1 small text-gray-500">에러 발생 시 하단 확인</div>
                                    </div>
                                    <div class="col-auto"><i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 중단: 매출/예매 추이 차트 + 실시간 대기열 -->
                <div class="row">
                    <!-- 매출/예매 추이 라인 차트 -->
                    <div class="col-xl-8 col-lg-7">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">매출 · 예매 추이</h6>
                            </div>
                            <div class="card-body">
                                <div class="chart-area">
                                    <canvas id="trendChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 실시간 대기열 -->
                    <div class="col-xl-4 col-lg-5">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">회차별 대기 현황</h6>
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush" id="sessionQueueList" style="max-height: 320px; overflow-y: auto;">
                                    <li class="list-group-item text-gray-500 p-3">불러오는 중...</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 하단: 공연별 예매율 + 오늘 회차 + 최근 예매 -->
                <div class="row">
                    <!-- 공연별 예매율 수평 바 차트 -->
                    <div class="col-xl-5 col-lg-5">
                        <div class="card shadow mb-4">
                            <a href="/admin/concert-sales-rates" class="card-header py-3 d-block text-decoration-none">
                                <h6 class="m-0 font-weight-bold text-primary">공연별 예매율 <small class="text-gray-500 font-weight-normal ml-2">누적 기준</small><i class="fas fa-chevron-right fa-xs ml-1"></i></h6>
                            </a>
                            <div class="card-body">
                                <div class="chart-bar" style="height: 220px;">
                                    <canvas id="salesRateChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 오늘 공연 회차 -->
                    <div class="col-xl-3 col-lg-3">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">오늘 공연 회차</h6>
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    {{#todaySessions}}
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="font-weight-bold small">{{concertTitle}}</div>
                                            <div class="text-gray-500" style="font-size:11px;">{{round}}</div>
                                        </div>
                                        <span class="badge badge-primary badge-pill">{{sessionTime}}</span>
                                    </li>
                                    {{/todaySessions}}
                                    {{^todaySessions}}
                                    <li class="list-group-item text-gray-500 small">오늘 예정된 공연이 없습니다.</li>
                                    {{/todaySessions}}
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- 최근 예매 -->
                    <div class="col-xl-4 col-lg-4">
                        <div class="card shadow mb-4">
                            <a href="/admin/bookings" class="card-header py-3 d-block text-decoration-none">
                                <h6 class="m-0 font-weight-bold text-primary">최근 예매 <i class="fas fa-chevron-right fa-xs ml-1"></i></h6>
                            </a>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush" id="recentBookingList">
                                    {{#recentBookings}}
                                    <li class="list-group-item">
                                        <div class="d-flex justify-content-between">
                                            <span class="font-weight-bold small">{{userName}}</span>
                                            <span class="text-success small font-weight-bold">{{totalAmountFormatted}}원</span>
                                        </div>
                                        <div class="text-gray-500" style="font-size:11px;">{{concertTitle}} · {{round}} · {{paidAt}}</div>
                                    </li>
                                    {{/recentBookings}}
                                    {{^recentBookings}}
                                    <li class="list-group-item text-gray-500 small">최근 예매 내역이 없습니다.</li>
                                    {{/recentBookings}}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 하단: 운영 로그 + 시스템 에러 -->
                <div class="row">
                    <div class="col-lg-6">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">최근 운영 로그</h6></div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush" id="operationLogList">
                                    {{#operationLogs}}
                                    <li class="list-group-item small">
                                        <span class="text-gray-500">[{{level}}]</span>
                                        <span class="font-weight-bold">{{actor}}</span>
                                        {{message}}
                                        <span class="text-gray-400 float-right">{{createdAt}}</span>
                                    </li>
                                    {{/operationLogs}}
                                    {{^operationLogs}}
                                    <li class="list-group-item text-gray-500 small">최근 운영 로그가 없습니다.</li>
                                    {{/operationLogs}}
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">최근 시스템 에러</h6></div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush" id="systemErrorList">
                                    {{#systemErrorStats.recentErrors}}
                                    <li class="list-group-item small {{#isError}}text-danger{{/isError}}{{#isWarn}}text-warning{{/isWarn}}">[{{level}}] {{message}} <span class="float-right">{{occurredAt}}</span></li>
                                    {{/systemErrorStats.recentErrors}}
                                    {{^systemErrorStats.recentErrors}}
                                    <li class="list-group-item text-gray-500 small">최근 1시간 내 에러가 없습니다.</li>
                                    {{/systemErrorStats.recentErrors}}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        {{> admin/layout/footer}}

        <script>
            var DASHBOARD_PERIOD = '{{summary.period}}';
        </script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
        <script src="/js/admin/queue-monitor.js"></script>
        <script src="/js/admin/dashboard-charts.js"></script>
    </div>
</div>
</body>
</html>
