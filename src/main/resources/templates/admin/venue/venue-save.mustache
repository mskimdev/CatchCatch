{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">공연장 등록</h1>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연장 기본 정보 입력</h6>
                    </div>
                    <div class="card-body">
                        <form action="/admin/venues/save" method="post">
                            {{#_csrf}}
                                <input type="hidden" name="{{parameterName}}" value="{{token}}">
                            {{/_csrf}}

                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label for="name" class="font-weight-bold">공연장명 <span class="text-danger">*</span></label>
                                    <input id="name" class="form-control" type="text" name="name" placeholder="예: KSPO DOME" required>
                                </div>

                                <div class="col-md-6 form-group">
                                    <label for="totalCapacity" class="font-weight-bold">총 수용 인원 <span class="text-danger">*</span></label>
                                    <input id="totalCapacity" class="form-control" type="number" name="totalCapacity" placeholder="예: 15000" min="1" required>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="address" class="font-weight-bold">주소 <span class="text-danger">*</span></label>
                                <input id="address" class="form-control" type="text" name="address" placeholder="예: 서울특별시 송파구 올림픽로 424" required>
                            </div>

                            <div class="alert alert-info mt-4" role="alert">
                                <i class="fas fa-info-circle"></i> 등록한 공연장은 콘서트 등록 시 공연장 선택 목록에 사용됩니다.
                            </div>

                            <div class="d-flex justify-content-end mt-4">
                                <a class="btn btn-secondary mr-2" href="/admin/venues">목록으로</a>
                                <button class="btn btn-primary" type="submit">공연장 등록</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>
</body>
</html>