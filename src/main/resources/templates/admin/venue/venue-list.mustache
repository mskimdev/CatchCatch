//venue-list.mustache
{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <main class="container-fluid admin-venue-page">
                <section class="card shadow mb-4 border-left-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h1 class="h3 text-gray-800 font-weight-bold">공연장 관리</h1>
                                <p class="text-gray-600 mb-0">콘서트 예매에 사용할 공연장 정보를 등록하고 관리합니다.</p>
                            </div>
                            <a class="btn btn-primary btn-icon-split" href="/admin/venues/save">
                                <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
                                <span class="text">공연장 등록</span>
                            </a>
                        </div>

                        <div class="mt-4">
                            <span class="badge badge-secondary p-2">등록 공연장: {{venueCount}}건</span>
                            {{#isSearch}}
                                <span class="badge badge-info p-2">검색어: {{keyword}}</span>
                                <a href="/admin/venues" class="text-xs ml-2">전체 목록 보기</a>
                            {{/isSearch}}
                        </div>
                    </div>
                </section>

                <section class="card shadow mb-4">
                    <div class="card-header py-3 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary">공연장 목록</h6>
                        {{^isSearch}}
                            <a href="/admin/venues" class="btn btn-sm btn-outline-secondary">새로고침 ↻</a>
                        {{/isSearch}}
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="venueTable" width="100%">
                                <thead class="thead-light">
                                <tr>
                                    <th>번호</th>
                                    <th>공연장명</th>
                                    <th>주소</th>
                                    <th>총 수용 인원</th>
                                    <th>등록일</th>
                                    <th>관리</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#venues}}
                                    <tr>
                                        <td class="align-middle">#{{id}}</td>
                                        <td class="align-middle font-weight-bold text-gray-800">🎤 {{name}}</td>
                                        <td class="align-middle">{{address}}</td>
                                        <td class="align-middle text-center">
                                            <span class="badge badge-pill badge-info">{{totalCapacity}}명</span>
                                        </td>
                                        <td class="align-middle">{{formattedCreatedAt}}</td>
                                        <td class="align-middle text-center">

                                            <a class="btn btn-warning btn-sm btn-edit" href="/admin/venues/edit">
                                                <span class="text">수정</span>
                                            </a>

                                            <button type="button"
                                                    class="btn btn-danger btn-sm btn-delete"
                                                    data-id="{{id}}">
                                                삭제
                                            </button>
                                        </td>
                                    </tr>
                                {{/venues}}
                                {{^venues}}
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-gray-500">
                                                <i class="fas fa-search fa-2x mb-3"></i>
                                                <h3>{{#isSearch}}
                                                    검색 결과가 없습니다.{{/isSearch}}{{^isSearch}}
                                                    등록된 공연장이 없습니다.{{/isSearch}}</h3>
                                            </div>
                                        </td>
                                    </tr>
                                {{/venues}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>
    {{> admin/layout/footer}}
    <script src="/admin/js/venue.js"></script>
</div>
</div>
</body>
</html>