{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">공연장 수정</h1>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연장 기본 정보 수정</h6>
                    </div>

                    <div class="card-body">
                        <form id="venue-edit-form" data-id="{{venue.id}}">
                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label for="name" class="font-weight-bold">
                                        공연장명 <span class="text-danger">*</span>
                                    </label>
                                    <input id="name"
                                           class="form-control"
                                           type="text"
                                           name="name"
                                           value="{{venue.name}}"
                                           required>
                                </div>

                                <div class="col-md-6 form-group">
                                    <label for="totalCapacity" class="font-weight-bold">
                                        총 수용 인원 <span class="text-danger">*</span>
                                    </label>
                                    <input id="totalCapacity"
                                           class="form-control"
                                           type="number"
                                           name="totalCapacity"
                                           value="{{venue.totalCapacity}}"
                                           min="1"
                                           required>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="address" class="font-weight-bold">
                                    주소 <span class="text-danger">*</span>
                                </label>
                                <input id="address" class="form-control" type="text" name="address" value="{{venue.address}}" required>
                            </div>

                            <form action="/admin/venues/edit" method="post" enctype="multipart/form-data">
                                {{#_csrf}}
                                    <input type="hidden" name="{{parameterName}}" value="{{token}}">
                                {{/_csrf}}

                                <div class="form-group mt-3">
                                    <label for="seatMapFile" class="font-weight-bold">좌석배치도 파일 (.json) <span class="text-danger">*</span></label>
                                    <input id="seatMapFile" class="form-control-file" type="file" name="seatMapFile" accept=".json" required>
                                    <small class="form-text text-muted">공연장 좌석 배치 정보가 담긴 JSON 파일을 업로드해 주세요.</small>
                                </div>

                            <div class="alert alert-warning mt-4" role="alert">
                                <i class="fas fa-info-circle"></i>
                                수정한 공연장 정보는 콘서트 등록 시 공연장 선택 목록에 반영됩니다.
                            </div>

                            <div class="d-flex justify-content-end mt-4">
                                <a class="btn btn-secondary mr-2" href="/admin/venues">목록으로</a>
                                <button class="btn btn-primary" type="submit">공연장 수정</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        {{> admin/layout/footer}}
    </div>
</div>

<script src="/admin/js/venue.js"></script>
</body>
</html>