{{> admin/layout/header}}

<style>
  .chat-user-list { height: calc(100vh - 220px); overflow-y: auto; }
  .chat-user-item { padding: 12px 16px; border-bottom: 1px solid #e3e6f0; cursor: pointer; transition: background .15s; }
  .chat-user-item:hover, .chat-user-item.active { background: #e8e3ff; }
  .chat-user-item .username { font-weight: 700; font-size: 14px; }
  .chat-user-item .preview { font-size: 12px; color: #858796; margin-top: 2px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
  .chat-user-item .badge-new { background: #7c3aed; color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 10px; }

  .chat-body { height: calc(100vh - 320px); overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 12px; background: #f8f9fc; }
  .chat-msg { display: flex; gap: 8px; align-items: flex-start; max-width: 75%; }
  .chat-msg--user { align-self: flex-start; }
  .chat-msg--admin { flex-direction: row-reverse; align-self: flex-end; }
  .chat-msg__avatar { width: 32px; height: 32px; border-radius: 50%; background: #e8e3ff; color: #7c3aed; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 13px; }
  .chat-msg--admin .chat-msg__avatar { background: #7c3aed; color: #fff; }
  .chat-msg__bubble { padding: 9px 13px; border-radius: 14px; font-size: 13.5px; line-height: 1.5; word-break: break-word; min-width: 48px; }
  .chat-msg--user .chat-msg__bubble { background: #fff; border: 1px solid #e3e6f0; border-bottom-left-radius: 4px; }
  .chat-msg--admin .chat-msg__bubble { background: #7c3aed; color: #fff; border-bottom-right-radius: 4px; }
  .chat-msg__time { font-size: 11px; color: #b7b9cc; margin-top: 4px; }

  .chat-foot { padding: 12px 16px; border-top: 1px solid #e3e6f0; display: flex; align-items: flex-end; gap: 8px; background: #fff; }
  .chat-foot textarea { flex: 1; border: 1px solid #d1d3e2; border-radius: 8px; padding: 8px 12px; font-size: 13.5px; resize: none; outline: none; max-height: 120px; overflow-y: auto; box-sizing: border-box; }
  .chat-foot textarea:focus { border-color: #7c3aed; }
  .chat-foot .btn-send { background: #7c3aed; color: #fff; border: none; border-radius: 8px; padding: 8px 18px; font-size: 13px; cursor: pointer; flex-shrink: 0; height: 38px; }
  .chat-foot .btn-send:hover { background: #6d28d9; }

  .chat-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #b7b9cc; }
</style>

<body id="page-top">
<div id="wrapper">
  {{> admin/layout/sidebar}}

  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      {{> admin/layout/topbar}}

      <div class="container-fluid">

        <div class="d-sm-flex align-items-center justify-content-between mb-4">
          <h1 class="h3 mb-0 text-gray-800">채팅 관리</h1>
        </div>

        <div class="row" style="height: calc(100vh - 180px);">

          <!-- 유저 목록 -->
          <div class="col-md-3 pr-0">
            <div class="card shadow h-100">
              <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                  <i class="fas fa-users mr-1"></i> 채팅 유저
                </h6>
              </div>
              <div class="chat-user-list" id="chat-user-list">
                {{#chatUsers}}
                <div class="chat-user-item" data-user-id="{{userId}}" data-username="{{username}}">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="username">{{username}}</span>
                    {{#hasNew}}<span class="badge-new">NEW</span>{{/hasNew}}
                  </div>
                  <div class="preview">{{lastMessage}}</div>
                </div>
                {{/chatUsers}}
                {{^chatUsers}}
                <div class="text-center text-muted py-5">
                  <i class="fas fa-comment-slash fa-2x mb-2 d-block"></i>
                  채팅 내역이 없습니다.
                </div>
                {{/chatUsers}}
              </div>
            </div>
          </div>

          <!-- 채팅창 -->
          <div class="col-md-9 pl-0">
            <div class="card shadow h-100 d-flex flex-column">
              <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary" id="chat-title">
                  <i class="fas fa-comment-dots mr-1"></i> 유저를 선택하세요
                </h6>
              </div>

              <div class="chat-body" id="chat-body">
                <div class="chat-empty" id="chat-empty">
                  <i class="fas fa-comments fa-3x mb-3"></i>
                  <p>왼쪽에서 유저를 선택하면 채팅 내역이 표시됩니다.</p>
                </div>
              </div>

              <div class="chat-foot">
                <textarea id="admin-chat-input" placeholder="답장을 입력하세요... (Enter: 전송, Shift+Enter: 줄바꿈)" rows="2"></textarea>
                <button class="btn-send" id="admin-chat-send">
                  <i class="fas fa-paper-plane mr-1"></i> 전송
                </button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
    {{> admin/layout/footer}}

    <script src="https://cdn.jsdelivr.net/npm/sockjs-client@1/dist/sockjs.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/stompjs@2.3.3/lib/stomp.min.js"></script>
    <script src="/js/admin/chat.js"></script>
  </div>
</div>
</body>
</html>