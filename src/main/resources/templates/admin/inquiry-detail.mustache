{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">문의 상세 및 답변</h1>
                    <a href="/admin/boards/inquiry" class="btn btn-sm btn-secondary shadow-sm">
                        <i class="fas fa-list fa-sm text-white-50"></i> 목록으로
                    </a>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="m-0 font-weight-bold text-primary">{{title}}</h6>
                            <span class="badge {{statusClass}}">{{statusLabel}}</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-4 text-gray-700">
                            <strong>작성자: {{username}}</strong> | <span>{{createdAt}}</span>
                        </div>
                        <div class="p-3 bg-light border rounded">
                            {{content}}
                        </div>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-success">
                            <i class="fas fa-reply"></i> 답변 관리
                        </h6>
                    </div>
                    <div class="card-body">
                        <form action="/admin/inquiries/{{id}}/reply" method="post">
                            {{#_csrf}}
                                <input type="hidden" name="{{parameterName}}" value="{{token}}">
                            {{/_csrf}}

                            <div class="form-group">
                                <textarea class="form-control" name="reply" rows="5"
                                          placeholder="문의에 대한 답변을 입력해 주세요." required>{{reply}}</textarea>
                            </div>

                            <div class="d-flex justify-content-end">
                                {{#isAnswered}}
                                    <button class="btn btn-warning" type="submit">답변 수정</button>
                                {{/isAnswered}}
                                {{^isAnswered}}
                                    <button class="btn btn-success" type="submit">답변 등록</button>
                                {{/isAnswered}}
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>
</body>
</html>