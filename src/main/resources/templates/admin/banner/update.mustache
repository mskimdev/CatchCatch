{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <div>
                        <h1 class="h3 mb-1 text-gray-800">배너 수정</h1>
                        <p class="mb-0 text-muted small">배너 #{{banner.id}}의 이미지, 문구와 노출 설정을 변경합니다.</p>
                    </div>
                    <a href="/admin/banners" class="btn btn-sm btn-outline-secondary mt-3 mt-sm-0"><i class="fas fa-arrow-left mr-1"></i>목록으로</a>
                </div>

                <form id="bannerUpdateForm" enctype="multipart/form-data">
                    <input type="hidden" id="bannerId" value="{{banner.id}}">
                    <div class="row">
                        <div class="col-xl-7 col-lg-7">
                            <div class="card admin-banner-form-card shadow mb-4">
                                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                                    <h6 class="m-0 font-weight-bold text-primary">배너 정보</h6>
                                    <span class="badge badge-light border">ID {{banner.id}}</span>
                                </div>
                                <div class="card-body">
                                    <section class="admin-banner-form-section">
                                        <div class="admin-banner-form-section__title mb-3"><i class="far fa-image text-primary mr-2"></i>배너 이미지</div>
                                        <div class="custom-file">
                                            <input type="file" class="custom-file-input" id="imageFile" name="imageFile" accept="image/*">
                                            <label class="custom-file-label" for="imageFile" id="imageFileName">변경할 이미지를 선택하세요</label>
                                        </div>
                                        <small class="form-text text-muted"><i class="fas fa-info-circle mr-1"></i>이미지를 선택하지 않으면 현재 이미지가 유지됩니다. 권장 비율은 5:2입니다.</small>
                                    </section>

                                    <section class="admin-banner-form-section">
                                        <div class="admin-banner-form-section__title mb-3"><i class="fas fa-font text-primary mr-2"></i>노출 문구</div>
                                        <div class="row">
                                            <div class="form-group col-md-4">
                                                <label for="displayOrder">노출 순서 <span class="text-danger">*</span></label>
                                                <input type="number" class="form-control" id="displayOrder" name="displayOrder" value="{{banner.displayOrder}}" min="1" required>
                                            </div>
                                            <div class="form-group col-md-8">
                                                <label for="eyebrow">상단 카피</label>
                                                <input type="text" class="form-control js-preview-input" id="eyebrow" name="eyebrow" value="{{banner.eyebrow}}" data-preview="previewEyebrow">
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label for="title">메인 타이틀 <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control js-preview-input" id="title" name="title" value="{{banner.title}}" data-preview="previewTitle" required>
                                        </div>
                                        <div class="form-group">
                                            <label for="highlight">강조 문구</label>
                                            <input type="text" class="form-control js-preview-input" id="highlight" name="highlight" value="{{banner.highlight}}" data-preview="previewHighlight">
                                        </div>
                                        <div class="form-group mb-0">
                                            <label for="description">상세 설명</label>
                                            <textarea class="form-control js-preview-input" id="description" name="description" rows="3" data-preview="previewDescription">{{banner.description}}</textarea>
                                        </div>
                                    </section>

                                    <section class="admin-banner-form-section">
                                        <div class="admin-banner-form-section__title mb-3"><i class="fas fa-mouse-pointer text-primary mr-2"></i>연결 및 노출</div>
                                        <div class="row">
                                            <div class="form-group col-md-5">
                                                <label for="buttonText">버튼 텍스트</label>
                                                <input type="text" class="form-control js-preview-input" id="buttonText" name="buttonText" value="{{banner.buttonText}}" data-preview="previewButton">
                                            </div>
                                            <div class="form-group col-md-7">
                                                <label for="linkUrl">이동 링크 URL</label>
                                                <input type="text" class="form-control" id="linkUrl" name="linkUrl" value="{{banner.linkUrl}}">
                                            </div>
                                        </div>
                                        <div class="rounded bg-light border px-3 py-3">
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="isActive" name="isActive" value="true" {{#banner.isActive}}checked{{/banner.isActive}}>
                                                <label class="custom-control-label font-weight-bold" for="isActive">메인 홈에 배너 노출</label>
                                            </div>
                                            <small class="text-muted ml-4">비활성화하면 배너 정보는 유지되고 사용자 화면에서만 숨겨집니다.</small>
                                        </div>
                                    </section>

                                    <div class="d-flex justify-content-end pt-3">
                                        <a href="/admin/banners" class="btn btn-light border mr-2">취소</a>
                                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save mr-1"></i>변경사항 저장</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-5 col-lg-5">
                            <div class="admin-banner-preview">
                                <div class="admin-banner-preview__canvas">
                                    <img id="imagePreview" class="admin-banner-preview__image" src="{{banner.imageUrl}}" alt="{{banner.title}} 배너 이미지">
                                    <div class="admin-banner-preview__shade"></div>
                                    <div class="admin-banner-preview__content">
                                        <div class="admin-banner-preview__eyebrow" id="previewEyebrow">{{banner.eyebrow}}</div>
                                        <h2 class="admin-banner-preview__title"><span id="previewTitle">{{banner.title}}</span><br><span class="admin-banner-preview__highlight" id="previewHighlight">{{banner.highlight}}</span></h2>
                                        <p class="admin-banner-preview__description" id="previewDescription">{{banner.description}}</p>
                                        <span class="admin-banner-preview__button" id="previewButton">{{banner.buttonText}}</span>
                                    </div>
                                </div>
                                <div class="admin-banner-preview__meta d-flex justify-content-between"><span><i class="fas fa-desktop mr-1"></i>메인 홈 미리보기</span>{{#banner.isActive}}<span id="previewStatus" class="text-success font-weight-bold">노출 중</span>{{/banner.isActive}}{{^banner.isActive}}<span id="previewStatus" class="text-secondary font-weight-bold">비노출</span>{{/banner.isActive}}</div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>

<script>
    const previewFallbacks = {
        previewEyebrow: 'CATCHCATCH EXCLUSIVE', previewTitle: '메인 타이틀을 입력하세요',
        previewHighlight: '강조 문구', previewDescription: '배너 상세 설명이 이곳에 표시됩니다.', previewButton: '자세히 보기'
    };

    document.querySelectorAll('.js-preview-input').forEach(input => {
        input.addEventListener('input', () => {
            document.getElementById(input.dataset.preview).textContent = input.value.trim() || previewFallbacks[input.dataset.preview];
        });
    });

    document.getElementById('imageFile').addEventListener('change', function() {
        const file = this.files && this.files[0];
        if (!file) return;
        document.getElementById('imageFileName').textContent = file.name;
        const reader = new FileReader();
        reader.onload = event => document.getElementById('imagePreview').src = event.target.result;
        reader.readAsDataURL(file);
    });

    document.getElementById('isActive').addEventListener('change', function() {
        const status = document.getElementById('previewStatus');
        status.textContent = this.checked ? '노출 예정' : '비노출';
        status.className = this.checked ? 'text-success font-weight-bold' : 'text-secondary font-weight-bold';
    });

    document.getElementById('bannerUpdateForm').addEventListener('submit', async function(event) {
        event.preventDefault();
        if (!this.checkValidity()) {
            this.reportValidity();
            return;
        }

        const formData = new FormData(this);
        if (!document.getElementById('isActive').checked) formData.append('isActive', 'false');

        CcUI.loading.show('변경사항을 저장하고 있습니다...');
        try {
            const id = document.getElementById('bannerId').value;
            const response = await fetch(`/api/admin/banners/${id}`, { method: 'PUT', body: formData });
            CcUI.loading.hide();
            if (!response.ok) {
                CcUI.alert('입력한 내용을 확인해주세요.', 'error');
                return;
            }
            CcUI.toast('배너 정보가 수정되었습니다.');
            setTimeout(() => location.href = '/admin/banners', 700);
        } catch (error) {
            CcUI.loading.hide();
            CcUI.alert('서버와 통신하지 못했습니다.', 'error');
        }
    });
</script>
</body>
</html>
