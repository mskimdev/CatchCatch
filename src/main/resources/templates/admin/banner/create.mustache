{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <div>
                        <h1 class="h3 mb-1 text-gray-800">새 배너 등록</h1>
                        <p class="mb-0 text-muted small">이미지와 홍보 문구를 입력하고 메인 홈 노출 모습을 확인하세요.</p>
                    </div>
                    <a href="/admin/banners" class="btn btn-sm btn-outline-secondary mt-3 mt-sm-0"><i class="fas fa-arrow-left mr-1"></i>목록으로</a>
                </div>

                <form id="bannerForm" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-xl-7 col-lg-7">
                            <div class="card admin-banner-form-card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">배너 정보</h6></div>
                                <div class="card-body">
                                    <section class="admin-banner-form-section">
                                        <div class="admin-banner-form-section__title mb-3"><i class="far fa-image text-primary mr-2"></i>배너 이미지</div>
                                        <div class="custom-file">
                                            <input type="file" class="custom-file-input" id="imageFile" name="imageFile" accept="image/*" required>
                                            <label class="custom-file-label" for="imageFile" id="imageFileName">이미지 파일을 선택하세요</label>
                                        </div>
                                        <small class="form-text text-muted"><i class="fas fa-info-circle mr-1"></i>가로형 이미지(권장 비율 5:2, JPG/PNG/WEBP)를 사용하면 가장 자연스럽게 노출됩니다.</small>
                                    </section>

                                    <section class="admin-banner-form-section">
                                        <div class="admin-banner-form-section__title mb-3"><i class="fas fa-font text-primary mr-2"></i>노출 문구</div>
                                        <div class="form-group col-md-4 pl-0">
                                            <label for="displayOrder">노출 순서 <span class="text-danger">*</span></label>
                                            <input type="number" class="form-control" id="displayOrder" name="displayOrder" value="1" min="1" required>
                                        </div>
                                        <div class="rounded bg-light border px-3 py-3 mb-3">
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="showText" name="showText" value="true">
                                                <label class="custom-control-label font-weight-bold" for="showText">노출 문구 설정하기</label>
                                            </div>
                                            <small class="text-muted ml-4">체크하지 않으면 이미지만 노출되고, 아래 문구 입력란은 저장되지 않습니다.</small>
                                        </div>
                                        <div id="textFieldsGroup" class="d-none">
                                            <div class="form-group">
                                                <label for="eyebrow">상단 카피</label>
                                                <input type="text" class="form-control js-preview-input" id="eyebrow" name="eyebrow" placeholder="CATCHCATCH EXCLUSIVE" data-preview="previewEyebrow">
                                            </div>
                                            <div class="form-group">
                                                <label for="title">메인 타이틀 <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control js-preview-input" id="title" name="title" placeholder="2026 악뮤 전국투어 콘서트" data-preview="previewTitle">
                                            </div>
                                            <div class="form-group">
                                                <label for="highlight">강조 문구</label>
                                                <input type="text" class="form-control js-preview-input" id="highlight" name="highlight" placeholder="단독 오픈 결정!" data-preview="previewHighlight">
                                            </div>
                                            <div class="form-group mb-0">
                                                <label for="description">상세 설명</label>
                                                <textarea class="form-control js-preview-input" id="description" name="description" rows="3" placeholder="배너에 들어갈 상세 홍보 문구를 입력하세요." data-preview="previewDescription"></textarea>
                                            </div>
                                        </div>
                                    </section>

                                    <section class="admin-banner-form-section">
                                        <div class="admin-banner-form-section__title mb-3"><i class="fas fa-mouse-pointer text-primary mr-2"></i>연결 및 노출</div>
                                        <div class="row">
                                            <div class="form-group col-md-5 d-none" id="buttonTextGroup">
                                                <label for="buttonText">버튼 텍스트</label>
                                                <input type="text" class="form-control js-preview-input" id="buttonText" name="buttonText" placeholder="예매하기" data-preview="previewButton">
                                            </div>
                                            <div class="form-group col-md-7">
                                                <label for="linkUrl">이동 링크 URL</label>
                                                <input type="text" class="form-control" id="linkUrl" name="linkUrl" placeholder="/concerts/1">
                                            </div>
                                        </div>
                                        <div class="rounded bg-light border px-3 py-3">
                                            <div class="custom-control custom-switch">
                                                <input type="checkbox" class="custom-control-input" id="isActive" name="isActive" value="true" checked>
                                                <label class="custom-control-label font-weight-bold" for="isActive">등록 즉시 메인 홈에 노출</label>
                                            </div>
                                            <small class="text-muted ml-4">비활성화하면 저장되지만 사용자 화면에는 표시되지 않습니다.</small>
                                        </div>
                                    </section>

                                    <div class="d-flex justify-content-end pt-3">
                                        <a href="/admin/banners" class="btn btn-light border mr-2">취소</a>
                                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-check mr-1"></i>배너 등록</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-5 col-lg-5">
                            <div class="admin-banner-preview">
                                <div class="admin-banner-preview__canvas">
                                    <img id="imagePreview" class="admin-banner-preview__image d-none" alt="선택한 배너 이미지">
                                    <div class="admin-banner-preview__shade d-none" id="previewShade"></div>
                                    <div class="admin-banner-preview__content d-none" id="previewContent">
                                        <div class="admin-banner-preview__eyebrow" id="previewEyebrow">CATCHCATCH EXCLUSIVE</div>
                                        <h2 class="admin-banner-preview__title"><span id="previewTitle">메인 타이틀을 입력하세요</span><br><span class="admin-banner-preview__highlight" id="previewHighlight">강조 문구</span></h2>
                                        <p class="admin-banner-preview__description" id="previewDescription">배너 상세 설명이 이곳에 표시됩니다.</p>
                                        <span class="admin-banner-preview__button" id="previewButton">자세히 보기</span>
                                    </div>
                                </div>
                                <div class="admin-banner-preview__meta d-flex justify-content-between"><span><i class="fas fa-desktop mr-1"></i>메인 홈 미리보기</span><span id="previewStatus" class="text-success font-weight-bold">노출 예정</span></div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>

<script>
    const previewFallbacks = {
        previewEyebrow: 'CATCHCATCH EXCLUSIVE', previewTitle: '메인 타이틀을 입력하세요',
        previewHighlight: '강조 문구', previewDescription: '배너 상세 설명이 이곳에 표시됩니다.', previewButton: '자세히 보기'
    };

    document.querySelectorAll('.js-preview-input').forEach(input => {
        input.addEventListener('input', () => {
            const target = document.getElementById(input.dataset.preview);
            target.textContent = input.value.trim() || previewFallbacks[input.dataset.preview];
        });
    });

    document.getElementById('imageFile').addEventListener('change', function() {
        const file = this.files && this.files[0];
        if (!file) return;
        document.getElementById('imageFileName').textContent = file.name;
        const reader = new FileReader();
        reader.onload = event => {
            const preview = document.getElementById('imagePreview');
            preview.src = event.target.result;
            preview.classList.remove('d-none');
        };
        reader.readAsDataURL(file);
    });

    document.getElementById('isActive').addEventListener('change', function() {
        const status = document.getElementById('previewStatus');
        status.textContent = this.checked ? '노출 예정' : '비노출 저장';
        status.className = this.checked ? 'text-success font-weight-bold' : 'text-secondary font-weight-bold';
    });

    const titleInput = document.getElementById('title');
    document.getElementById('showText').addEventListener('change', function() {
        const on = this.checked;
        document.getElementById('textFieldsGroup').classList.toggle('d-none', !on);
        document.getElementById('buttonTextGroup').classList.toggle('d-none', !on);
        document.getElementById('previewShade').classList.toggle('d-none', !on);
        document.getElementById('previewContent').classList.toggle('d-none', !on);
        titleInput.required = on;
        if (!on) titleInput.value = '';
    });

    document.getElementById('bannerForm').addEventListener('submit', async function(event) {
        event.preventDefault();
        if (!this.checkValidity()) {
            this.reportValidity();
            return;
        }

        const formData = new FormData(this);
        if (!document.getElementById('isActive').checked) formData.append('isActive', 'false');
        if (!document.getElementById('showText').checked) formData.append('showText', 'false');

        CcUI.loading.show('배너를 등록하고 있습니다...');
        try {
            const response = await fetch('/api/admin/banners', { method: 'POST', body: formData });
            CcUI.loading.hide();
            if (!response.ok) {
                CcUI.alert('입력한 내용을 확인해주세요.', 'error');
                return;
            }
            CcUI.toast('새 배너가 등록되었습니다.');
            setTimeout(() => location.href = '/admin/banners', 700);
        } catch (error) {
            CcUI.loading.hide();
            CcUI.alert('서버와 통신하지 못했습니다.', 'error');
        }
    });
</script>
</body>
</html>
