{{> layout/header-admin}}

<main class="cc-main">
    <div class="cc-container">

        <!-- 상단 소개 영역 -->
        <section class="cc-card admin-venue-hero">
            <div class="admin-venue-hero__content">
                <p class="admin-venue-eyebrow">관리자 메뉴</p>

                <h1 class="admin-venue-title">공연장 관리</h1>

                <p class="admin-venue-desc">
                    콘서트 예매에 사용할 공연장 정보를 등록하고 관리합니다.
                </p>

                {{#keyword}}
                    <p class="admin-venue-search-info">
                        <strong>{{keyword}}</strong> 검색 결과입니다.
                    </p>
                {{/keyword}}
            </div>

            <div class="admin-venue-hero__action">
                <a class="cc-btn cc-btn--primary admin-venue-create-btn" href="/admin/venues/save">
                    + 공연장 등록
                </a>
            </div>
        </section>

        <!-- 공연장 목록 영역 -->
        <section class="cc-section">
            <div class="cc-section__head">
                <h2 class="cc-section__title">
                    공연장 목록
                    <span class="cc-accent-text">{{venueCount}}건</span>
                </h2>

                {{#keyword}}
                    <a class="cc-more" href="/admin/venues">
                        전체 목록 보기 ↻
                    </a>
                {{/keyword}}

                {{^keyword}}
                    <a class="cc-more" href="/admin/venues">
                        새로고침 ↻
                    </a>
                {{/keyword}}
            </div>

            <div class="cc-card admin-venue-table-card">
                <table class="admin-venue-table">
                    <thead>
                    <tr>
                        <th>번호</th>
                        <th>공연장명</th>
                        <th>주소</th>
                        <th>총 수용 인원</th>
                        <th>등록일</th>
                        <th>관리</th>
                    </tr>
                    </thead>

                    <tbody>
                    {{#venues}}
                        <tr>
                            <td>{{id}}</td>

                            <td>
                                <strong class="admin-venue-name">
                                    {{name}}
                                </strong>
                            </td>

                            <td>{{address}}</td>

                            <td>
                                <span class="cc-badge">
                                    {{totalCapacity}}명
                                </span>
                            </td>

                            <td>{{createdAt}}</td>

                            <td>
                                <form action="/admin/venues/{{id}}/delete"
                                      method="post"
                                      onsubmit="return confirm('이 공연장을 삭제하시겠습니까?');">
                                    {{#_csrf}}
                                        <input type="hidden" name="{{parameterName}}" value="{{token}}">
                                    {{/_csrf}}

                                    <button class="admin-venue-delete-btn" type="submit">
                                        삭제
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {{/venues}}

                    {{^venues}}
                        <tr>
                            <td colspan="6">
                                <div class="admin-venue-empty">
                                    {{#keyword}}
                                        <p>
                                            <strong>{{keyword}}</strong>에 대한 검색 결과가 없습니다.
                                        </p>

                                        <a class="cc-btn cc-btn--outline" href="/admin/venues">
                                            전체 공연장 보기
                                        </a>
                                    {{/keyword}}

                                    {{^keyword}}
                                        <p>아직 등록된 공연장이 없습니다.</p>

                                        <a class="cc-btn cc-btn--outline" href="/admin/venues/save">
                                            첫 공연장 등록하기
                                        </a>
                                    {{/keyword}}
                                </div>
                            </td>
                        </tr>
                    {{/venues}}
                    </tbody>
                </table>
            </div>
        </section>

    </div>
</main>

{{> layout/footer}}