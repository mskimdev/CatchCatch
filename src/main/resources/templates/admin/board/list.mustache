{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">{{pageTitle}}</h1>
                    <a href="/admin/boards/{{category}}/create" class="btn btn-sm btn-primary shadow-sm">
                        <i class="fas fa-plus fa-sm text-white-50"></i> 글 작성
                    </a>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">{{pageTitle}} 목록</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="boardTable" width="100%" cellspacing="0">
                                <thead class="thead-light">
                                <tr>
                                    <th>ID</th>
                                    <th>제목</th>
                                    <th>작성일</th>
                                    {{#isInquiry}}
                                        <th>답변 상태</th>
                                    {{/isInquiry}}
                                    <th>관리</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#posts}}
                                    <tr>
                                        <td class="align-middle">{{id}}</td>
                                        <td class="align-middle">{{title}}</td>
                                        <td class="align-middle">{{createdAt}}</td>

                                        {{#isInquiry}}
                                            <td class="align-middle text-center">
                                                {{#isAnswered}}
                                                    <span class="badge badge-success">답변완료</span>
                                                {{/isAnswered}}
                                                {{^isAnswered}}
                                                    <span class="badge badge-warning">답변대기</span>
                                                {{/isAnswered}}
                                            </td>
                                        {{/isInquiry}}

                                        <td class="align-middle">
                                            <a href="/admin/boards/{{category}}/edit/{{id}}" class="btn btn-warning btn-sm">수정</a>
                                            <button class="btn btn-danger btn-sm" onclick="deletePost({{id}})">삭제</button>
                                        </td>
                                    </tr>
                                {{/posts}}

                                {{^posts}}
                                    <tr>
                                        <td colspan="{{#isInquiry}}5{{/isInquiry}}{{^isInquiry}}4{{/isInquiry}}" class="text-center py-4">
                                            등록된 글이 없습니다.
                                        </td>
                                    </tr>
                                {{/posts}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>

<script>
    function deletePost(id) {
        if(confirm("정말 삭제하시겠습니까?")) {
            // 추후 API 연동 위치
            console.log("Delete ID: " + id);
        }
    }
</script>
</body>
</html>