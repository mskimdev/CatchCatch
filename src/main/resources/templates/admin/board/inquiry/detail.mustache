{{> admin/layout/header}}

<style>
    .badge.inquiry-status--pending  { background-color: #f6c23e; color: #fff; font-size: .8rem; padding: .4em .75em; }
    .badge.inquiry-status--resolved { background-color: #1cc88a; color: #fff; font-size: .8rem; padding: .4em .75em; }
    .badge.inquiry-status--cancelled{ background-color: #858796; color: #fff; font-size: .8rem; padding: .4em .75em; }
    .badge.iq-category { background-color: #e8e3ff; color: #6f42c1; font-weight: 700; font-size: .8rem; padding: .4em .75em; }
    .inquiry-content-box {
        background: #f8f9fc;
        border: 1px solid #e3e6f0;
        border-radius: .35rem;
        padding: 1.25rem 1.5rem;
        white-space: pre-wrap;
        min-height: 120px;
        line-height: 1.7;
        color: #3a3b45;
    }
    .reply-box {
        background: #f0fff4;
        border: 1px solid #c3e6cb;
        border-radius: .35rem;
        padding: 1.25rem 1.5rem;
        white-space: pre-wrap;
        line-height: 1.7;
        color: #155724;
    }
    .reply-label {
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #1cc88a;
        margin-bottom: .5rem;
    }
    .meta-info { font-size: .85rem; color: #858796; }
    .meta-info span + span::before { content: "·"; margin: 0 .5rem; }

</style>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <!-- 페이지 제목 -->
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">문의 답변</h1>
                    <a href="/admin/boards/inquiry" class="btn btn-sm btn-secondary shadow-sm">
                        <i class="fas fa-list fa-sm"></i> 목록으로
                    </a>
                </div>

                {{#inquiry}}
                <div class="row">
                    <div class="col-lg-8">

                        <!-- 문의 내용 카드 -->
                        <div class="card shadow mb-4">
                            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                                <h6 class="m-0 font-weight-bold text-primary">문의 내용</h6>
                                <div>
                                    <span class="badge iq-category mr-1">{{categoryLabel}}</span>
                                    <span class="badge {{statusClass}}">{{statusLabel}}</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <h5 class="font-weight-bold mb-2">{{title}}</h5>
                                <div class="meta-info mb-3">
                                    <span><i class="fas fa-user mr-1"></i>{{username}}</span>
                                    <span><i class="fas fa-calendar mr-1"></i>{{createdAt}}</span>
                                </div>
                                <div class="inquiry-content-box">{{content}}</div>
                            </div>
                        </div>

                        <!-- 기존 답변 표시 (답변 완료된 경우) -->
                        {{#reply}}
                        <div class="card shadow mb-4 border-left-success">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-success">
                                    <i class="fas fa-check-circle mr-1"></i> 등록된 답변
                                </h6>
                            </div>
                            <div class="card-body">
                                <div class="reply-label"><i class="fas fa-reply mr-1"></i>관리자 답변</div>
                                <div class="reply-box">{{reply}}</div>
                            </div>
                        </div>
                        {{/reply}}

                        <!-- 답변 작성 카드 -->
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">
                                    <i class="fas fa-reply mr-1"></i> 답변 작성
                                </h6>
                            </div>
                            <div class="card-body">
                                <form id="reply-form" action="/admin/boards/inquiry/{{id}}/reply" method="post">
                                    <div class="form-group">
                                        <textarea class="form-control" name="reply" rows="7"
                                                  placeholder="답변 내용을 입력해 주세요" required>{{reply}}</textarea>
                                    </div>
                                    <div class="d-flex justify-content-end">
                                        <a href="/admin/boards/inquiry" class="btn btn-secondary mr-2">취소</a>
                                        <button type="submit" id="submit-btn" class="btn btn-primary">
                                            <i class="fas fa-paper-plane mr-1"></i> 답변 등록
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                    </div>

                    <!-- 우측 정보 패널 -->
                    <div class="col-lg-4">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">문의 정보</h6>
                            </div>
                            <div class="card-body">
                                <table class="table table-sm table-borderless mb-0">
                                    <tbody>
                                        <tr>
                                            <td class="font-weight-bold text-muted" style="width:80px;">번호</td>
                                            <td>#{{id}}</td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold text-muted">유형</td>
                                            <td><span class="badge iq-category">{{categoryLabel}}</span></td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold text-muted">작성자</td>
                                            <td>{{username}}</td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold text-muted">상태</td>
                                            <td><span class="badge {{statusClass}}">{{statusLabel}}</span></td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold text-muted">등록일</td>
                                            <td>{{createdAt}}</td>
                                        </tr>
                                        <tr><td colspan="2"><hr class="my-2"></td></tr>
                                        <tr>
                                            <td class="font-weight-bold text-muted" colspan="2">알림 설정</td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted"><i class="fas fa-envelope fa-sm mr-1"></i>이메일</td>
                                            <td>
                                                {{#notifyEmail}}
                                                    <span class="badge badge-success">수신</span>
                                                {{/notifyEmail}}
                                                {{^notifyEmail}}
                                                    <span class="badge badge-secondary">미수신</span>
                                                {{/notifyEmail}}
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-muted"><i class="fas fa-sms fa-sm mr-1"></i>SMS</td>
                                            <td>
                                                {{#notifySms}}
                                                    <span class="badge badge-success">수신</span>
                                                {{/notifySms}}
                                                {{^notifySms}}
                                                    <span class="badge badge-secondary">미수신</span>
                                                {{/notifySms}}
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                {{/inquiry}}

            </div>
        </div>
        {{> admin/layout/footer}}

        <script>
            document.getElementById('reply-form').addEventListener('submit', function (e) {
                e.preventDefault();
                const reply = document.querySelector('textarea[name="reply"]').value.trim();
                if (!reply) {
                    CcUI.alert('답변 내용을 입력해 주세요.');
                    return;
                }
                CcUI.confirm({
                    title: '답변을 등록하시겠습니까?',
                    text: '등록 후 작성자에게 알림이 발송됩니다.',
                    confirmText: '등록',
                    onConfirm: async () => {
                        CcUI.loading.show('답변을 등록하는 중입니다...');
                        const { res } = await apiPut('/api/admin/boards/inquiry/{{#inquiry}}{{id}}{{/inquiry}}/reply', { reply });
                        CcUI.loading.hide();
                        if (res && res.ok) {
                            sessionStorage.setItem('replySuccess', '1');
                            location.reload();
                        } else {
                            CcUI.alert('답변 등록 중 오류가 발생했습니다.', 'error');
                        }
                    }
                });
            });

            if (sessionStorage.getItem('replySuccess')) {
                sessionStorage.removeItem('replySuccess');
                CcUI.toast('답변이 등록되었습니다.');
            }
</script>
    </div>
</div>
</body>
</html>
