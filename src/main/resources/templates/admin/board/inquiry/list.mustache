{{> admin/layout/header}}

<style>
    /* statusClass 값: inquiry-status--pending / inquiry-status--resolved / inquiry-status--cancelled */
    .badge.inquiry-status--pending  { background-color: #f6c23e; color: #fff; font-size: .75rem; }
    .badge.inquiry-status--resolved { background-color: #1cc88a; color: #fff; font-size: .75rem; }
    .badge.inquiry-status--cancelled{ background-color: #858796; color: #fff; font-size: .75rem; }
    .badge.iq-category { background-color: #e8e3ff; color: #6f42c1; font-weight: 700; }
    .filter-btn.active { font-weight: 700; }
    .stat-card { border-left: .25rem solid; padding: .5rem 1rem; border-radius: .35rem; }
    .stat-card--total   { border-color: #4e73df; background: #f0f3ff; }
    .stat-card--pending { border-color: #f6c23e; background: #fffbf0; }
</style>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <!-- 페이지 제목 -->
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">1:1 문의 관리</h1>
                </div>

                <!-- 통계 카드 -->
                <div class="row mb-4">
                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="stat-card stat-card--total d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-uppercase mb-1" style="color:#4e73df;">전체 문의</div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{totalCount}}건</div>
                            </div>
                            <i class="fas fa-inbox fa-2x text-gray-300"></i>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="stat-card stat-card--pending d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-uppercase mb-1" style="color:#f6c23e;">답변 대기</div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{pendingCount}}건</div>
                            </div>
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>

                <!-- 문의 목록 카드 -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">문의 목록</h6>
                        <div>
                            <a href="/admin/boards/inquiry"
                               class="btn btn-sm filter-btn {{#filterAll}}btn-primary active{{/filterAll}}{{^filterAll}}btn-outline-primary{{/filterAll}}">
                                전체
                            </a>
                            <a href="/admin/boards/inquiry?status=PENDING"
                               class="btn btn-sm filter-btn {{#filterPending}}btn-warning active{{/filterPending}}{{^filterPending}}btn-outline-warning{{/filterPending}}">
                                답변대기
                            </a>
                            <a href="/admin/boards/inquiry?status=RESOLVED"
                               class="btn btn-sm filter-btn {{#filterResolved}}btn-success active{{/filterResolved}}{{^filterResolved}}btn-outline-success{{/filterResolved}}">
                                답변완료
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="inquiryTable" width="100%" cellspacing="0">
                                <thead class="thead-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>유형</th>
                                    <th>제목</th>
                                    <th>작성자</th>
                                    <th>답변 상태</th>
                                    <th>등록일</th>
                                    <th>관리</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#inquiries}}
                                    <tr>
                                        <td class="align-middle text-center" style="width:60px;">{{id}}</td>
                                        <td class="align-middle text-center" style="width:90px;">
                                            <span class="badge iq-category">{{categoryLabel}}</span>
                                        </td>
                                        <td class="align-middle">{{title}}</td>
                                        <td class="align-middle text-center" style="width:100px;">{{username}}</td>
                                        <td class="align-middle text-center" style="width:100px;">
                                            <span class="badge {{statusClass}}">{{statusLabel}}</span>
                                        </td>
                                        <td class="align-middle text-center" style="width:160px;">{{createdAt}}</td>
                                        <td class="align-middle text-center" style="width:90px;">
                                            <a href="/admin/boards/inquiry/{{id}}"
                                               class="btn btn-primary btn-sm">
                                                <i class="fas fa-reply"></i> 답변
                                            </a>
                                        </td>
                                    </tr>
                                {{/inquiries}}
                                {{^inquiries}}
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">
                                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                            등록된 문의가 없습니다.
                                        </td>
                                    </tr>
                                {{/inquiries}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        {{> admin/layout/footer}}

        <script src="/admin/vendor/datatables/jquery.dataTables.min.js"></script>
        <script src="/admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>
        <script>
            $(document).ready(function () {
                $('#inquiryTable').DataTable({
                    "order": [[0, "desc"]],
                    "columnDefs": [{"orderable": false, "targets": 6}],
                    "language": {"url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Korean.json"}
                });
            });
        </script>
    </div>
</div>
</body>
</html>
