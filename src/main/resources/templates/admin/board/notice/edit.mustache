{{> admin/layout/header}}

<link href="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-bs4.min.css" rel="stylesheet">
<style>
    .form-section-label {
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #858796;
        margin-bottom: .4rem;
    }
</style>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">공지 수정</h1>
                    <a href="/admin/boards/notice" class="btn btn-sm btn-secondary shadow-sm">
                        <i class="fas fa-list fa-sm"></i> 목록으로
                    </a>
                </div>

                <div class="row">
                    <div class="col-lg-8">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">공지 내용</h6>
                            </div>
                            <div class="card-body">
                                <form id="notice-form" data-id="{{notice.id}}">
                                    {{#_csrf}}
                                        <input type="hidden" name="{{parameterName}}" value="{{token}}">
                                    {{/_csrf}}

                                    <div class="form-group">
                                        <div class="form-section-label">제목</div>
                                        <input type="text" class="form-control" name="title"
                                               value="{{notice.title}}"
                                               placeholder="공지사항 제목을 입력하세요" maxlength="100" required>
                                    </div>

                                    <div class="form-group">
                                        <div class="form-section-label">내용</div>
                                        <textarea name="content" id="noticeContent"></textarea>
                                    </div>

                                    <div class="form-group mb-4">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input"
                                                   id="isPinned" name="isPinned" value="true"
                                                   {{#notice.isPinned}}checked{{/notice.isPinned}}>
                                            <label class="custom-control-label font-weight-bold" for="isPinned">
                                                상단 고정
                                            </label>
                                            <small class="form-text text-muted">
                                                체크하면 사용자 공지사항 목록 상단에 고정됩니다.
                                            </small>
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-end">
                                        <a href="/admin/boards/notice" class="btn btn-secondary mr-2">취소</a>
                                        <button type="submit" id="submit-btn" class="btn btn-warning">
                                            <i class="fas fa-save mr-1"></i> 수정
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">공지 정보</h6>
                            </div>
                            <div class="card-body">
                                <table class="table table-sm table-borderless mb-0">
                                    <tbody>
                                    <tr>
                                        <td class="font-weight-bold text-muted" style="width:90px;">번호</td>
                                        <td>#{{notice.id}}</td>
                                    </tr>
                                    <tr>
                                        <td class="font-weight-bold text-muted">조회수</td>
                                        <td>{{notice.viewCount}}</td>
                                    </tr>
                                    <tr>
                                        <td class="font-weight-bold text-muted">등록일</td>
                                        <td>{{notice.createdAt}}</td>
                                    </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {{> admin/layout/footer}}

        <script type="text/template" id="content-initial">{{{notice.content}}}</script>
        <script src="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/summernote-bs4.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/summernote@0.9.0/dist/lang/summernote-ko-KR.min.js"></script>
        <script>
            $(document).ready(function () {
            $('#noticeContent').summernote({
                lang: 'ko-KR',
                height: 320,
                toolbar: [
                    ['style', ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
                    ['fontsize', ['fontsize']],
                    ['color', ['color']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['insert', ['link', 'picture']],
                    ['view', ['fullscreen', 'codeview']]
                ]
            });
            $('#noticeContent').summernote('code', document.getElementById('content-initial').textContent);


            document.getElementById('notice-form').addEventListener('submit', function (e) {
                e.preventDefault();

                const form = e.currentTarget;
                const noticeId = form.dataset.id;
                const submitBtn = document.getElementById('submit-btn');
                const title = form.querySelector('[name="title"]').value.trim();
                const content = $('#noticeContent').summernote('code').trim();
                const isPinned = form.querySelector('[name="isPinned"]').checked;

                if (!title) {
                    CcUI.alert('공지사항 제목을 입력해 주세요.', 'warning');
                    return;
                }
                if (content === '<p><br></p>' || content === '') {
                    CcUI.alert('공지사항 내용을 입력해 주세요.', 'warning');
                    return;
                }

                CcUI.confirm({
                    title: '공지사항을 수정하시겠습니까?',
                    text: '수정한 내용은 사용자 공지사항 화면에 바로 반영됩니다.',
                    confirmText: '수정',
                    cancelText: '취소',
                    onConfirm: async () => {
                        try {
                            submitBtn.disabled = true;
                            CcUI.loading.show('수정 중입니다...');

                            const { res, data } = await apiPut(`/admin/boards/notice/${noticeId}/edit`, {
                                title, content, isPinned
                            });

                            CcUI.loading.hide();

                            if (!res || !res.ok) {
                                CcUI.alert(data?.msg ?? '공지사항 수정에 실패했습니다.', 'error');
                                submitBtn.disabled = false;
                                return;
                            }

                            CcUI.toast(data?.body ?? data?.msg ?? '공지사항이 수정되었습니다.');
                            setTimeout(() => location.href = '/admin/boards/notice', 500);
                        } catch (error) {
                            CcUI.loading.hide();
                            CcUI.alert('공지사항 수정 중 오류가 발생했습니다.', 'error');
                            submitBtn.disabled = false;
                        }
                    }
                });
            });
            }); // document.ready
        </script>
    </div>
</div>
</body>
</html>
