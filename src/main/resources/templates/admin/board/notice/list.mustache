{{> admin/layout/header}}

<style>
    .badge.notice-pinned {
        background-color: #7b35ff;
        color: #fff;
        font-size: .75rem;
    }

    .badge.notice-normal {
        background-color: #858796;
        color: #fff;
        font-size: .75rem;
    }

    .stat-card {
        border-left: .25rem solid;
        padding: .75rem 1rem;
        border-radius: .35rem;
    }

    .stat-card--total {
        border-color: #4e73df;
        background: #f0f3ff;
    }

    .stat-card--pinned {
        border-color: #7b35ff;
        background: #f5f0ff;
    }

    .notice-title {
        font-weight: 700;
        color: #2d2d2d;
    }

    .notice-action-cell {
        width: 190px;
        min-width: 190px;
        white-space: nowrap;
    }

    .notice-action-buttons {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        flex-wrap: nowrap;
    }
</style>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">공지사항 관리</h1>

                    <a href="/admin/boards/notice/save" class="btn btn-primary btn-sm shadow-sm">
                        <i class="fas fa-plus fa-sm"></i> 공지 등록
                    </a>
                </div>

                <div class="row mb-4">
                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="stat-card stat-card--total d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-uppercase mb-1" style="color:#4e73df;">
                                    전체 공지
                                </div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{totalCount}}건</div>
                            </div>
                            <i class="fas fa-bullhorn fa-2x text-gray-300"></i>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="stat-card stat-card--pinned d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-uppercase mb-1" style="color:#7b35ff;">
                                    고정 공지
                                </div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{pinnedCount}}건</div>
                            </div>
                            <i class="fas fa-thumbtack fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공지사항 목록</h6>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="noticeTable" width="100%" cellspacing="0">
                                <thead class="thead-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>제목</th>
                                    <th>고정</th>
                                    <th>조회수</th>
                                    <th>등록일</th>
                                    <th>관리</th>
                                </tr>
                                </thead>

                                <tbody>
                                {{#notices}}
                                    <tr>
                                        <td class="align-middle text-center" style="width:60px;">{{id}}</td>
                                        <td class="align-middle">
                                            <div class="notice-title">{{title}}</div>
                                        </td>
                                        <td class="align-middle text-center" style="width:80px;">
                                            {{#isPinned}}<span class="badge notice-pinned">고정</span>{{/isPinned}}
                                            {{^isPinned}}<span class="badge notice-normal">일반</span>{{/isPinned}}
                                        </td>
                                        <td class="align-middle text-center" style="width:90px;">{{viewCount}}</td>
                                        <td class="align-middle text-center" style="width:160px;">{{createdAt}}</td>
                                        <td class="align-middle text-center notice-action-cell">
                                            <div class="notice-action-buttons">
                                                <a href="/admin/boards/notice/{{id}}/edit" class="btn btn-warning btn-sm">
                                                    <i class="fas fa-edit"></i> 수정
                                                </a>

                                                <form action="/admin/boards/notice/{{id}}/delete"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('공지사항을 삭제하시겠습니까?')">
                                                    <button type="submit" class="btn btn-danger btn-sm">
                                                        <i class="fas fa-trash"></i> 삭제
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {{/notices}}

                                {{^notices}}
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="fas fa-bullhorn fa-2x mb-2 d-block"></i>
                                            등록된 공지사항이 없습니다.
                                        </td>
                                    </tr>
                                {{/notices}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {{> admin/layout/footer}}

        <script src="/admin/vendor/datatables/jquery.dataTables.min.js"></script>
        <script src="/admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>
        <script>
            $(document).ready(function () {
                $('#noticeTable').DataTable({
                    "order": [[0, "desc"]],
                    "columnDefs": [
                        { "orderable": false, "targets": [2, 5] }
                    ],
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Korean.json"
                    }
                });
            });
        </script>
    </div>
</div>
</body>
</html>
