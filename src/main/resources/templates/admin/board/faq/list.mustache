{{> admin/layout/header}}

<style>
    .badge.faq-category {
        background-color: #e8e3ff;
        color: #6f42c1;
        font-weight: 700;
        font-size: .75rem;
        padding: .45rem .65rem;
        border-radius: 999px;
    }

    .stat-card {
        border-left: .25rem solid;
        padding: .75rem 1rem;
        border-radius: .35rem;
    }

    .stat-card--total {
        border-color: #4e73df;
        background: #f0f3ff;
    }

    .faq-question {
        font-weight: 700;
        color: #2d2d2d;
    }

    .faq-answer-preview {
        color: #858796;
        font-size: .85rem;
        margin-top: .25rem;
        max-width: 620px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .faq-action-cell {
        width: 190px;
        min-width: 190px;
        white-space: nowrap;
    }

    .faq-action-buttons {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        flex-wrap: nowrap;
    }

    .faq-action-buttons .btn {
        white-space: nowrap;
        min-width: 64px;
    }
</style>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <!-- 페이지 제목 -->
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">FAQ 관리</h1>

                    <a href="/admin/boards/faq/save" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus"></i> FAQ 등록
                    </a>
                </div>

                <!-- 통계 카드 -->
                <div class="row mb-4">
                    <div class="col-xl-3 col-md-6 mb-3">
                        <div class="stat-card stat-card--total d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-uppercase mb-1" style="color:#4e73df;">
                                    전체 자주 묻는 사항
                                </div>
                                <div class="h4 mb-0 font-weight-bold text-gray-800">{{faqCount}}건</div>
                            </div>
                            <i class="fas fa-question-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>

                <!-- FAQ 목록 카드 -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">자주 묻는 사항 목록</h6>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="faqTable" width="100%" cellspacing="0">
                                <thead class="thead-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>카테고리</th>
                                    <th>질문 / 답변</th>
                                    <th>등록일</th>
                                    <th>관리</th>
                                </tr>
                                </thead>

                                <tbody>
                                {{#faqs}}
                                    <tr>
                                        <td class="align-middle text-center" style="width:60px;">
                                            {{id}}
                                        </td>

                                        <td class="align-middle text-center" style="width:120px;">
                                            <span class="badge faq-category">{{category.label}}</span>
                                        </td>

                                        <td class="align-middle">
                                            <div class="faq-question">{{question}}</div>
                                            <div class="faq-answer-preview">{{answerPreview}}</div>
                                        </td>

                                        <td class="align-middle text-center" style="width:160px;">
                                            {{formattedCreatedAt}}
                                        </td>

                                        <td class="align-middle text-center faq-action-cell">
                                            <div class="faq-action-buttons">
                                                <a href="/admin/boards/faq/{{id}}/edit"
                                                   class="btn btn-warning btn-sm">
                                                    <i class="fas fa-edit"></i> 수정
                                                </a>

                                                <button type="button"
                                                        class="btn btn-danger btn-sm btn-delete"
                                                        data-id="{{id}}">
                                                    <i class="fas fa-trash"></i> 삭제
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                {{/faqs}}

                                {{^faqs}}
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <i class="fas fa-question-circle fa-2x mb-2 d-block"></i>
                                            등록된 FAQ가 없습니다.
                                        </td>
                                    </tr>
                                {{/faqs}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        {{> admin/layout/footer}}

        <script src="/admin/vendor/datatables/jquery.dataTables.min.js"></script>
        <script src="/admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>
        <script>
            $(document).ready(function () {
                $('#faqTable').DataTable({
                    "order": [[0, "desc"]],
                    "columnDefs": [
                        { "orderable": false, "targets": 4 }
                    ],
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Korean.json"
                    }
                });
            });
        </script>
        <script src="/admin/js/faq.js"></script>
    </div>
</div>
</body>
</html>