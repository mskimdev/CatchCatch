<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>CatchCatch 관리자 콘서트 통합 제어 패널</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 30px; background-color: #f4f6f9; color: #333; margin: 0; }
        .container { max-width: 1400px; margin: 0 auto; }
        h1 { color: #1e293b; font-size: 28px; margin-bottom: 25px; border-bottom: 3px solid #3b82f6; padding-bottom: 12px; }

        .grid { display: grid; grid-template-columns: 1fr; gap: 25px; }
        .box { border: null; background-color: #ffffff; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .box h3 { margin-top: 0; margin-bottom: 20px; color: #2563eb; border-left: 5px solid #2563eb; padding-left: 12px; font-size: 18px; }

        .form-group { margin-bottom: 15px; display: inline-block; vertical-align: top; margin-right: 15px; }
        .form-group.block { display: block; width: 100%; }
        .form-group label { display: block; margin-bottom: 6px; font-weight: 600; font-size: 13px; color: #475569; }

        input[type="text"], input[type="number"], input[type="date"], input[type="datetime-local"], select, textarea {
            padding: 10px; width: 260px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; font-size: 14px; background-color: #f8fafc;
        }
        textarea { width: 100%; height: 70px; resize: none; }

        button { padding: 10px 24px; cursor: pointer; background-color: #2563eb; color: white; border: none; border-radius: 6px; font-weight: bold; font-size: 14px; transition: all 0.2s; }
        button:hover { background-color: #1d4ed8; transform: translateY(-1px); }

        /* 테이블 스타일 보강 */
        .table-responsive { width: 100%; overflow-x: auto; margin-top: 15px; border-radius: 8px; border: 1px solid #e2e8f0; }
        table { width: 100%; border-collapse: collapse; text-align: left; font-size: 14px; background: #fff; }
        th { background-color: #f1f5f9; color: #334155; font-weight: 700; padding: 12px 16px; border-bottom: 2px solid #e2e8f0; }
        td { padding: 14px 16px; border-bottom: 1px solid #e2e8f0; color: #334155; }
        tr:hover { background-color: #f8fafc; }

        /* 상태 배지 */
        .badge { display: inline-block; padding: 4px 8px; font-size: 11px; font-weight: bold; border-radius: 50px; text-align: center; }
        .badge-coming { background-color: #e0f2fe; color: #0369a1; }
        .badge-open { background-color: #dcfce7; color: #15803d; }
        .badge-closed { background-color: #fef3c7; color: #b45309; }
        .badge-ended { background-color: #fee2e2; color: #b91c1c; }

        .session-count { font-weight: bold; color: #2563eb; background: #eff6ff; padding: 2px 8px; border-radius: 4px; }
        .btn-action { padding: 4px 10px; font-size: 12px; margin-right: 4px; }
    </style>
</head>
<body>

<div class="container">
    <h1>🛠️ CatchCatch 관리자 라이브 콘서트 제어소</h1>

    <div class="grid">
        <div class="box">
            <h3>🎵 신규 라이브 공연 기획 및 등록 (POST)</h3>
            <div class="form-group">
                <label>공연 타이틀</label>
                <input type="text" id="c-title" value="뮤지컬 <시카고> 오리지널 내한">
            </div>
            <div class="form-group">
                <label>아티스트/기획사</label>
                <input type="text" id="c-artist" value="브로드웨이 캐스트">
            </div>
            <div class="form-group">
                <label>공연 인프라 (공연장)</label>
                <select id="c-venue">
                    <option value="1">올림픽 체조경기장 (ID: 1)</option>
                    <option value="2">고척 스카이돔 (ID: 2)</option>
                </select>
            </div>
            <div class="form-group">
                <label>카테고리 장르</label>
                <select id="c-genre">
                    <option value="musical">musical (뮤지컬)</option>
                    <option value="concert">concert (콘서트)</option>
                </select>
            </div>
            <div class="form-group">
                <label>최초 릴리즈 상태</label>
                <select id="c-status">
                    <option value="COMING_SOON">COMING_SOON (준비중)</option>
                    <option value="OPEN">OPEN (오픈)</option>
                </select>
            </div>
            <br>
            <div class="form-group">
                <label>오픈 베뉴 개막일</label>
                <input type="date" id="c-start-date" value="2026-09-05">
            </div>
            <div class="form-group">
                <label>시즌 폐막일</label>
                <input type="date" id="c-end-date" value="2026-09-07">
            </div>
            <div class="form-group">
                <label>온라인 티켓 예매 개시일</label>
                <input type="datetime-local" id="c-ticket-date" value="2026-06-15T14:00">
            </div>
            <div class="form-group block">
                <label>공연 요약 시놉시스</label>
                <textarea id="c-description">역사상 가장 매혹적인 무대, 오리지널 라이브 밴드 세션과 함께 찾아옵니다.</textarea>
            </div>
            <input type="hidden" id="c-poster" value="/images/sample/poster.svg">
            <button onclick="createConcert()">🚀 시스템에 공연 최종 등록</button>
        </div>

        <div class="box">
            <h3>📊 전개된 콘서트 마스터 리스트 (GET)</h3>
            <button onclick="getConcerts()" style="background-color: #10b981; margin-bottom: 15px;">🔄 데이터 실시간 동기화</button>

            <div class="table-responsive">
                <table>
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>공연 상태</th>
                        <th>공연명 / 아티스트</th>
                        <th>매핑 공연장</th>
                        <th>총 회차</th>
                        <th>공연 진행 기간</th>
                        <th>티켓 오픈 일시</th>
                        <th>기능 관리</th>
                    </tr>
                    </thead>
                    <tbody id="concert-table-body">
                    </tbody>
                </table>
            </div>
        </div>

        <div class="box" id="edit-section">
            <h3>✏️ 선택된 공연 세부 정보 변경 수정 (PUT)</h3>
            <div class="form-group">
                <label>타겟 인덱스 ID</label>
                <input type="number" id="u-id" readonly style="background-color: #e2e8f0;" placeholder="행 우측 수정 버튼 클릭">
            </div>
            <div class="form-group">
                <label>수정 제목</label>
                <input type="text" id="u-title">
            </div>
            <div class="form-group">
                <label>수정 아티스트</label>
                <input type="text" id="u-artist">
            </div>
            <div class="form-group">
                <label>인프라 변경</label>
                <select id="u-venue">
                    <option value="1">올림픽 체조경기장 (ID: 1)</option>
                    <option value="2">고척 스카이돔 (ID: 2)</option>
                </select>
            </div>
            <div class="form-group">
                <label>상태 천이 변경</label>
                <select id="u-status">
                    <option value="COMING_SOON">COMING_SOON (준비중)</option>
                    <option value="OPEN">OPEN (오픈)</option>
                    <option value="CLOSED_SOON">CLOSED_SOON (종료임박)</option>
                    <option value="ENDED">ENDED (종료)</option>
                </select>
            </div>
            <input type="hidden" id="u-genre" value="musical">
            <input type="hidden" id="u-age" value="만 15세 관람가">
            <input type="hidden" id="u-runtime" value="150분">
            <br>
            <button onclick="updateConcert()" style="background-color: #f59e0b;">💾 변경 내역 반영 저장</button>
        </div>
    </div>
</div>

<script>
    window.onload = function() {
        getConcerts();
    };

    // 1. 등록 프로세스
    async function createConcert() {
        const payload = {
            title: document.getElementById('c-title').value,
            artist: document.getElementById('c-artist').value,
            posterUrl: document.getElementById('c-poster').value,
            venueId: parseInt(document.getElementById('c-venue').value),
            genre: document.getElementById('c-genre').value,
            concertStatus: document.getElementById('c-status').value,
            startDate: document.getElementById('c-start-date').value,
            endDate: document.getElementById('c-end-date').value,
            ticketOpenDate: document.getElementById('c-ticket-date').value,
            description: document.getElementById('c-description').value
        };

        const response = await fetch('/api/admin/concerts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        alert(await response.text());
        getConcerts();
    }

    // 2. 동적 테이블 렌더링 조회 로직 (받아온 다중 정보 처리)
    async function getConcerts() {
        const response = await fetch('/api/admin/concerts');
        const list = await response.json();

        let html = '';
        list.forEach(c => {
            // 상태별 커스텀 배지 스타일 적용
            let badgeClass = 'badge-coming';
            if(c.concertStatus === 'OPEN') badgeClass = 'badge-open';
            if(c.concertStatus === 'CLOSED_SOON') badgeClass = 'badge-closed';
            if(c.concertStatus === 'ENDED') badgeClass = 'badge-ended';

            html += `
                <tr>
                    <td><b>${c.id}</b></td>
                    <td><span class="badge ${badgeClass}">${c.concertStatus}</span></td>
                    <td>
                        <div style="font-weight: bold; color: #000;">${c.title}</div>
                        <div style="font-size: 12px; color: #64748b;">${c.artist} (${c.genre})</div>
                    </td>
                    <td><span style="font-size: 13px; font-weight: 500;">📍 ${c.venueName}</span></td>
                    <td><span class="session-count">${c.totalSessions} 회차</span></td>
                    <td>
                        <span style="font-size: 12px;">🗓️ ${c.startDate || '미정'} ~ ${c.endDate || '미정'}</span>
                    </td>
                    <td><small>⏰ ${c.ticketOpenDate ? c.ticketOpenDate.replace('T', ' ') : '미정'}</small></td>
                    <td>
                        <button class="btn-action" style="background-color:#f59e0b;" onclick="setupEditForm(${JSON.stringify(c).replace(/"/g, '&quot;')})">수정</button>
                        <button class="btn-action" style="background-color:#dc3545;" onclick="deleteConcert(${c.id})">삭제</button>
                    </td>
                </tr>
            `;
        });

        document.getElementById('concert-table-body').innerHTML = html;
    }

    // 수정 폼에 데이터 자동 세팅 헬퍼
    function setupEditForm(concert) {
        document.getElementById('u-id').value = concert.id;
        document.getElementById('u-title').value = concert.title;
        document.getElementById('u-artist').value = concert.artist;
        document.getElementById('u-venue').value = concert.venueId || 1;
        document.getElementById('u-status').value = concert.concertStatus;

        document.getElementById('edit-section').scrollIntoView({ behavior: 'smooth' });
    }

    // 3. 수정 프로세스
    async function updateConcert() {
        const id = document.getElementById('u-id').value;
        if(!id) return alert("수정 버튼을 통해 대상을 먼저 선택하세요.");

        const payload = {
            title: document.getElementById('u-title').value,
            artist: document.getElementById('u-artist').value,
            venueId: parseInt(document.getElementById('u-venue').value),
            concertStatus: document.getElementById('u-status').value,
            genre: document.getElementById('u-genre').value,
            ageLimit: document.getElementById('u-age').value,
            runtime: document.getElementById('u-runtime').value,
            posterUrl: "/images/sample/poster.svg"
        };

        const response = await fetch(`/api/admin/concerts/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        alert(await response.text());
        getConcerts();
    }

    // 4. 삭제 프로세스
    async function deleteConcert(id) {
        if(!confirm(id + "번 공연을 삭제 처리하시겠습니까?")) return;

        const response = await fetch(`/api/admin/concerts/${id}`, { method: 'DELETE' });
        alert(await response.text());
        getConcerts();
    }
</script>

</body>
</html>