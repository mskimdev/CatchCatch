</style></head><body>
<header class="top"><div class="brand"><span class="logo">▦</span>Concert Stage1 <small>단색 도면 추출</small></div><div class="top-actions"><a class="top-btn" href="main.html">이전</a><a class="top-btn main" href="concert-stage2.html">Stage2</a></div></header>
<div class="work"><aside class="side"><p class="side-title">Stage1 · 파트 분리</p>
    <div class="tabs"><button class="tab active" id="tab1">파트1 자르기</button><button class="tab" id="tab2">파트2 색상</button><button class="tab" id="tab3">파트3 다듬기</button></div>
    <div id="part1"><div class="box active"><h3>파트 1 - 자르기</h3><button class="btn dark" id="cropStart">범위 드래그 시작</button><button class="btn" id="cropApply" disabled>선택 범위로 자르기</button><button class="btn primary" id="go2">다음: 색상 추출</button><div class="help">도면 영역만 남기고 제목/범례/여백은 제거하세요.</div></div></div>
    <div id="part2" class="hidden"><div class="box active"><h3>파트 2 - 색상 선택 추출</h3><div class="help">오른쪽 이미지를 클릭하면 해당 색상이 추가되고 즉시 미리보기에 반영됩니다. 원본은 선명하게 두고 선택된 도형 영역만 위에 덮어 표시합니다.</div><div id="samples"></div><div class="row"><div><label>색상 허용 범위</label><input type="range" id="tol" min="5" max="120" value="45"></div><div><label>도형 표시 강도</label><input type="range" id="alpha" min="0" max="100" value="55"></div></div><div class="row"><div><label>도형색</label><input type="color" id="shapeColor" value="#d9d9d9"></div><div><label>배경색</label><input type="color" id="bgColor" value="#f7f7f7"></div></div><div class="row"><div><label>숫자/구멍 메우기</label><input type="number" id="hole" value="140"></div><div><label>보기</label><select id="viewMode"><option value="mix">원본+미리보기</option><option value="clean">미리보기만</option></select></div></div><div class="row"><button class="btn" id="clearSamples">색상 초기화</button><button class="btn" id="restoreOriginal">원본 복구</button></div><button class="btn primary" id="go3">다음: 다듬기</button></div></div>
    <div id="part3" class="hidden"><div class="box active"><h3>파트 3 - 다듬기</h3><div class="row"><button class="btn dark" id="eraser">지우개 사용</button><button class="btn" id="stopEraser">지우개 종료</button></div><div class="row"><button class="btn green" id="rectFill">브러쉬 채우기</button><button class="btn" id="stopRectFill">채우기 종료</button></div><div class="row"><div><label>지우개/브러쉬 크기</label><input type="range" id="eraserSize" min="4" max="80" value="18"></div><div><label>작은 조각 제거</label><input type="number" id="cleanupArea" value="180"></div></div><div class="row"><button class="btn amber" id="cleanup">작은 선/조각 자동 제거</button><button class="btn" id="restoreExtract">추출본 복구</button></div><div class="row"><button class="btn green" id="saveClean">Stage1 저장</button><button class="btn primary" id="toStage3">Stage2 이동</button></div><div class="help">숫자 때문에 비어 보이는 부분은 <b>직각 도형 채우기</b>로 드래그해서 메우세요. 실제 좌석 버튼이 아니라 Stage2 도면용 회색 사각형입니다.</div></div></div>
</aside><main class="main"><div class="canvas-wrap"><div class="canvas-head"><span id="title">원본 / 자르기</span><span id="size">-</span></div><div class="canvas-box" id="box"><canvas class="base" id="canvas"></canvas><canvas id="overlay"></canvas><div id="eraserCursor" class="eraser-cursor"></div></div></div></main></div><div class="toast" id="toast"></div><script>
    const $=id=>document.getElementById(id);const c=$('canvas'),o=$('overlay'),ctx=c.getContext('2d',{willReadFrequently:true}),ox=o.getContext('2d');const clean=document.createElement('canvas'),cleanCtx=clean.getContext('2d',{willReadFrequently:true});let W=0,H=0,original=localStorage.getItem('concert_originalImage'),working=localStorage.getItem('concert_cleanImage')||original,cleanUrl=working,lastExtract=working,part=1,cropMode=false,cropDraft=null,cropRect=null,samples=[],eraser=false,erasing=false,rectFillMode=false,rectDraft=null,filling=false;
    function toast(m){const t=$('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000)}function rgb(h){return{r:parseInt(h.slice(1,3),16),g:parseInt(h.slice(3,5),16),b:parseInt(h.slice(5,7),16)}}function hex(c){return '#'+[c.r,c.g,c.b].map(v=>v.toString(16).padStart(2,'0')).join('')}function dist(a,b){return Math.hypot(a.r-b.r,a.g-b.g,a.b-b.b)}function img(url,cb){const im=new Image();im.onload=()=>cb(im);im.src=url}function setup(w,h){W=w;H=h;c.width=o.width=clean.width=w;c.height=o.height=clean.height=h;const s=Math.min(1,1120/w,720/h);c.style.width=o.style.width=(w*s)+'px';c.style.height=o.style.height=(h*s)+'px';$('box').style.width=(w*s)+'px';$('box').style.height=(h*s)+'px';$('size').textContent=w+' × '+h}function pos(e){const r=o.getBoundingClientRect();return{x:(e.clientX-r.left)*o.width/r.width,y:(e.clientY-r.top)*o.height/r.height}}function showPart(n){part=n;['1','2','3'].forEach(k=>{$('tab'+k).classList.toggle('active',+k===n);$('part'+k).classList.toggle('hidden',+k!==n)});$('title').textContent=n===1?'원본 / 자르기':n===2?'원본 + 추출 미리보기':'추출본 다듬기';if(n!==3)hideEraserCursor();draw()}
    function draw(){ox.clearRect(0,0,W,H);ctx.clearRect(0,0,W,H);if(part===1||(part===2&&$('viewMode').value==='mix')){img(working,im=>{ctx.clearRect(0,0,W,H);ctx.drawImage(im,0,0,W,H);if(part===2)drawPreview();if(part===1)drawCrop()})}else img(cleanUrl,im=>{ctx.clearRect(0,0,W,H);ctx.drawImage(im,0,0,W,H);if(part===3&&eraser&&lastEraserPos)updateEraserCursor(lastEraserPos)})}
    function drawPreview(){if(!cleanUrl)return;img(cleanUrl,im=>{const tmp=document.createElement('canvas');tmp.width=W;tmp.height=H;const t=tmp.getContext('2d',{willReadFrequently:true});t.drawImage(im,0,0,W,H);const data=t.getImageData(0,0,W,H),d=data.data,shape=rgb($('shapeColor').value),a=Math.round(((+$('alpha').value||55)/100)*255);for(let i=0;i<d.length;i+=4){const col={r:d[i],g:d[i+1],b:d[i+2]};if(dist(col,shape)<=18){d[i]=shape.r;d[i+1]=shape.g;d[i+2]=shape.b;d[i+3]=a}else{d[i+3]=0}}t.putImageData(data,0,0);ox.clearRect(0,0,W,H);ox.drawImage(tmp,0,0)})}function drawCrop(){ox.clearRect(0,0,W,H);const r=cropDraft||cropRect;if(r){ox.save();ox.fillStyle='rgba(124,58,237,.08)';ox.fillRect(r.x,r.y,r.w,r.h);ox.strokeStyle='#7c3aed';ox.lineWidth=2;ox.setLineDash([7,5]);ox.strokeRect(r.x,r.y,r.w,r.h);ox.restore()}}function drawRectPreview(){if(!rectDraft)return;ox.save();ox.fillStyle='rgba(217,217,217,.45)';ox.strokeStyle='#10b981';ox.lineWidth=2;ox.setLineDash([6,4]);ox.fillRect(rectDraft.x,rectDraft.y,rectDraft.w,rectDraft.h);ox.strokeRect(rectDraft.x,rectDraft.y,rectDraft.w,rectDraft.h);ox.restore()}

    let lastEraserPos=null;
    function updateEraserCursor(p){lastEraserPos=p;const cursor=$('eraserCursor');if(!cursor)return;if(!(part===3&&(eraser||rectFillMode))){cursor.style.display='none';$('box').classList.remove('is-erasing');return;}const size=+$('eraserSize').value||18;const scale=parseFloat(c.style.width)/W||1;cursor.style.display='block';cursor.style.borderColor=rectFillMode?'#10b981':'#111827';cursor.style.width=(size*scale)+'px';cursor.style.height=(size*scale)+'px';cursor.style.transform=`translate(${p.x*scale-size*scale/2}px, ${p.y*scale-size*scale/2}px)`;$('box').classList.add('is-erasing')}
    function hideEraserCursor(){const cursor=$('eraserCursor');if(cursor)cursor.style.display='none';$('box').classList.remove('is-erasing');lastEraserPos=null}
    function renderSamples(){if(!samples.length){$('samples').innerHTML='<div class="help">이미지를 클릭해서 남길 색상을 고르세요.</div>';return}$('samples').innerHTML=samples.map((s,i)=>`<div class="sample"><span><i style="background:${hex(s)}"></i>${hex(s).toUpperCase()}</span><button data-i="${i}">×</button></div>`).join('');document.querySelectorAll('#samples button').forEach(b=>b.onclick=()=>{samples.splice(+b.dataset.i,1);renderSamples();extract()})}
    function fillHoles(data,shape,bg,max){if(max<=0)return;const d=data.data,seen=new Uint8Array(W*H),isBg=i=>d[i*4]===bg.r&&d[i*4+1]===bg.g&&d[i*4+2]===bg.b,paint=i=>{d[i*4]=shape.r;d[i*4+1]=shape.g;d[i*4+2]=shape.b;d[i*4+3]=255};for(let y=0;y<H;y++)for(let x=0;x<W;x++){const s=y*W+x;if(seen[s]||!isBg(s))continue;const q=[s],cells=[];let head=0,edge=false;seen[s]=1;while(head<q.length){const n=q[head++],nx=n%W,ny=(n/W)|0;cells.push(n);if(nx===0||ny===0||nx===W-1||ny===H-1)edge=true;[[1,0],[-1,0],[0,1],[0,-1]].forEach(([dx,dy])=>{const xx=nx+dx,yy=ny+dy;if(xx<0||yy<0||xx>=W||yy>=H)return;const ni=yy*W+xx;if(!seen[ni]&&isBg(ni)){seen[ni]=1;q.push(ni)}})}if(!edge&&cells.length<=max)cells.forEach(paint)}}
    function extract(){if(!working)return;img(working,im=>{cleanCtx.clearRect(0,0,W,H);cleanCtx.drawImage(im,0,0,W,H);const data=cleanCtx.getImageData(0,0,W,H),d=data.data,tol=+$('tol').value||45,shape=rgb($('shapeColor').value),bg=rgb($('bgColor').value);if(samples.length){for(let i=0;i<d.length;i+=4){const col={r:d[i],g:d[i+1],b:d[i+2]},ok=samples.some(s=>dist(col,s)<=tol);if(ok){d[i]=shape.r;d[i+1]=shape.g;d[i+2]=shape.b;d[i+3]=255}else{d[i]=bg.r;d[i+1]=bg.g;d[i+2]=bg.b;d[i+3]=255}}fillHoles(data,shape,bg,+$('hole').value||0)}cleanCtx.putImageData(data,0,0);cleanUrl=clean.toDataURL('image/png');lastExtract=cleanUrl;draw()})}
    function cropApply(){const r=cropRect;if(!r)return;const tmp=document.createElement('canvas');tmp.width=Math.round(r.w);tmp.height=Math.round(r.h);tmp.getContext('2d').drawImage(c,r.x,r.y,r.w,r.h,0,0,tmp.width,tmp.height);working=tmp.toDataURL('image/png');localStorage.setItem('concert_originalImage',working);img(working,im=>{setup(im.naturalWidth,im.naturalHeight);cleanUrl=working;lastExtract=working;cropRect=null;cropDraft=null;draw();toast('자르기 완료')})}
    function erase(p){const bg=$('bgColor').value,size=+$('eraserSize').value||18;cleanCtx.save();cleanCtx.fillStyle=bg;cleanCtx.beginPath();cleanCtx.arc(p.x,p.y,size/2,0,Math.PI*2);cleanCtx.fill();cleanCtx.restore();cleanUrl=clean.toDataURL('image/png');draw()}function fillBrush(p){const shape=$('shapeColor').value,size=+$('eraserSize').value||18;cleanCtx.save();cleanCtx.fillStyle=shape;cleanCtx.beginPath();cleanCtx.arc(p.x,p.y,size/2,0,Math.PI*2);cleanCtx.fill();cleanCtx.restore();cleanUrl=clean.toDataURL('image/png');lastExtract=cleanUrl;draw()}function cleanup(){const shape=rgb($('shapeColor').value),bg=rgb($('bgColor').value),min=+$('cleanupArea').value||180,data=cleanCtx.getImageData(0,0,W,H),d=data.data,seen=new Uint8Array(W*H),isShape=i=>d[i*4]===shape.r&&d[i*4+1]===shape.g&&d[i*4+2]===shape.b,paint=i=>{d[i*4]=bg.r;d[i*4+1]=bg.g;d[i*4+2]=bg.b;d[i*4+3]=255};for(let y=0;y<H;y++)for(let x=0;x<W;x++){const s=y*W+x;if(seen[s]||!isShape(s))continue;const q=[s],cells=[];let head=0;seen[s]=1;while(head<q.length){const n=q[head++],nx=n%W,ny=(n/W)|0;cells.push(n);[[1,0],[-1,0],[0,1],[0,-1]].forEach(([dx,dy])=>{const xx=nx+dx,yy=ny+dy;if(xx<0||yy<0||xx>=W||yy>=H)return;const ni=yy*W+xx;if(!seen[ni]&&isShape(ni)){seen[ni]=1;q.push(ni)}})}if(cells.length<=min)cells.forEach(paint)}cleanCtx.putImageData(data,0,0);cleanUrl=clean.toDataURL('image/png');draw();toast('자동 제거 완료')}
    if(!original){toast('메인에서 이미지를 업로드하세요');}else img(working,im=>{setup(im.naturalWidth,im.naturalHeight);cleanCtx.drawImage(im,0,0,W,H);draw();renderSamples()});
    $('tab1').onclick=()=>showPart(1);$('tab2').onclick=()=>showPart(2);$('tab3').onclick=()=>showPart(3);$('go2').onclick=()=>showPart(2);$('go3').onclick=()=>showPart(3);$('cropStart').onclick=()=>{cropMode=true;toast('자를 범위를 드래그하세요')};$('cropApply').onclick=cropApply;o.onpointerdown=e=>{const p=pos(e);if(part===1&&cropMode){cropDraft={x:p.x,y:p.y,w:0,h:0,startX:p.x,startY:p.y};return}if(part===2){img(working,im=>{const t=document.createElement('canvas');t.width=W;t.height=H;const tctx=t.getContext('2d',{willReadFrequently:true});tctx.drawImage(im,0,0,W,H);const d=tctx.getImageData(Math.floor(p.x),Math.floor(p.y),1,1).data;samples.push({r:d[0],g:d[1],b:d[2]});renderSamples();extract()});return}if(part===3&&eraser){updateEraserCursor(p);erasing=true;erase(p);return}if(part===3&&rectFillMode){updateEraserCursor(p);filling=true;fillBrush(p);return}};window.onpointermove=e=>{const p=pos(e);if(cropDraft){cropDraft.x=Math.min(cropDraft.startX,p.x);cropDraft.y=Math.min(cropDraft.startY,p.y);cropDraft.w=Math.abs(p.x-cropDraft.startX);cropDraft.h=Math.abs(p.y-cropDraft.startY);drawCrop()}if(part===3&&(eraser||rectFillMode))updateEraserCursor(p);if(erasing)erase(p);if(filling)fillBrush(p)};window.onpointerup=()=>{if(cropDraft){cropRect={x:cropDraft.x,y:cropDraft.y,w:cropDraft.w,h:cropDraft.h};cropDraft=null;cropMode=false;$('cropApply').disabled=!(cropRect.w>5&&cropRect.h>5);drawCrop()}erasing=false;filling=false};o.onpointerleave=()=>{if(part===3&&(eraser||rectFillMode)&&!erasing&&!filling)hideEraserCursor()};o.onpointerenter=e=>{if(part===3&&(eraser||rectFillMode))updateEraserCursor(pos(e))};$('eraserSize').oninput=()=>{if(part===3&&eraser&&lastEraserPos)updateEraserCursor(lastEraserPos)};['tol','alpha','shapeColor','bgColor','hole','viewMode'].forEach(id=>$(id).oninput=extract);$('clearSamples').onclick=()=>{samples=[];renderSamples();extract()};$('restoreOriginal').onclick=()=>{samples=[];renderSamples();cleanUrl=working;draw()};$('eraser').onclick=()=>{eraser=true;rectFillMode=false;$('box').classList.add('is-erasing');toast('지우개 모드: 원형 커서 크기만큼 지워집니다')};$('stopEraser').onclick=()=>{eraser=false;hideEraserCursor()};$('rectFill').onclick=()=>{rectFillMode=true;eraser=false;hideEraserCursor();toast('브러쉬 채우기 모드: 빈 부분을 드래그해서 칠하세요')};$('stopRectFill').onclick=()=>{rectFillMode=false;filling=false;rectDraft=null;hideEraserCursor();draw()};$('cleanup').onclick=cleanup;$('restoreExtract').onclick=()=>{cleanUrl=lastExtract;img(cleanUrl,im=>{cleanCtx.clearRect(0,0,W,H);cleanCtx.drawImage(im,0,0,W,H);draw()})};$('saveClean').onclick=()=>{localStorage.setItem('concert_cleanImage',cleanUrl);localStorage.setItem('concert_imageMeta',JSON.stringify({width:W,height:H}));toast('Stage1 저장 완료')};$('toStage3').onclick=()=>{$('saveClean').click();location.href='concert-stage2.html'};
</script></body></html>