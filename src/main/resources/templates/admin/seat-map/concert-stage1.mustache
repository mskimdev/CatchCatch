rgba(124,58,237,.08)}.box h3{font-size:14px;margin:0 0 10px}.row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}.row.three{grid-template-columns:1fr 1fr 1fr}label{display:block;font-size:10px;color:#64748b;font-weight:900;margin:0 0 5px}input,select{width:100%;height:34px;border:1px solid var(--line);border-radius:9px;background:#f8fafc;padding:0 9px;outline:0}input:focus,select:focus{border-color:#8b5cf6;background:#fff}input[type=range]{height:20px;border:0;padding:0;background:transparent}.main{overflow:auto;background:#fff;background-image:radial-gradient(#dbe3ef .8px,transparent .8px);background-size:18px 18px}.canvas-wrap{width:max-content;min-width:860px;min-height:560px;margin:28px auto 90px}.canvas-head{height:36px;display:flex;align-items:center;justify-content:space-between;background:#fff;border:1px solid var(--line);border-bottom:0;border-radius:16px 16px 0 0;padding:0 14px;color:#64748b;font-size:11px;font-weight:900}.canvas-box{position:relative;background:#fff;border:1px solid var(--line);box-shadow:var(--shadow);overflow:hidden}canvas{position:absolute;left:0;top:0}canvas.base{position:relative;display:block}.list{display:grid;gap:7px;max-height:240px;overflow:auto}.item{display:flex;align-items:center;gap:8px;border:1px solid var(--line);border-radius:10px;padding:8px;background:#fff;font-size:11px;cursor:pointer}.item.active{border-color:#8b5cf6;background:#f5f3ff}.dot{width:12px;height:12px;border-radius:3px;background:#8b5cf6}.item strong{display:block;font-size:12px}.item span{display:block;color:#64748b;font-size:10px;margin-top:2px}.sample{display:flex;align-items:center;justify-content:space-between;border:1px solid var(--line);border-radius:10px;background:#f8fafc;padding:7px;font-size:10px;color:#475569;margin-top:6px}.sample i{width:18px;height:18px;border-radius:5px;border:1px solid #cbd5e1;margin-right:6px}.sample span{display:flex;align-items:center}.sample button{border:0;background:transparent;color:#ef4444;font-weight:900}.tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}.tab{height:36px;border:1px solid var(--line);border-radius:10px;background:#fff;color:#475569;font-size:12px;font-weight:900}.tab.active{border-color:#8b5cf6;background:#f5f3ff;color:#6d28d9}.metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.metric{border:1px solid var(--line);border-radius:12px;background:#f8fafc;padding:10px;color:#64748b;font-size:11px}.metric b{display:block;font-size:20px;color:#111827;margin-top:3px}.json-box{max-height:190px;overflow:auto;background:#0f172a;color:#dbeafe;border-radius:10px;padding:10px;font-size:10px;line-height:1.45}.toast{position:fixed;right:22px;bottom:22px;background:#111827;color:#fff;padding:12px 15px;border-radius:12px;font-size:12px;opacity:0;transform:translateY(6px);transition:.16s;z-index:100}.toast.show{opacity:1;transform:none}
