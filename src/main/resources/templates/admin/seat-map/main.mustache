<!DOCTYPE html><html lang="ko"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>SeatTrace Main</title><style>
    :root{--nav:#0f172a;--panel:#fff;--line:#e5e7eb;--muted:#64748b;--ink:#111827;--bg:#f4f6fa;--violet:#7c3aed;--blue:#2563eb;--green:#10b981;--red:#ef4444;--amber:#f59e0b;--shadow:0 16px 42px rgba(15,23,42,.12)}
    *{box-sizing:border-box}html,body{height:100%}body{margin:0;font-family:Pretendard,'Noto Sans KR',Arial,sans-serif;background:var(--bg);color:var(--ink);overflow:hidden}button,input,select{font:inherit}button{cursor:pointer}button:disabled{opacity:.45;cursor:not-allowed}.hidden{display:none!important}
    .top{height:58px;background:var(--nav);color:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 18px;border-bottom:1px solid #2d374b}.brand{display:flex;align-items:center;gap:10px;font-weight:950}.logo{width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,var(--violet),var(--blue));display:grid;place-items:center}.brand small{color:#a8b4cb;margin-left:6px}.top-actions{display:flex;gap:8px;align-items:center}.top-btn{height:34px;border:1px solid #334155;border-radius:9px;background:#172033;color:#e2e8f0;font-size:12px;font-weight:850;padding:0 12px;text-decoration:none;display:inline-flex;align-items:center}.top-btn.main{border:0;background:linear-gradient(135deg,var(--violet),var(--blue));color:#fff}.wrap{height:calc(100vh - 58px);overflow:auto}.center{min-height:100%;display:grid;place-items:center;padding:28px}.card{background:#fff;border:1px solid var(--line);border-radius:22px;box-shadow:var(--shadow);padding:26px}.btn{width:100%;height:40px;border:1px solid var(--line);border-radius:11px;background:#fff;color:#334155;font-size:12px;font-weight:900}.btn.primary{border:0;background:linear-gradient(135deg,var(--violet),var(--blue));color:#fff}.btn.dark{border:0;background:#111827;color:#fff}.btn.green{border:0;background:var(--green);color:#fff}.btn.red{border:0;background:var(--red);color:#fff}.btn.amber{border:0;background:var(--amber);color:#fff}.btn+ .btn{margin-top:8px}.note,.help{margin-top:10px;border-radius:12px;background:#f1f5f9;padding:11px;color:#64748b;font-size:12px;line-height:1.55}.work{height:calc(100vh - 58px);display:grid;grid-template-columns:360px 1fr;min-height:0}.side{background:#fff;border-right:1px solid var(--line);overflow:auto;padding:15px}.side-title{font-size:11px;font-weight:950;letter-spacing:.08em;color:#738099;margin:0 0 12px}.box{border:1px solid var(--line);border-radius:16px;background:#fff;padding:13px;margin-bottom:12px}.box.active{border-color:#a78bfa;box-shadow:0 0 0 3px rgba(124,58,237,.08)}.box h3{font-size:14px;margin:0 0 10px}.row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}.row.three{grid-template-columns:1fr 1fr 1fr}label{display:block;font-size:10px;color:#64748b;font-weight:900;margin:0 0 5px}input,select{width:100%;height:34px;border:1px solid var(--line);border-radius:9px;background:#f8fafc;padding:0 9px;outline:0}input:focus,select:focus{border-color:#8b5cf6;background:#fff}input[type=range]{height:20px;border:0;padding:0;background:transparent}.main{overflow:auto;background:#fff;background-image:radial-gradient(#dbe3ef .8px,transparent .8px);background-size:18px 18px}.canvas-wrap{width:max-content;min-width:860px;min-height:560px;margin:28px auto 90px}.canvas-head{height:36px;display:flex;align-items:center;justify-content:space-between;background:#fff;border:1px solid var(--line);border-bottom:0;border-radius:16px 16px 0 0;padding:0 14px;color:#64748b;font-size:11px;font-weight:900}.canvas-box{position:relative;background:#fff;border:1px solid var(--line);box-shadow:var(--shadow);overflow:hidden}canvas{position:absolute;left:0;top:0}canvas.base{position:relative;display:block}.list{display:grid;gap:7px;max-height:240px;overflow:auto}.item{display:flex;align-items:center;gap:8px;border:1px solid var(--line);border-radius:10px;padding:8px;background:#fff;font-size:11px;cursor:pointer}.item.active{border-color:#8b5cf6;background:#f5f3ff}.dot{width:12px;height:12px;border-radius:3px;background:#8b5cf6}.item strong{display:block;font-size:12px}.item span{display:block;color:#64748b;font-size:10px;margin-top:2px}.sample{display:flex;align-items:center;justify-content:space-between;border:1px solid var(--line);border-radius:10px;background:#f8fafc;padding:7px;font-size:10px;color:#475569;margin-top:6px}.sample i{width:18px;height:18px;border-radius:5px;border:1px solid #cbd5e1;margin-right:6px}.sample span{display:flex;align-items:center}.sample button{border:0;background:transparent;color:#ef4444;font-weight:900}.tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}.tab{height:36px;border:1px solid var(--line);border-radius:10px;background:#fff;color:#475569;font-size:12px;font-weight:900}.tab.active{border-color:#8b5cf6;background:#f5f3ff;color:#6d28d9}.metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.metric{border:1px solid var(--line);border-radius:12px;background:#f8fafc;padding:10px;color:#64748b;font-size:11px}.metric b{display:block;font-size:20px;color:#111827;margin-top:3px}.json-box{max-height:190px;overflow:auto;background:#0f172a;color:#dbeafe;border-radius:10px;padding:10px;font-size:10px;line-height:1.45}.toast{position:fixed;right:22px;bottom:22px;background:#111827;color:#fff;padding:12px 15px;border-radius:12px;font-size:12px;opacity:0;transform:translateY(6px);transition:.16s;z-index:100}.toast.show{opacity:1;transform:none}
</style></head><body>
<header class="top"><div class="brand"><span class="logo">▦</span>SeatTrace <small>좌석 도면 제작 시스템</small></div></header>
<div class="center"><div class="card" style="width:min(920px,100%)">
    <h1 style="margin:0 0 8px;font-size:30px;letter-spacing:-.045em">어떤 좌석 시스템을 만들까요?</h1>
    <p style="margin:0 0 22px;color:#64748b;line-height:1.6">콘서트 대형장과 소극장은 제작 방식이 다르므로 처음부터 분리합니다.</p>
    <button class="btn dark" id="resetAllBtn" style="margin-bottom:16px">저장된 작업 전체 초기화</button>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <a class="card" id="concertStartCard" href="concert-stage1.html" style="text-decoration:none;color:inherit;min-height:250px;box-shadow:none">
            <h2 style="margin:0 0 10px">콘서트 / 대형장</h2>
            <p style="color:#64748b;line-height:1.6">도쿄돔, 체조경기장처럼 전체 구역도와 실제 좌석 배치가 다른 경우.</p>
            <div class="note">Stage1 업로드 → Stage1 단색 도면 추출 → Stage2 구역 버튼 → Stage3 각 구역 좌석 생성</div>
            <button class="btn primary" style="margin-top:18px">콘서트 제작 시작</button>
        </a>
        <a class="card" id="smallStartCard" href="small-seat-builder.html" style="text-decoration:none;color:inherit;min-height:250px;box-shadow:none">
            <h2 style="margin:0 0 10px">소극장 / 좌석 이미지</h2>
            <p style="color:#64748b;line-height:1.6">500석 내외처럼 좌석 하나하나가 원본 이미지에 보이는 경우.</p>
            <div class="note">기존 방식 유지: 이미지 업로드 → 스포이드 → 좌석 후보 분석 → 좌석 버튼 생성/보정</div>
            <button class="btn green" style="margin-top:18px">소극장 제작 시작</button>
        </a>
    </div>
</div></div><input class="hidden" type="file" id="concertFile" accept="image/*"><input class="hidden" type="file" id="smallFile" accept="image/*"><div class="toast" id="toast"></div><script>
    const $=id=>document.getElementById(id);
    function toast(msg){const t=$('toast');t.textContent=msg;t.classList.add('show');clearTimeout(window.__toastTimer);window.__toastTimer=setTimeout(()=>t.classList.remove('show'),2000)}
    function readImage(file, cb){const r=new FileReader();r.onload=()=>cb(r.result);r.readAsDataURL(file)}
    function clearConcertData(){['concert_originalImage','concert_cleanImage','concert_sections','concert_seats','concert_extractSettings','concert_finalLayout','concert_imageMeta','concert_entryFromMain'].forEach(k=>localStorage.removeItem(k))}
    function clearSmallData(){['small_originalImage','small_detectedSeats','small_seats','small_finalLayout','small_entryFromMain'].forEach(k=>localStorage.removeItem(k))}
    $('resetAllBtn').onclick=()=>{clearConcertData();clearSmallData();toast('저장된 작업을 모두 초기화했습니다.')};
    $('concertStartCard').onclick=e=>{e.preventDefault();clearConcertData();$('concertFile').value='';$('concertFile').click()};
    $('smallStartCard').onclick=e=>{e.preventDefault();clearSmallData();$('smallFile').value='';$('smallFile').click()};
    $('concertFile').onchange=e=>{const f=e.target.files[0];if(!f)return;readImage(f,url=>{localStorage.setItem('concert_originalImage',url);localStorage.setItem('concert_entryFromMain','true');toast('콘서트 이미지 등록 완료. Stage1로 이동합니다.');setTimeout(()=>location.href='concert-stage1.html',250)})};
    $('smallFile').onchange=e=>{const f=e.target.files[0];if(!f)return;readImage(f,url=>{localStorage.setItem('small_originalImage',url);localStorage.setItem('small_entryFromMain','true');toast('소극장 이미지 등록 완료. 제작 화면으로 이동합니다.');setTimeout(()=>location.href='small-seat-builder.html',250)})};
</script></body></html>