{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">회원 관리</h1>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">가입 회원 목록</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="userTable" width="100%" cellspacing="0">
                                <thead class="thead-dark">
                                <tr>
                                    <th>회원ID</th>
                                    <th>아이디</th>
                                    <th>이메일</th>
                                    <th>가입일</th>
                                    <th>상태</th>
                                    <th>관리</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#users}}
                                    <tr>
                                        <td>{{id}}</td>
                                        <td>{{username}}</td>
                                        <td>{{email}}</td>
                                        <td>{{createdAt}}</td>
                                        <td>
                                            {{#isActive}}
                                                <span class="badge badge-primary">정상</span>
                                            {{/isActive}}
                                            {{^isActive}}
                                                <span class="badge badge-warning">정지</span>
                                            {{/isActive}}
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-warning btn-sm" onclick="toggleStatus({{id}})">상태변경</button>
                                            <button class="btn btn-outline-danger btn-sm" onclick="deleteUser({{id}})">탈퇴</button>
                                        </td>
                                    </tr>
                                {{/users}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{> admin/layout/footer}}

        <script src="/admin/vendor/datatables/jquery.dataTables.min.js"></script>
        <script src="/admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>
        <script>
            $(document).ready(function() {
                $('#userTable').DataTable({
                    "language": { "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Korean.json" }
                });
            });

            function toggleStatus(id) {
                if(confirm("회원 상태를 변경하시겠습니까?")) {
                    // 추후 POST /admin/users/{id}/status 호출
                    console.log("Toggle Status ID: " + id);
                }
            }

            function deleteUser(id) {
                if(confirm("정말 강제 탈퇴 처리하시겠습니까?")) {
                    // 추후 DELETE /admin/users/{id} 호출
                    console.log("Delete User ID: " + id);
                }
            }
        </script>
    </div>
</div>
</body>
</html>