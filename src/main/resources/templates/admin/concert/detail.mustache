{{> admin/layout/header}}

<script src="/js/core/api.js"></script>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">공연 상세 정보</h1>
                    <div>
                        <a href="/admin/concerts" class="btn btn-secondary btn-sm shadow-sm">목록으로</a>
                        <a href="/admin/concerts/update/{{concert.id}}" class="btn btn-primary btn-sm shadow-sm">공연 정보 수정</a>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연 상세 정보</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 text-center">
                                <img src="{{concert.posterUrl}}" class="img-fluid rounded border" alt="포스터">
                            </div>
                            <div class="col-md-9">
                                <h3 class="font-weight-bold mb-3">{{concert.title}}</h3>
                                <p class="text-muted">{{concert.description}}</p>
                                <ul class="list-unstyled mt-4">
                                    <li class="mb-2"><strong>아티스트:</strong> {{concert.artist}}</li>
                                    <li class="mb-2"><strong>장르:</strong> {{concert.genreLabel}} <small class="text-muted">({{concert.genre}})</small></li>
                                    <li class="mb-2"><strong>장소:</strong> {{concert.venueName}}</li>

                                    <li class="mb-3 mt-3 p-3 bg-light rounded">
                                        <strong class="d-block mb-2"><i class="fas fa-ticket-alt"></i> 티켓 가격표</strong>
                                        <span class="badge badge-danger p-2 mr-2">VIP</span> {{concert.priceVip}}원&nbsp;
                                        <span class="badge badge-primary p-2 mr-2">R</span> {{concert.priceR}}원&nbsp;
                                        <span class="badge badge-success p-2 mr-2">S</span> {{concert.priceS}}원&nbsp;
                                        <span class="badge badge-secondary p-2 mr-2">A</span> {{concert.priceA}}원
                                    </li>

                                    <li class="mb-2 mt-3"><strong>공연기간:</strong> {{concert.startDate}} ~ {{concert.endDate}}</li>
                                    <li class="mb-2"><strong>티켓 오픈:</strong> {{concert.ticketOpenDate}}</li>
                                    <li class="mb-2"><strong>관람시간:</strong> {{concert.runtime}}</li>
                                    <li class="mb-2"><strong>관람등급:</strong> {{concert.ageLimit}}</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">사용자용 상세 페이지 소개 설정</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-12 form-group mb-4">
                                    <label class="font-weight-bold text-danger">상세페이지 내용</label>
                                    {{#concert.detailDescription1}}
                                        <div class="p-3 border rounded bg-light text-dark" style="min-height: 100px;">{{{concert.detailDescription1}}}</div>
                                    {{/concert.detailDescription1}}
                                    {{^concert.detailDescription1}}
                                        <div class="p-3 border rounded bg-light text-muted italic" style="min-height: 100px;">설정된 내용이 없습니다. (사용자 화면에서 숨겨짐)</div>
                                    {{/concert.detailDescription1}}
                                </div>

                                <div class="col-md-12 form-group mb-4">
                                    <label class="font-weight-bold text-info">추가 공연정보 / 유의사항 및 안내</label>
                                    {{#concert.detailDescription2}}
                                        <div class="p-3 border rounded bg-light text-dark" style="min-height: 100px;">{{{concert.detailDescription2}}}</div>
                                    {{/concert.detailDescription2}}
                                    {{^concert.detailDescription2}}
                                        <div class="p-3 border rounded bg-light text-muted italic" style="min-height: 100px;">설정된 내용이 없습니다. (사용자 화면에서 숨겨짐)</div>
                                    {{/concert.detailDescription2}}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <div>
                            <h6 class="m-0 font-weight-bold text-primary">회차(Session) 관리</h6>
                            <small class="text-danger mt-1 d-block">
                                공연 등록 후 회차를 반드시 추가해주세요.
                            </small>
                        </div>
                        <button class="btn btn-sm btn-success shadow-sm" data-toggle="modal" data-target="#addSessionModal">
                            <i class="fas fa-plus fa-sm"></i> 회차 추가
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover">
                                <thead class="thead-light">
                                <tr>
                                    <th>회차 번호(ID)</th>
                                    <th>회차(N회차)</th>
                                    <th>공연 날짜</th>
                                    <th>공연 시간</th>
                                    <th>관리</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#concert.sessionList}}
                                    <tr>
                                        <td class="align-middle text-center">{{id}}</td>
                                        <td class="align-middle text-center">{{round}}회차</td>
                                        <td class="align-middle text-center">{{sessionDate}}</td>
                                        <td class="align-middle text-center">{{sessionTime}}</td>
                                        <td class="align-middle text-center">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    onclick="openEditModal({{id}}, {{round}}, '{{sessionDate}}', '{{sessionTime}}')">수정</button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="deleteSession({{id}})">삭제</button>
                                        </td>
                                    </tr>
                                {{/concert.sessionList}}
                                {{^concert.sessionList}}
                                    <tr>
                                        <td colspan="5" class="text-center py-4">등록된 회차가 없습니다.</td>
                                    </tr>
                                {{/concert.sessionList}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="addSessionModal" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content">
                            <form id="addSessionForm">
                                <div class="modal-header">
                                    <h5 class="modal-title">새 회차 추가</h5>
                                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <div class="form-group">
                                        <label>회차 (예: 1)</label>
                                        <input type="number" name="round" class="form-control" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 날짜</label>
                                        <input type="date" name="sessionDate" class="form-control" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 시간</label>
                                        <input type="time" name="sessionTime" class="form-control" required>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button class="btn btn-secondary" type="button" data-dismiss="modal">취소</button>
                                    <button class="btn btn-success" type="submit">추가하기</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="editSessionModal" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content">
                            <form id="editSessionForm">
                                <input type="hidden" id="editSessionId">
                                <div class="modal-header">
                                    <h5 class="modal-title">회차 수정</h5>
                                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <div class="form-group">
                                        <label>회차</label>
                                        <input type="number" id="editRound" class="form-control" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 날짜</label>
                                        <input type="date" id="editSessionDate" class="form-control" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 시간</label>
                                        <input type="time" id="editSessionTime" class="form-control" required>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button class="btn btn-secondary" type="button" data-dismiss="modal">취소</button>
                                    <button class="btn btn-primary" type="submit">수정하기</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <script>
                    const concertId = {{concert.id}};

                    // 1) 회차 추가 처리 (POST)
                    document.getElementById('addSessionForm').addEventListener('submit', async function (e) {
                        e.preventDefault();
                        const form = e.target;
                        const reqDTO = {
                            round: parseInt(form.round.value),
                            sessionDate: form.sessionDate.value,
                            sessionTime: form.sessionTime.value
                        };

                        try {
                            let { res, data } = await apiPost(`/api/admin/concerts/${concertId}/sessions`, reqDTO);

                            if (res && res.ok && data && (data.code === 1 || data.code === 200 || res.status === 200)) {
                                CcUI.toast('회차가 성공적으로 추가되었습니다.', 'success');
                                setTimeout(() => window.location.reload(), 1000); // 1초 후 새로고침
                            } else {
                                CcUI.alert('회차 추가에 실패했습니다: ' + (data && data.msg ? data.msg : '알 수 없는 오류'));
                            }
                        } catch (error) {
                            console.error('회차 추가 통신 에러:', error);
                            CcUI.alert('서버와 통신에 실패했습니다.');
                        }
                    });

                    // 2) 수정 모달 띄우기 함수
                    function openEditModal(sessionId, round, sessionDate, sessionTime) {
                        document.getElementById('editSessionId').value = sessionId;
                        document.getElementById('editRound').value = round;
                        document.getElementById('editSessionDate').value = sessionDate;
                        document.getElementById('editSessionTime').value = sessionTime;
                        $('#editSessionModal').modal('show');
                    }

                    // 3) 회차 수정 처리 (PUT)
                    document.getElementById('editSessionForm').addEventListener('submit', async function (e) {
                        e.preventDefault();
                        const sessionId = document.getElementById('editSessionId').value;
                        const reqDTO = {
                            round: parseInt(document.getElementById('editRound').value),
                            sessionDate: document.getElementById('editSessionDate').value,
                            sessionTime: document.getElementById('editSessionTime').value
                        };

                        try {
                            let { res, data } = await apiPut(`/api/admin/concerts/${concertId}/sessions/${sessionId}`, reqDTO);

                            if (res && res.ok && data && (data.code === 1 || data.code === 200 || res.status === 200)) {
                                CcUI.toast('성공적으로 수정되었습니다.', 'success');
                                setTimeout(() => window.location.reload(), 1000); // 1초 후 새로고침
                            } else {
                                CcUI.alert('회차 수정에 실패했습니다: ' + (data && data.msg ? data.msg : '알 수 없는 오류'));
                            }
                        } catch (error) {
                            console.error('회차 수정 통신 에러:', error);
                            CcUI.alert('서버와 통신에 실패했습니다.');
                        }
                    });

                    // 4) 회차 논리 삭제 처리 (DELETE)
                    function deleteSession(sessionId) {
                    CcUI.confirm({
                        text: '이 회차를 정말 삭제하시겠습니까?',
                        danger: true,
                        onConfirm: async () => {
                            try {
                                let { res, data } = await apiDelete(`/api/admin/concerts/${concertId}/sessions/${sessionId}`);

                                if (res && res.ok && data && (data.code === 1 || data.code === 200 || res.status === 200)) {
                                    CcUI.toast('성공적으로 삭제되었습니다.', 'success');
                                    setTimeout(() => window.location.reload(), 1000);
                                } else {
                                    CcUI.alert('삭제에 실패했습니다.');
                                }
                            } catch (error) {
                                console.error('회차 삭제 통신 에러:', error);
                                CcUI.alert('서버와 통신에 실패했습니다.');
                            }
                        }
                    });
                }
                </script>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>
</body>
