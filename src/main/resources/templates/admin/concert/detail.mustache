{{> admin/layout/header}}

<script src="/js/core/api.js"></script>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">공연 상세 정보</h1>
                    <div>
                        <a href="/admin/concerts" class="btn btn-secondary btn-sm shadow-sm">목록으로</a>
                        <a href="/admin/concerts/update/{{concert.id}}" class="btn btn-primary btn-sm shadow-sm">공연 정보 수정</a>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연 상세 정보</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 text-center">
                                <img src="{{concert.posterUrl}}" class="img-fluid rounded border" alt="포스터">
                            </div>
                            <div class="col-md-9">
                                <h4 class="font-weight-bold">{{concert.title}}</h4>
                                <p class="text-muted">{{concert.artist}} | {{concert.genre}}</p>
                                <hr>
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>공연장:</strong> {{concert.venueName}}</p>
                                        <p><strong>공연 상태:</strong> <span class="badge badge-success">{{concert.concertStatus}}</span></p>
                                        <p><strong>관람 연령:</strong> {{concert.ageLimit}}</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p><strong>공연 기간:</strong> {{concert.startDate}} ~ {{concert.endDate}}</p>
                                        <p><strong>예매 오픈:</strong> {{concert.ticketOpenDate}}</p>
                                        <p><strong>러닝타임:</strong> {{concert.runtime}}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div class="mt-3">
                            <h6 class="font-weight-bold text-gray-800">공연 설명</h6>
                            <p>{{concert.description}}</p>
                            <h6 class="font-weight-bold text-gray-800">상세 설명 1</h6>
                            <p>{{concert.detailDescription1}}</p>
                            <h6 class="font-weight-bold text-gray-800">상세 설명 2</h6>
                            <p>{{concert.detailDescription2}}</p>
                        </div>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-success">회차 관리</h6>
                        <button type="button" class="btn btn-outline-success btn-sm" data-toggle="modal"
                                data-target="#addSessionModal">
                            + 회차 추가
                        </button>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered table-hover">
                            <thead class="thead-light">
                            <tr>
                                <th>ID</th>
                                <th>회차명</th>
                                <th>날짜</th>
                                <th>시간</th>
                                <th>관리</th>
                            </tr>
                            </thead>
                            <tbody>
                            {{#concert.sessionList}}
                                <tr>
                                    <td>{{id}}</td>
                                    <td>{{round}}</td>
                                    <td>{{sessionDate}}</td>
                                    <td>{{sessionTime}}</td>
                                    <td>
                                        <button class="btn btn-warning btn-sm"
                                                onclick="openEditModal('{{id}}', '{{round}}', '{{sessionDate}}', '{{sessionTime}}')">
                                            수정
                                        </button>
                                        <button type="button" class="btn btn-danger btn-sm"
                                                onclick="deleteSession('{{id}}')">삭제</button>
                                    </td>
                                </tr>
                            {{/concert.sessionList}}
                            {{^concert.sessionList}}
                                <tr>
                                    <td colspan="5" class="text-center py-3">등록된 회차가 없습니다.</td>
                                </tr>
                            {{/concert.sessionList}}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="modal fade" id="addSessionModal" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title font-weight-bold">새 공연 회차 등록</h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <form id="addSessionForm">
                                <div class="modal-body">
                                    <div class="form-group">
                                        <label>회차명</label>
                                        <input type="text" id="addRound" name="round" class="form-control" placeholder="예: 3회차" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 날짜</label>
                                        <input type="date" id="addSessionDate" name="sessionDate" class="form-control" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 시간</label>
                                        <input type="time" id="addSessionTime" name="sessionTime" class="form-control" required>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">취소</button>
                                    <button type="button" id="btnSaveSession" class="btn btn-success">회차 등록</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="editSessionModal" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title font-weight-bold">회차 정보 수정</h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <form id="editSessionForm">
                                <input type="hidden" id="editSessionId" name="sessionId">
                                <div class="modal-body">
                                    <div class="form-group">
                                        <label>회차명</label>
                                        <input type="text" id="editRound" name="round" class="form-control" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 날짜</label>
                                        <input type="date" id="editSessionDate" name="sessionDate" class="form-control" required>
                                    </div>
                                    <div class="form-group">
                                        <label>공연 시간</label>
                                        <input type="time" id="editSessionTime" name="sessionTime" class="form-control" required>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">취소</button>
                                    <button type="button" id="btnUpdateSession" class="btn btn-warning">수정 완료</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <script>
                    const concertId = "{{concert.id}}";

                    // 1) 회차 추가 기능 (POST 비동기 처리 추가)
                    document.getElementById('btnSaveSession').addEventListener('click', async () => {
                        const reqDTO = {
                            round: document.getElementById('addRound').value,
                            sessionDate: document.getElementById('addSessionDate').value,
                            sessionTime: document.getElementById('addSessionTime').value
                        };

                        // 유효성 검증 예외 방어
                        if (!reqDTO.round || !reqDTO.sessionDate || !reqDTO.sessionTime) {
                            alert('모든 필수 항목을 입력해주세요.');
                            return;
                        }

                        try {
                            // 백엔드 엔드포인트 명세 설계 규격 매핑: /api/concert/{concertId}/sessions
                            let { res, data } = await apiPost(`/api/concert/${concertId}/sessions`, reqDTO);

                            if (res && res.ok && data && (data.code === 1 || data.code === 200 || res.status === 200)) {
                                alert('새로운 회차가 정상 등록되었습니다.');
                                window.location.reload();
                            } else {
                                alert('회차 등록에 실패했습니다: ' + (data && data.msg ? data.msg : '알 수 없는 오류'));
                            }
                        } catch (error) {
                            console.error('회차 추가 통신 에러:', error);
                            alert('서버와 통신 중 오류가 발생했습니다.');
                        }
                    });

                    // 2) 수정 모달창 오픈 및 데이터 세팅
                    function openEditModal(id, round, date, time) {
                        document.getElementById('editSessionId').value = id;
                        document.getElementById('editRound').value = round;
                        document.getElementById('editSessionDate').value = date;

                        if (time && time.length > 5) {
                            time = time.substring(0, 5);
                        }
                        document.getElementById('editSessionTime').value = time;
                        $('#editSessionModal').modal('show');
                    }

                    // 3) 회차 수정 완료 처리 (PUT)
                    document.getElementById('btnUpdateSession').addEventListener('click', async () => {
                        const sessionId = document.getElementById('editSessionId').value;
                        const reqDTO = {
                            round: document.getElementById('editRound').value,
                            sessionDate: document.getElementById('editSessionDate').value,
                            sessionTime: document.getElementById('editSessionTime').value
                        };

                        try {
                            let { res, data } = await apiPut(`/api/concert/${concertId}/sessions/${sessionId}`, reqDTO);

                            if (res && res.ok && data && (data.code === 1 || data.code === 200 || res.status === 200)) {
                                alert('회차 정보가 성공적으로 수정되었습니다.');
                                window.location.reload();
                            } else {
                                alert('회차 수정에 실패했습니다: ' + (data && data.msg ? data.msg : '알 수 없는 오류'));
                            }
                        } catch (error) {
                            console.error('회차 수정 통신 에러:', error);
                            alert('서버와 통신에 실패했습니다.');
                        }
                    });

                    // 4) 회차 논리 삭제 처리 (DELETE)
                    async function deleteSession(sessionId) {
                        if (!confirm('이 회차를 정말 삭제하시겠습니까? (소프트딜리트)')) {
                            return;
                        }

                        try {
                            let { res, data } = await apiDelete(`/api/concert/${concertId}/sessions/${sessionId}`);

                            if (res && res.ok && data && (data.code === 1 || data.code === 200 || res.status === 200)) {
                                alert('성공적으로 삭제되었습니다.');
                                window.location.reload();
                            } else {
                                alert('삭제에 실패했습니다: ' + (data && data.msg ? data.msg : '알 수 없는 오류'));
                            }
                        } catch (error) {
                            console.error('회차 삭제 통신 에러:', error);
                            alert('서버와 통신에 실패했습니다.');
                        }
                    }
                </script>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>
</body>