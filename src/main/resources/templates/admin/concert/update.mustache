{{> admin/layout/header}}

<script src="/js/core/api.js"></script>
<script src="/js/core/file.js"></script>
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs4.min.css" rel="stylesheet">

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <h1 class="h3 mb-4 text-gray-800">공연 정보 수정</h1>

                <form id="concertUpdateForm">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">공연 상세 정보 수정</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label>공연 제목</label>
                                    <input type="text" name="title" class="form-control" value="{{concert.title}}" required>
                                </div>
                                <div class="col-md-6 form-group">
                                    <label>아티스트</label>
                                    <input type="text" name="artist" class="form-control" value="{{concert.artist}}" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 form-group">
                                    <label>공연장 선택</label>
                                    <select name="venueId" class="form-control">
                                        {{#venueList}}
                                            <option value="{{id}}">{{name}}</option>
                                        {{/venueList}}
                                        {{^venueList}}
                                            <option value="1">올림픽공원 체조경기장</option>
                                            <option value="2">KSPO DOME</option>
                                        {{/venueList}}
                                    </select>
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>장르</label>
                                    <select name="genre" class="form-control" data-current-genre="{{concert.genre}}" required>
                                        <option value="concert">콘서트</option>
                                        <option value="musical">뮤지컬</option>
                                        <option value="festival">페스티벌</option>
                                        <option value="fanmeeting">팬미팅</option>
                                        <option value="classic">클래식</option>
                                        <option value="etc">기타</option>
                                    </select>
                                </div>
                            </div>

                            <hr class="mt-4 mb-4">
                            <h6 class="font-weight-bold text-primary mb-3">좌석 등급별 가격</h6>
                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>VIP석 가격</label>
                                    <input type="number" name="priceVip" class="form-control" value="{{concert.priceVip}}" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>R석 가격</label>
                                    <input type="number" name="priceR" class="form-control" value="{{concert.priceR}}" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>S석 가격</label>
                                    <input type="number" name="priceS" class="form-control" value="{{concert.priceS}}" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>A석 가격</label>
                                    <input type="number" name="priceA" class="form-control" value="{{concert.priceA}}" min="0" required>
                                </div>
                            </div>

                            <hr class="mt-4 mb-4">
                            <h6 class="font-weight-bold text-primary mb-3">일정 및 상태</h6>
                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>티켓 오픈일</label>
                                    <input type="datetime-local" name="ticketOpenDate" class="form-control" value="{{concert.ticketOpenDate}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>공연 시작일</label>
                                    <input type="date" name="startDate" class="form-control" value="{{concert.startDate}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>공연 종료일</label>
                                    <input type="date" name="endDate" class="form-control" value="{{concert.endDate}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>공연 상태</label>
                                    <select name="concertStatus" class="form-control">
                                        <option value="OPEN" selected>오픈 (OPEN)</option>
                                        <option value="COMING_SOON">오픈 예정 (COMING_SOON)</option>
                                        <option value="CLOSED_SOON">마감 임박 (CLOSED_SOON)</option>
                                        <option value="CLOSED">종료 (CLOSED)</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>러닝타임</label>
                                    <input type="text" name="runtime" class="form-control" value="{{concert.runtime}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>관람 등급</label>
                                    <input type="text" name="ageLimit" class="form-control" value="{{concert.ageLimit}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>주최/주관</label>
                                    <input type="text" name="organizer" class="form-control" value="{{concert.organizer}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>고객센터</label>
                                    <input type="text" name="contact" class="form-control" value="{{concert.contact}}" required>
                                </div>
                            </div>

                            <hr class="mt-4">

                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label>상세 타이틀</label>
                                    <input type="text" name="detailTitle" class="form-control" value="{{concert.detailTitle}}" required>
                                </div>
                                <div class="col-md-6 form-group">
                                    <label>간략 설명</label>
                                    <input type="text" name="description" class="form-control" value="{{concert.description}}">
                                </div>
                            </div>

                            <div class="form-group mt-4">
                                <label>포스터 이미지 (변경할 경우만 선택)</label>
                                <div class="custom-file">
                                    <input type="file" name="posterImage" class="custom-file-input" id="posterUpdateFile" accept="image/*">
                                    <label class="custom-file-label" for="posterUpdateFile">새 이미지를 선택하세요</label>
                                </div>
                            </div>

                            <div class="form-group mt-4">
                                <label class="font-weight-bold text-dark">상세 배너 이미지 (긴 세로 상세 이미지)</label>
                                {{#_csrf}}<span id="uploadCsrfMeta" data-param="{{parameterName}}" data-token="{{token}}" hidden></span>{{/_csrf}}
                                <div class="d-flex align-items-center" style="gap:8px;">
                                    <input type="text" id="detailBannerUrlInput" name="detailBannerUrl"
                                           class="form-control" value="{{concert.detailBannerUrl}}"
                                           placeholder="이미지를 업로드하면 URL이 자동으로 채워집니다." readonly>
                                    <label for="detailBannerFileInput" class="btn btn-outline-secondary mb-0 text-nowrap" style="cursor:pointer;">파일 변경</label>
                                    <input type="file" id="detailBannerFileInput" accept="image/*" class="d-none">
                                </div>
                                <div id="detailBannerUploadStatus" class="small mt-1"></div>
                                {{#concert.detailBannerUrl}}
                                <div id="detailBannerPreviewWrap" class="mt-2">
                                    <img id="detailBannerPreview" src="{{concert.detailBannerUrl}}" alt="상세 이미지 미리보기"
                                         style="max-width:200px; border:1px solid #dee2e6; border-radius:4px;">
                                </div>
                                {{/concert.detailBannerUrl}}
                                {{^concert.detailBannerUrl}}
                                <div id="detailBannerPreviewWrap" class="mt-2 d-none">
                                    <img id="detailBannerPreview" src="" alt="상세 이미지 미리보기"
                                         style="max-width:200px; border:1px solid #dee2e6; border-radius:4px;">
                                </div>
                                {{/concert.detailBannerUrl}}
                                <small class="text-muted d-block mt-1">700px 폭의 긴 세로 이미지를 권장합니다. (최대 50MB)</small>
                            </div>

                            <div class="row">
                                <div class="col-md-12 form-group">
                                    <label class="font-weight-bold text-dark">상세페이지 내용</label>
                                    <textarea name="detailDescription1" class="form-control js-summernote" rows="8"
                                              placeholder="상세페이지 본문에 표시할 소개, 이미지, 안내 문구를 작성하세요.">{{concert.detailDescription1}}</textarea>
                                </div>
                                <div class="col-md-12 form-group">
                                    <label class="font-weight-bold text-dark">추가 공연정보 / 유의사항 및 안내</label>
                                    <textarea name="detailDescription2" class="form-control js-summernote" rows="6"
                                              placeholder="추가 공연 정보, 캐스팅 변경, 예매 유의사항 등을 작성하세요.">{{concert.detailDescription2}}</textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mb-5">
                        <a href="/admin/concerts/{{concert.id}}" class="btn btn-secondary mr-2">취소</a>
                        <button type="submit" class="btn btn-primary px-5">수정 저장하기</button>
                    </div>
                </form>

                <script>
                    function initSummernoteEditors() {
                        if (!window.jQuery || !jQuery.fn || !jQuery.fn.summernote) return;

                        jQuery('.js-summernote').summernote({
                            height: 320,
                            placeholder: '상세 페이지에 표시할 내용을 입력하세요.',
                            toolbar: [
                                ['style', ['style']],
                                ['font', ['bold', 'italic', 'underline', 'clear']],
                                ['fontname', ['fontname']],
                                ['color', ['color']],
                                ['para', ['ul', 'ol', 'paragraph']],
                                ['insert', ['link', 'picture', 'video']],
                                ['view', ['fullscreen', 'codeview', 'help']]
                            ]
                        });
                    }

                    window.addEventListener('load', function () {
                        if (window.jQuery && jQuery.fn && jQuery.fn.summernote) {
                            initSummernoteEditors();
                            return;
                        }

                        const script = document.createElement('script');
                        script.src = 'https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs4.min.js';
                        script.onload = initSummernoteEditors;
                        document.body.appendChild(script);
                    });

                    function syncSummernoteEditors() {
                        if (!window.jQuery || !jQuery.fn || !jQuery.fn.summernote) return;
                        document.querySelectorAll('.js-summernote').forEach((editor) => {
                            editor.value = jQuery(editor).summernote('code');
                        });
                    }

                    function normalizeBlank(value) {
                        return value === '' ? null : value;
                    }

                    const concertIdText = "{{concert.id}}";
                    const concertId = concertIdText ? parseInt(concertIdText) : null;
                    const concertUpdateForm = document.getElementById('concertUpdateForm');
                    const posterFileInput = document.getElementById('posterUpdateFile');
                    const genreSelect = concertUpdateForm?.querySelector('[name="genre"]');

                    if (genreSelect && genreSelect.dataset.currentGenre) {
                        genreSelect.value = genreSelect.dataset.currentGenre;
                    }

                    if (posterFileInput) {
                        posterFileInput.addEventListener('change', function (e) {
                            const fileName = e.target.files[0]?.name || '새 이미지를 선택하세요';
                            const label = e.target.nextElementSibling;
                            if (label) label.innerText = fileName;
                        });
                    }

                    (function () {
                        const fileInput = document.getElementById('detailBannerFileInput');
                        const urlInput  = document.getElementById('detailBannerUrlInput');
                        const status    = document.getElementById('detailBannerUploadStatus');
                        const previewWrap = document.getElementById('detailBannerPreviewWrap');
                        const preview   = document.getElementById('detailBannerPreview');
                        if (!fileInput) return;

                        fileInput.addEventListener('change', async function () {
                            const file = this.files[0];
                            if (!file) return;

                            status.textContent = '업로드 중...';
                            status.className = 'small mt-1 text-info';

                            const csrfMeta = document.getElementById('uploadCsrfMeta');
                            const headers  = {};
                            if (csrfMeta) headers['X-CSRF-TOKEN'] = csrfMeta.dataset.token;

                            const body = new FormData();
                            body.append('file', file);

                            try {
                                const res  = await fetch('/admin/upload/image', { method: 'POST', headers, body });
                                const data = await res.json();
                                if (res.ok && data.status === 200) {
                                    urlInput.value = data.body;
                                    preview.src = data.body;
                                    previewWrap.classList.remove('d-none');
                                    status.textContent = '업로드 완료 ✓';
                                    status.className = 'small mt-1 text-success';
                                } else {
                                    status.textContent = '업로드 실패: ' + (data.msg || '서버 오류');
                                    status.className = 'small mt-1 text-danger';
                                }
                            } catch (e) {
                                status.textContent = '업로드 중 오류가 발생했습니다.';
                                status.className = 'small mt-1 text-danger';
                            }
                        });
                    })();

                    if (concertUpdateForm) {
                        concertUpdateForm.addEventListener('submit', function (e) {
                            e.preventDefault();

                            CcUI.confirm({
                                text: '공연 정보를 수정하시겠습니까?',
                                onConfirm: async () => {
                                    try {
                                        syncSummernoteEditors();
                                        const formData = new FormData(concertUpdateForm);

                                        const reqDTO = {
                                            title: formData.get('title'),
                                            artist: formData.get('artist'),
                                            venueId: parseInt(formData.get('venueId')),
                                            genre: formData.get('genre'),
                                            priceVip: parseInt(formData.get('priceVip')),
                                            priceR: parseInt(formData.get('priceR')),
                                            priceS: parseInt(formData.get('priceS')),
                                            priceA: parseInt(formData.get('priceA')),
                                            ticketOpenDate: normalizeBlank(formData.get('ticketOpenDate')),
                                            startDate: normalizeBlank(formData.get('startDate')),
                                            endDate: normalizeBlank(formData.get('endDate')),
                                            concertStatus: formData.get('concertStatus'),
                                            runtime: formData.get('runtime'),
                                            ageLimit: formData.get('ageLimit'),
                                            organizer: formData.get('organizer'),
                                            contact: formData.get('contact'),
                                            detailTitle: formData.get('detailTitle'),
                                            detailBannerUrl: normalizeBlank(formData.get('detailBannerUrl')),
                                            description: formData.get('description'),
                                            detailDescription1: formData.get('detailDescription1'),
                                            detailDescription2: formData.get('detailDescription2'),
                                            posterImageBase64: null
                                        };

                                        const posterFile = posterFileInput?.files[0];
                                        if (posterFile) {
                                            reqDTO.posterImageBase64 = await toBase64(posterFile);
                                        }

                                        const { res, data } = await apiPut(`/api/admin/concerts/${concertId}`, reqDTO);

                                        if (res?.ok && data && (data.status === 200 || data.code === 1 || data.code === 200 || res.status === 200)) {
                                            CcUI.toast('공연 정보가 수정되었습니다.');
                                            setTimeout(() => {
                                                window.location.href = `/admin/concerts/${concertId}`;
                                            }, 1500);
                                        } else {
                                            CcUI.alert('수정에 실패했습니다: ' + (data?.msg || data?.message || '알 수 없는 오류'));
                                        }
                                    } catch (error) {
                                        CcUI.alert('서버 통신에 실패했습니다. 관리자에게 문의하세요.');
                                    }
                                }
                            });
                        });
                    }
                </script>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>
</body>
