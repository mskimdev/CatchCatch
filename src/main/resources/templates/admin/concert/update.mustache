{{> admin/layout/header}}

<script src="/js/core/api.js"></script>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <h1 class="h3 mb-4 text-gray-800">공연 정보 수정</h1>

                <form id="concertUpdateForm">

                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">공연 상세 정보 수정</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label>공연 제목</label>
                                    <input type="text" name="title" class="form-control" value="{{concert.title}}" required>
                                </div>
                                <div class="col-md-6 form-group">
                                    <label>아티스트</label>
                                    <input type="text" name="artist" class="form-control" value="{{concert.artist}}" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 form-group">
                                    <label>공연장 선택</label>
                                    <select name="venueId" class="form-control">
                                        {{#venueList}}
                                            <option value="{{id}}">{{name}}</option>
                                        {{/venueList}}
                                        {{^venueList}}
                                            <option value="1">올림픽공원 체조경기장 (기본값)</option>
                                            <option value="2">KSPO DOME</option>
                                        {{/venueList}}
                                    </select>
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>장르</label>
                                    <input type="text" name="genre" class="form-control" value="{{concert.genre}}" required>
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>카테고리</label>
                                    <input type="text" name="category" class="form-control" value="콘서트" required>
                                </div>
                            </div>

                            <!-- 💡 새로 추가된 티켓 가격 수정 영역 -->
                            <hr class="mt-4 mb-4">
                            <h6 class="font-weight-bold text-primary mb-3">티켓 가격 수정</h6>
                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>VIP석 가격</label>
                                    <input type="number" name="priceVip" class="form-control" value="{{concert.priceVip}}" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>R석 가격</label>
                                    <input type="number" name="priceR" class="form-control" value="{{concert.priceR}}" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>S석 가격</label>
                                    <input type="number" name="priceS" class="form-control" value="{{concert.priceS}}" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>A석 가격</label>
                                    <input type="number" name="priceA" class="form-control" value="{{concert.priceA}}" min="0" required>
                                </div>
                            </div>

                            <hr class="mt-4 mb-4">
                            <h6 class="font-weight-bold text-primary mb-3">상세 일정 및 상태</h6>

                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>티켓 오픈일</label>
                                    <input type="datetime-local" name="ticketOpenDate" class="form-control" value="{{concert.ticketOpenDate}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>시작일</label>
                                    <input type="date" name="startDate" class="form-control" value="{{concert.startDate}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>종료일</label>
                                    <input type="date" name="endDate" class="form-control" value="{{concert.endDate}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>공연 상태</label>
                                    <select name="concertStatus" class="form-control">
                                        <option value="OPEN" selected>오픈 (OPEN)</option>
                                        <option value="COMING_SOON">오픈 예정 (COMING_SOON)</option>
                                        <option value="CLOSED_SOON">마감 임박 (CLOSED_SOON)</option>
                                        <option value="CLOSED">종료 (CLOSED)</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>관람 시간</label>
                                    <input type="text" name="runtime" class="form-control" value="{{concert.runtime}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>관람 등급</label>
                                    <input type="text" name="ageLimit" class="form-control" value="{{concert.ageLimit}}" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>주최/주관</label>
                                    <input type="text" name="organizer" class="form-control" value="기본 기획사" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>고객센터</label>
                                    <input type="text" name="contact" class="form-control" value="1544-0000" required>
                                </div>
                            </div>

                            <hr class="mt-4">

                            <div class="form-group">
                                <label>메인 상세 타이틀</label>
                                <input type="text" name="detailTitle" class="form-control" value="{{concert.description}}" required>
                            </div>
                            <div class="form-group">
                                <label>상세 설명 1</label>
                                <textarea name="detailDescription1" class="form-control" rows="3" required>{{concert.detailDescription1}}</textarea>
                            </div>
                            <div class="form-group">
                                <label>상세 설명 2</label>
                                <textarea name="detailDescription2" class="form-control" rows="3" required>{{concert.detailDescription2}}</textarea>
                            </div>

                            <div class="form-group mt-4">
                                <label>포스터 이미지 (변경할 경우만 선택)</label>
                                <div class="custom-file">
                                    <input type="file" name="posterImage" class="custom-file-input" id="posterUpdateFile" accept="image/*">
                                    <label class="custom-file-label" for="posterUpdateFile">새 이미지를 선택하세요</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mb-5">
                        <a href="/admin/concerts/{{concert.id}}" class="btn btn-secondary mr-2">취소</a>
                        <button type="submit" class="btn btn-primary px-5">수정 저장하기</button>
                    </div>

                </form>

                <script>
                    const concertId = {{concert.id}};

                    document.getElementById('posterUpdateFile').addEventListener('change', function (e) {
                        var fileName = document.getElementById("posterUpdateFile").files[0].name;
                        var nextSibling = e.target.nextElementSibling;
                        if (nextSibling) {
                            nextSibling.innerText = fileName;
                        }
                    });

                    // 파일을 Base64로 변환해주는 헬퍼 함수
                    function fileToBase64(file) {
                        return new Promise((resolve, reject) => {
                            const reader = new FileReader();
                            reader.readAsDataURL(file);
                            reader.onload = () => resolve(reader.result);
                            reader.onerror = error => reject(error);
                        });
                    }

                    document.getElementById('concertUpdateForm').addEventListener('submit', async function (e) {
                        e.preventDefault();

                        if (!confirm("공연 정보를 수정하시겠습니까?")) return;

                        const form = e.target;

                        // reqDTO에 가격 4개 추가
                        const reqDTO = {
                            title: form.title.value,
                            artist: form.artist.value,
                            venueId: parseInt(form.venueId.value),
                            genre: form.genre.value,
                            category: form.category.value,

                            priceVip: parseInt(form.priceVip.value) || 0,
                            priceR: parseInt(form.priceR.value) || 0,
                            priceS: parseInt(form.priceS.value) || 0,
                            priceA: parseInt(form.priceA.value) || 0,

                            ticketOpenDate: form.ticketOpenDate.value,
                            startDate: form.startDate.value,
                            endDate: form.endDate.value,
                            runtime: form.runtime.value,
                            ageLimit: form.ageLimit.value,
                            organizer: form.organizer.value,
                            contact: form.contact.value,
                            detailTitle: form.detailTitle.value,
                            description: form.detailTitle.value,
                            detailDescription1: form.detailDescription1.value,
                            detailDescription2: form.detailDescription2.value,
                            concertStatus: form.concertStatus.value
                        };

                        const posterInput = form.posterImage;
                        if (posterInput && posterInput.files.length > 0) {
                            reqDTO.posterImageBase64 = await fileToBase64(posterInput.files[0]);
                        }

                        CcUI.loading.show();

                        try {
                            let { res, data } = await apiPut(`/api/concert/${concertId}`, reqDTO);

                            if (res && res.ok && data && (data.code === 1 || data.code === 200 || res.status === 200)) {
                                CcUI.toast("공연 정보가 성공적으로 수정되었습니다.");
                                setTimeout(() => {
                                    location.href = `/admin/concerts/${concertId}`;
                                }, 1500);
                            } else {
                                CcUI.alert("수정 실패: " + (data && data.msg ? data.msg : "알 수 없는 오류"));
                            }
                        } catch (error) {
                            console.error("수정 요청 중 오류 발생:", error);
                            CcUI.alert("서버와 통신 중 오류가 발생했습니다.");
                        } finally {
                            CcUI.loading.hide();
                        }
                    });
                </script>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>
</body>