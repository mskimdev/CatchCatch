{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">{{pageTitle}}</h1>
                    <a href="/admin/concerts/create" class="btn btn-sm btn-primary shadow-sm">
                        <i class="fas fa-plus fa-sm text-white-50"></i> 새 공연 등록
                    </a>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연 리스트</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                                <thead class="thead-light">
                                <tr>
                                    <th>ID</th>
                                    <th>공연명</th>
                                    <th>회차 정보</th>
                                    <th>관리</th>
                                </tr>
                                </thead>

                                <tbody>
                                {{#concerts}}
                                    <tr>
                                        <td class="align-middle">{{id}}</td>

                                        <td class="align-middle font-weight-bold">
                                            <a href="/admin/concerts/{{id}}">{{title}}</a>
                                        </td>

                                        <td class="align-middle">
                                            <ul class="list-unstyled mb-0">
                                                {{#sessionList}}
                                                    <li class="badge badge-info mb-1 p-2">
                                                        {{sessionDate}} {{sessionTime}} - {{round}}
                                                    </li>
                                                {{/sessionList}}
                                                {{^sessionList}}
                                                    <span class="text-muted small">등록된 회차 없음</span>
                                                {{/sessionList}}
                                            </ul>
                                        </td>

                                        <td class="align-middle">
                                            <button type="button"
                                                    class="btn btn-danger btn-sm"
                                                    onclick="deleteConcert({{id}})">삭제</button>
                                        </td>
                                    </tr>
                                {{/concerts}}

                                {{^concerts}}
                                    <tr>
                                        <td colspan="4" class="text-center py-4">등록된 공연이 없습니다.</td>
                                    </tr>
                                {{/concerts}}
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>

<script>
    // list.mustache 하단의 스크립트 부분 수정

async function deleteConcert(id) {
    if (!confirm('정말 삭제하시겠습니까?')) {
        return;
    }

    try {
        // 백엔드 주소에 맞춰 delete 글자를 빼고 요청합니다.
        let response = await api.delete(`/api/admin/concerts/${id}`);

        // 응답 코드가 성공(1)이거나 상태가 200일 때
        if(response.code === 1 || response.status === 200) {
            alert('성공적으로 삭제되었습니다.');
            window.location.reload(); // 여기서 자바스크립트가 화면을 새로고침합니다!
        } else {
            alert('삭제에 실패했습니다: ' + (response.msg || '알 수 없는 오류'));
        }
    } catch (error) {
        console.error('삭제 요청 중 오류 발생:', error);
        alert('삭제 처리 중 서버와 통신에 실패했습니다.');
    }
}
</script>
</body>