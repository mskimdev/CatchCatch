{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">{{pageTitle}}</h1>
                    <a href="/admin/concerts/create" class="btn btn-sm btn-primary shadow-sm">
                        <i class="fas fa-plus fa-sm text-white-50"></i> 새 공연 등록
                    </a>
                </div>

                {{#isFilteredByComingSoon}}
                <div class="alert alert-info d-flex justify-content-between align-items-center">
                    <span>오픈 예정 콘서트만 표시 중입니다.</span>
                    <a href="/admin/concerts" class="btn btn-sm btn-outline-secondary">전체 보기</a>
                </div>
                {{/isFilteredByComingSoon}}

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연 리스트</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                                <thead class="thead-light">
                                <tr class="text-center">
                                    <th style="width: 5%;">ID</th>
                                    <th style="width: 30%;">공연명 및 기본정보</th>
                                    <th style="width: 15%;">VIP석 가격</th>
                                    <th style="width: 35%;">회차 정보 (총 {{totalSessions}}회)</th>
                                    <th style="width: 15%;">관리</th>
                                </tr>
                                </thead>

                                <tbody>
                                {{#concerts}}
                                    <tr>
                                        <td class="align-middle text-center">{{id}}</td>
                                        <td class="align-middle">
                                            <span class="badge badge-info mb-1">{{concertStatus}}</span><br>
                                            <h6 class="font-weight-bold mb-1">{{title}}</h6>
                                            <small class="text-muted">
                                                <i class="fas fa-user mr-1"></i>{{artist}} |
                                                <i class="fas fa-map-marker-alt mr-1"></i>{{venueName}} <br>
                                                <i class="fas fa-clock mr-1"></i>{{runtime}} | {{ageLimit}}
                                            </small>
                                        </td>

                                        <td class="align-middle text-center">
                                            <span class="text-danger font-weight-bold">{{priceVip}}원</span>
                                        </td>

                                        <td class="align-middle">
                                            <div class="mb-1"><strong>총 {{totalSessions}}회차 진행</strong></div>
                                            <ul class="list-unstyled mb-0" style="font-size: 0.85rem; max-height: 80px; overflow-y: auto;">
                                                {{#sessionList}}
                                                    <li class="border-bottom py-1">
                                                        <span class="badge badge-secondary mr-1">{{round}}회차</span>
                                                        {{sessionDate}} {{sessionTime}}
                                                    </li>
                                                {{/sessionList}}
                                                {{^sessionList}}
                                                    <li class="text-muted">등록된 회차가 없습니다.</li>
                                                {{/sessionList}}
                                            </ul>
                                        </td>

                                        <td class="align-middle text-center">
                                            <a href="/admin/concerts/{{id}}" class="btn btn-sm btn-outline-primary mb-1 d-block">상세보기</a>
                                            <button class="btn btn-sm btn-outline-danger d-block w-100" onclick="deleteConcert({{id}})">삭제</button>
                                        </td>
                                    </tr>
                                {{/concerts}}

                                {{^concerts}}
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="text-muted">등록된 공연이 없습니다.</div>
                                        </td>
                                    </tr>
                                {{/concerts}}
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>

<script src="/js/core/api.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const deleteSuccessMessage = sessionStorage.getItem('concertDeleteSuccess');
        if (deleteSuccessMessage) {
            sessionStorage.removeItem('concertDeleteSuccess');
            CcUI.toast(deleteSuccessMessage);
        }
    });

    function deleteConcert(id) {
        CcUI.confirm({
            title: '공연을 삭제하시겠습니까?',
            text: '삭제된 공연은 사용자 화면에 노출되지 않습니다.',
            confirmText: '삭제',
            cancelText: '취소',
            danger: true,
            onConfirm: async () => {
                try {
                    CcUI.loading.show('공연을 삭제하고 있습니다...');
                    const { res, data } = await apiDelete(`/api/admin/concerts/${id}`);
                    CcUI.loading.hide();

                    if (res && res.ok) {
                        sessionStorage.setItem(
                            'concertDeleteSuccess',
                            data?.body || data?.msg || '공연이 삭제되었습니다.'
                        );
                        window.location.reload();
                        return;
                    }

                    CcUI.alert(data?.msg || '공연 삭제에 실패했습니다.', 'error');
                } catch (error) {
                    CcUI.loading.hide();
                    console.error('삭제 요청 중 오류 발생:', error);
                    CcUI.alert('삭제 처리 중 서버와 통신하지 못했습니다.', 'error');
                }
            }
        });
    }
</script>
</body>
