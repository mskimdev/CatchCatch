{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">{{pageTitle}}</h1>
                    <a href="/admin/concerts/create" class="btn btn-sm btn-primary shadow-sm">
                        <i class="fas fa-plus fa-sm text-white-50"></i> 새 공연 등록
                    </a>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연 목록</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                                <thead class="thead-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>공연명</th>
                                    <th>아티스트</th>
                                    <th>상태</th>
                                    <th>관리</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#concerts}}
                                    <tr>
                                        <td>{{id}}</td>
                                        <td>{{title}}</td>
                                        <td>{{artist}}</td>
                                        <td>
                                            <span class="badge {{badgeClass}}">{{status}}</span>
                                        </td>
                                        <td>
                                            <a href="/admin/concerts/edit/{{id}}" class="btn btn-warning btn-circle btn-sm"><i class="fas fa-pen"></i></a>
                                            <button class="btn btn-danger btn-circle btn-sm" onclick="confirmDelete({{id}})"><i class="fas fa-trash"></i></button>
                                        </td>
                                    </tr>
                                {{/concerts}}
                                {{^concerts}}
                                    <tr>
                                        <td colspan="5" class="text-center">등록된 공연이 없습니다.</td>
                                    </tr>
                                {{/concerts}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{> admin/layout/footer}}
    </div>
</div>

<link href="/admin/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
<script src="/admin/vendor/datatables/jquery.dataTables.min.js"></script>
<script src="/admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>

<script>
    $(document).ready(function() {
        $('#dataTable').DataTable({
            "order": [[ 0, "desc" ]],
            "language": {
                "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Korean.json"
            }
        });
    });

    function confirmDelete(id) {
        if(confirm("정말 삭제하시겠습니까?")) {
            // 추후 AJAX delete 요청으로 연결할 부분
            console.log("Delete ID: " + id);
        }
    }
</script>
</body>
</html>