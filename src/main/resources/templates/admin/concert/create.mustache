{{> admin/layout/header}}

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <h1 class="h3 mb-4 text-gray-800">새 공연 등록</h1>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">공연 기본 정보 입력</h6>
                    </div>
                    <div class="card-body">
                        <form action="/admin/concerts" method="POST" enctype="multipart/form-data">

                            <div class="form-row">
                                <div class="form-group col-md-6">
                                    <label for="title">공연명 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="title" name="title" placeholder="예: 아이유 콘서트 : The Golden Hour" required>
                                </div>
                                <div class="form-group col-md-6">
                                    <label for="artist">아티스트 <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="artist" name="artist" placeholder="예: 아이유 (IU)" required>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group col-md-4">
                                    <label for="venue">공연장 <span class="text-danger">*</span></label>
                                    <select id="venue" name="venueId" class="form-control" required>
                                        <option value="" selected disabled>공연장을 선택하세요</option>
                                        <option value="1">KSPO DOME (올림픽체조경기장)</option>
                                        <option value="2">고척스카이돔</option>
                                        <option value="3">잠실종합운동장 주경기장</option>
                                    </select>
                                </div>
                                <div class="form-group col-md-4">
                                    <label for="genre">장르 <span class="text-danger">*</span></label>
                                    <select id="genre" name="genre" class="form-control" required>
                                        <option value="CONCERT" selected>콘서트</option>
                                        <option value="MUSICAL">뮤지컬</option>
                                        <option value="CLASSIC">클래식/무용</option>
                                        <option value="EXHIBITION">전시/행사</option>
                                    </select>
                                </div>
                                <div class="form-group col-md-4">
                                    <label for="ticketOpenDate">티켓 오픈 일시</label>
                                    <input type="datetime-local" class="form-control" id="ticketOpenDate" name="ticketOpenDate">
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="description">상세 설명</label>
                                <textarea class="form-control" id="description" name="description" rows="5" placeholder="공연에 대한 상세 설명을 입력하세요"></textarea>
                            </div>

                            <div class="form-group">
                                <label for="posterImage">포스터 이미지 첨부</label>
                                <input type="file" class="form-control-file" id="posterImage" name="posterImage" accept="image/*">
                                <small class="form-text text-muted">권장 사이즈: 500x700 픽셀 (JPG, PNG)</small>
                            </div>

                            <hr class="mt-4 mb-4">

                            <div class="d-flex justify-content-end">
                                <a href="/admin/concerts" class="btn btn-secondary mr-2">목록으로 취소</a>
                                <button type="submit" class="btn btn-primary">공연 등록하기</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>

        {{> admin/layout/footer}}

    </div>
</div>
</body>
</html>