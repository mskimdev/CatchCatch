{{> admin/layout/header}}

<script src="/js/core/api.js"></script>

<body id="page-top">
<div id="wrapper">
    {{> admin/layout/sidebar}}

    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            {{> admin/layout/topbar}}

            <div class="container-fluid">

                <h1 class="h3 mb-4 text-gray-800">새 공연 등록</h1>

                <form id="concertForm" action="/admin/concerts/create" method="POST" enctype="multipart/form-data">

                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">공연 기본 정보 입력</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 form-group">
                                    <label>공연 제목</label>
                                    <input type="text" name="title" class="form-control" value="[테스트] 2026 싸이 흠뻑쇼 - 서울"
                                           required>
                                </div>
                                <div class="col-md-6 form-group">
                                    <label>아티스트</label>
                                    <input type="text" name="artist" class="form-control" value="싸이 (PSY)" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 form-group">
                                    <label>공연장 선택</label>
                                    <select name="venueId" class="form-control">
                                        {{#venueList}}
                                            <option value="{{id}}">{{name}}</option>
                                        {{/venueList}}
                                        {{^venueList}}
                                            <option value="1">올림픽공원 체조경기장 (기본값)</option>
                                            <option value="2">KSPO DOME</option>
                                        {{/venueList}}
                                    </select>
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>카테고리</label>
                                    <select name="category" class="form-control">
                                        <option value="콘서트" selected>콘서트</option>
                                        <option value="뮤지컬">뮤지컬</option>
                                        <option value="팬미팅">팬미팅</option>
                                        <option value="페스티벌">페스티벌</option>
                                    </select>
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>장르 (검색용)</label>
                                    <input type="text" name="genre" class="form-control" value="concert" required>
                                </div>
                            </div>

                            <!-- 💡 새로 추가된 티켓 가격 설정 영역 -->
                            <hr class="mt-4 mb-4">
                            <h6 class="font-weight-bold text-primary mb-3">티켓 가격 설정</h6>
                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>VIP석 가격</label>
                                    <input type="number" name="priceVip" class="form-control" value="165000" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>R석 가격</label>
                                    <input type="number" name="priceR" class="form-control" value="143000" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>S석 가격</label>
                                    <input type="number" name="priceS" class="form-control" value="121000" min="0" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>A석 가격</label>
                                    <input type="number" name="priceA" class="form-control" value="99000" min="0" required>
                                </div>
                            </div>

                            <hr class="mt-4 mb-4">
                            <h6 class="font-weight-bold text-primary mb-3">상세 일정 및 운영 정보</h6>

                            <div class="row">
                                <div class="col-md-4 form-group">
                                    <label>티켓 오픈일</label>
                                    <input type="datetime-local" name="ticketOpenDate" class="form-control" required>
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>공연 시작일</label>
                                    <input type="date" name="startDate" class="form-control" required>
                                </div>
                                <div class="col-md-4 form-group">
                                    <label>공연 종료일</label>
                                    <input type="date" name="endDate" class="form-control" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-3 form-group">
                                    <label>관람 시간</label>
                                    <input type="text" name="runtime" class="form-control" value="150분" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>관람 등급</label>
                                    <input type="text" name="ageLimit" class="form-control" value="만 7세 이상 관람가" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>주최/주관</label>
                                    <input type="text" name="organizer" class="form-control" value="피네이션" required>
                                </div>
                                <div class="col-md-3 form-group">
                                    <label>고객센터 연락처</label>
                                    <input type="text" name="contact" class="form-control" value="1544-1111" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">상세 설명 및 포스터</h6>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label>메인 상세 타이틀</label>
                                <input type="text" name="detailTitle" class="form-control" value="기록적인 폭염을 날려버릴 짜릿한 워터쇼"
                                       required>
                            </div>
                            <div class="form-group">
                                <label>상세 설명 1</label>
                                <textarea name="detailDescription1" class="form-control" rows="3"
                                          required>더 강력해진 물대포와 역대급 스케일의 무대</textarea>
                            </div>
                            <div class="form-group">
                                <label>상세 설명 2</label>
                                <textarea name="detailDescription2" class="form-control" rows="3"
                                          required>드레스코드는 블루! 흠뻑 젖을 준비 완료?</textarea>
                            </div>

                            <div class="form-group mt-4">
                                <label>메인 포스터 이미지 업로드 (최대 10MB)</label>
                                <div class="custom-file">
                                    <input type="file" name="posterFile" class="custom-file-input" id="customFile"
                                           accept="image/*" required>
                                    <label class="custom-file-label" for="customFile">이미지 파일을 선택하세요</label>
                                </div>
                                <small class="text-muted mt-2 d-block">가로 400px, 세로 600px 비율의 이미지를 권장합니다.</small>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mb-5">
                        <button type="button" class="btn btn-secondary mr-2" onclick="history.back()">취소</button>
                        <button type="submit" class="btn btn-primary px-5">공연 등록하기</button>
                    </div>

                </form>

                <script>
                    document.getElementById('customFile').addEventListener('change', function (e) {
                        var fileName = document.getElementById("customFile").files[0].name;
                        var nextSibling = e.target.nextElementSibling;
                        if (nextSibling) {
                            nextSibling.innerText = fileName;
                        }
                    });

                    const form = document.getElementById("concertForm");

                    if (form) {
                        form.addEventListener("submit", function(e) {
                            e.preventDefault();
                            CcUI.confirm({
                                title: '새 공연 등록',
                                text: '입력하신 정보로 새 공연을 등록하시겠습니까?',
                                confirmText: '등록하기',
                                onConfirm: function() {
                                    CcUI.loading.show();
                                    HTMLFormElement.prototype.submit.call(form);
                                }
                            });
                        });
                    }
                </script>

            </div>
        </div>

        {{> admin/layout/footer}}

    </div>
</div>
</body>