<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SeatTrace - 04 좌석 배치</title>

    <link rel="stylesheet" href="/css/admin/seatmap-header.css">
    <link rel="stylesheet" href="/css/admin/seatmap-workspace.css">
    <link rel="stylesheet" href="/css/admin/seatmap-stage4.css">
</head>

<body class="seatmap-page seatmap-page--stage4">
{{> admin/seatmap/common/header}}
{{> admin/seatmap/common/work-toolbar}}

<div class="seatmap-workspace seatmap-workspace--stage4"
     id="stage4App"
     data-project-id="{{projectId}}"
     data-project-path="{{projectPath}}"
     data-stage3-url="{{stage3Url}}"
     data-stage5-url="{{stage5Url}}"
     data-prev-stage-url="{{stage3Url}}"
     data-next-stage-url="{{stage5Url}}"
     data-seatmap-image-url="{{seatmapImageUrl}}"
     data-button-image-url="{{buttonImageUrl}}"
     data-section-json-url="{{sectionJsonUrl}}"
     data-sections-url="{{sectionJsonUrl}}"
     data-seats-url="{{seatJsonUrl}}"
     data-decorations-url="{{decorationJsonUrl}}"
     data-final-image-url="{{finalImageUrl}}"
     data-cropped-image-url="{{croppedImageUrl}}"
     data-save-url="/admin/seatmap/temp-save">

    {{> admin/seatmap/workspace/workspace-stage4}}

</div>

<div class="toast" id="toast"></div>

<script defer src="/js/admin/seatmap-header.js"></script>
<script defer src="/js/admin/seatmap-workspace.js"></script>
<script defer src="/js/admin/seatmap-stage4.js"></script>
</body>
</html>
