<!DOCTYPE html><html lang="ko"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Small Seat Builder</title><style>
    :root{--nav:#0f172a;--panel:#fff;--line:#e5e7eb;--muted:#64748b;--ink:#111827;--bg:#f4f6fa;--violet:#7c3aed;--blue:#2563eb;--green:#10b981;--red:#ef4444;--amber:#f59e0b;--shadow:0 16px 42px rgba(15,23,42,.12)}
    *{box-sizing:border-box}html,body{height:100%}body{margin:0;font-family:Pretendard,'Noto Sans KR',Arial,sans-serif;background:var(--bg);color:var(--ink);overflow:hidden}button,input,select{font:inherit}button{cursor:pointer}button:disabled{opacity:.45;cursor:not-allowed}.hidden{display:none!important}
    .top{height:58px;background:var(--nav);color:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 18px;border-bottom:1px solid #2d374b}.brand{display:flex;align-items:center;gap:10px;font-weight:950}.logo{width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,var(--violet),var(--blue));display:grid;place-items:center}.brand small{color:#a8b4cb;margin-left:6px}.top-actions{display:flex;gap:8px;align-items:center}.top-btn{height:34px;border:1px solid #334155;border-radius:9px;background:#172033;color:#e2e8f0;font-size:12px;font-weight:850;padding:0 12px;text-decoration:none;display:inline-flex;align-items:center}.top-btn.main{border:0;background:linear-gradient(135deg,var(--violet),var(--blue));color:#fff}.wrap{height:calc(100vh - 58px);overflow:auto}.center{min-height:100%;display:grid;place-items:center;padding:28px}.card{background:#fff;border:1px solid var(--line);border-radius:22px;box-shadow:var(--shadow);padding:26px}.btn{width:100%;height:40px;border:1px solid var(--line);border-radius:11px;background:#fff;color:#334155;font-size:12px;font-weight:900}.btn.primary{border:0;background:linear-gradient(135deg,var(--violet),var(--blue));color:#fff}.btn.dark{border:0;background:#111827;color:#fff}.btn.green{border:0;background:var(--green);color:#fff}.btn.red{border:0;background:var(--red);color:#fff}.btn.amber{border:0;background:var(--amber);color:#fff}.btn+ .btn{margin-top:8px}.note,.help{margin-top:10px;border-radius:12px;background:#f1f5f9;padding:11px;color:#64748b;font-size:12px;line-height:1.55}.work{height:calc(100vh - 58px);display:grid;grid-template-columns:360px 1fr;min-height:0}.side{background:#fff;border-right:1px solid var(--line);overflow:auto;padding:15px}.side-title{font-size:11px;font-weight:950;letter-spacing:.08em;color:#738099;margin:0 0 12px}.box{border:1px solid var(--line);border-radius:16px;background:#fff;padding:13px;margin-bottom:12px}.box.active{border-color:#a78bfa;box-shadow:0 0 0 3px rgba(124,58,237,.08)}.box h3{font-size:14px;margin:0 0 10px}.row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}.row.three{grid-template-columns:1fr 1fr 1fr}label{display:block;font-size:10px;color:#64748b;font-weight:900;margin:0 0 5px}input,select{width:100%;height:34px;border:1px solid var(--line);border-radius:9px;background:#f8fafc;padding:0 9px;outline:0}input:focus,select:focus{border-color:#8b5cf6;background:#fff}input[type=range]{height:20px;border:0;padding:0;background:transparent}.main{overflow:auto;background:#fff;background-image:radial-gradient(#dbe3ef .8px,transparent .8px);background-size:18px 18px}.canvas-wrap{width:max-content;min-width:860px;min-height:560px;margin:28px auto 90px}.canvas-head{height:36px;display:flex;align-items:center;justify-content:space-between;background:#fff;border:1px solid var(--line);border-bottom:0;border-radius:16px 16px 0 0;padding:0 14px;color:#64748b;font-size:11px;font-weight:900}.canvas-box{position:relative;background:#fff;border:1px solid var(--line);box-shadow:var(--shadow);overflow:hidden}canvas{position:absolute;left:0;top:0}canvas.base{position:relative;display:block}.list{display:grid;gap:7px;max-height:240px;overflow:auto}.item{display:flex;align-items:center;gap:8px;border:1px solid var(--line);border-radius:10px;padding:8px;background:#fff;font-size:11px;cursor:pointer}.item.active{border-color:#8b5cf6;background:#f5f3ff}.dot{width:12px;height:12px;border-radius:3px;background:#8b5cf6}.item strong{display:block;font-size:12px}.item span{display:block;color:#64748b;font-size:10px;margin-top:2px}.sample{display:flex;align-items:center;justify-content:space-between;border:1px solid var(--line);border-radius:10px;background:#f8fafc;padding:7px;font-size:10px;color:#475569;margin-top:6px}.sample i{width:18px;height:18px;border-radius:5px;border:1px solid #cbd5e1;margin-right:6px}.sample span{display:flex;align-items:center}.sample button{border:0;background:transparent;color:#ef4444;font-weight:900}.tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}.tab{height:36px;border:1px solid var(--line);border-radius:10px;background:#fff;color:#475569;font-size:12px;font-weight:900}.tab.active{border-color:#8b5cf6;background:#f5f3ff;color:#6d28d9}.metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.metric{border:1px solid var(--line);border-radius:12px;background:#f8fafc;padding:10px;color:#64748b;font-size:11px}.metric b{display:block;font-size:20px;color:#111827;margin-top:3px}.json-box{max-height:190px;overflow:auto;background:#0f172a;color:#dbeafe;border-radius:10px;padding:10px;font-size:10px;line-height:1.45}.toast{position:fixed;right:22px;bottom:22px;background:#111827;color:#fff;padding:12px 15px;border-radius:12px;font-size:12px;opacity:0;transform:translateY(6px);transition:.16s;z-index:100}.toast.show{opacity:1;transform:none}
</style></head><body>
<header class="top"><div class="brand"><span class="logo">▦</span>Small Theater <small>기존 소극장 좌석 이미지 방식</small></div><div class="top-actions"><a class="top-btn" href="main.html">메인</a><button class="top-btn main" id="download">JSON 저장</button></div></header>
<div class="work"><aside class="side"><p class="side-title">소극장 · 좌석 직접 분석</p><div class="box active"><h3>1) 이미지 등록</h3><input class="hidden" type="file" id="file" accept="image/*"><button class="btn primary" id="upload">소극장 좌석 이미지 업로드</button><div class="help">좌석 하나하나가 보이는 이미지를 사용합니다.</div></div><div class="box"><h3>2) 스포이드 색상 분석</h3><button class="btn dark" id="pick">스포이드 모드</button><div id="samples"></div><div class="row"><div><label>유사 색상 범위</label><input type="range" id="tol" min="5" max="100" value="35"></div><div><label>최소 좌석 면적</label><input type="number" id="minArea" value="30"></div></div><button class="btn green" id="analyze">좌석 후보 분석</button></div><div class="box"><h3>3) 좌석 보정</h3><div class="row"><button class="btn" id="manualSeat">수동 좌석 추가</button><button class="btn red" id="deleteSel">선택 삭제</button></div><div class="row"><div><label>층</label><input id="floor" value="1층"></div><div><label>구역</label><input id="section" value="가"></div></div><div class="row"><div><label>등급</label><input id="grade" value="R석"></div><div><label>가격</label><input id="price" value="132000"></div></div><div class="help">기존 소극장 방식 유지: 스포이드로 좌석 색을 찍고 후보를 만든 뒤 삭제/추가/이동으로 보정합니다.</div></div><div class="box"><h3>결과</h3><div class="metric-grid"><div class="metric">좌석<b id="seatCount">0</b></div><div class="metric">선택<b id="selCount">0</b></div></div><pre class="json-box" id="json">{}</pre></div></aside><main class="main"><div class="canvas-wrap"><div class="canvas-head"><span>소극장 좌석 분석 도면</span><span id="size">-</span></div><div class="canvas-box" id="box"><canvas class="base" id="canvas"></canvas><canvas id="overlay"></canvas></div></div></main></div><div class="toast" id="toast"></div><script>
    const $=id=>document.getElementById(id),c=$('canvas'),o=$('overlay'),ctx=c.getContext('2d',{willReadFrequently:true}),ox=o.getContext('2d');let imgUrl=localStorage.getItem('small_originalImage'),W=0,H=0,samples=[],seats=JSON.parse(localStorage.getItem('small_seats')||'[]'),selected=new Set(),pick=false,manual=false,drag=null,nextSeat=seats.length+1;
    function toast(m){const t=$('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000)}function rgb(h){return{r:parseInt(h.slice(1,3),16),g:parseInt(h.slice(3,5),16),b:parseInt(h.slice(5,7),16)}}function hex(c){return '#'+[c.r,c.g,c.b].map(v=>v.toString(16).padStart(2,'0')).join('')}function dist(a,b){return Math.hypot(a.r-b.r,a.g-b.g,a.b-b.b)}function pos(e){const r=o.getBoundingClientRect();return{x:(e.clientX-r.left)*o.width/r.width,y:(e.clientY-r.top)*o.height/r.height}}function load(url){const im=new Image();im.onload=()=>{W=im.naturalWidth;H=im.naturalHeight;c.width=o.width=W;c.height=o.height=H;const s=Math.min(1,1120/W,720/H);c.style.width=o.style.width=(W*s)+'px';c.style.height=o.style.height=(H*s)+'px';$('box').style.width=(W*s)+'px';$('box').style.height=(H*s)+'px';$('size').textContent=W+' × '+H;ctx.drawImage(im,0,0,W,H);draw()};im.src=url}function renderSamples(){if(!samples.length){$('samples').innerHTML='<div class="help">스포이드로 좌석 색상을 찍으세요.</div>';return}$('samples').innerHTML=samples.map((s,i)=>`<div class="sample"><span><i style="background:${hex(s)}"></i>${hex(s).toUpperCase()}</span><button data-i="${i}">×</button></div>`).join('');document.querySelectorAll('#samples button').forEach(b=>b.onclick=()=>{samples.splice(+b.dataset.i,1);renderSamples()})}
    function analyze(){if(!imgUrl||!samples.length){toast('이미지와 색상을 먼저 선택하세요');return}const data=ctx.getImageData(0,0,W,H).data,mask=new Uint8Array(W*H),seen=new Uint8Array(W*H),tol=+$('tol').value||35,min=+$('minArea').value||30;for(let i=0;i<W*H;i++){const k=i*4,c={r:data[k],g:data[k+1],b:data[k+2]};if(samples.some(s=>dist(c,s)<=tol))mask[i]=1}const found=[];for(let y=0;y<H;y++)for(let x=0;x<W;x++){const st=y*W+x;if(!mask[st]||seen[st])continue;const q=[st];let head=0,minX=x,maxX=x,minY=y,maxY=y,count=0;seen[st]=1;while(head<q.length){const n=q[head++],nx=n%W,ny=(n/W)|0;count++;minX=Math.min(minX,nx);maxX=Math.max(maxX,nx);minY=Math.min(minY,ny);maxY=Math.max(maxY,ny);[[1,0],[-1,0],[0,1],[0,-1]].forEach(([dx,dy])=>{const xx=nx+dx,yy=ny+dy;if(xx<0||yy<0||xx>=W||yy>=H)return;const ni=yy*W+xx;if(mask[ni]&&!seen[ni]){seen[ni]=1;q.push(ni)}})}if(count>=min){const w=maxX-minX+1,h=maxY-minY+1;if(w>4&&h>4&&w<80&&h<80)found.push({x:minX,y:minY,w,h})}}seats=found.map((r,i)=>({id:'small-seat'+(++nextSeat),floor:$('floor').value,section:$('section').value,rowNo:'',colNo:i+1,grade:$('grade').value,price:+$('price').value||0,x:r.x,y:r.y,w:r.w,h:r.h,deleted:false,status:'AVAILABLE'}));save();draw();toast('좌석 후보 '+seats.length+'개 생성')}
    function draw(){ox.clearRect(0,0,W,H);seats.forEach(s=>{if(s.deleted)return;ox.fillStyle=selected.has(s.id)?'rgba(124,58,237,.35)':'rgba(16,185,129,.22)';ox.strokeStyle=selected.has(s.id)?'#7c3aed':'#10b981';ox.lineWidth=2;ox.fillRect(s.x,s.y,s.w,s.h);ox.strokeRect(s.x,s.y,s.w,s.h)});if(drag&&drag.type==='box'){const r=drag.rect;ox.fillStyle='rgba(124,58,237,.08)';ox.strokeStyle='#7c3aed';ox.fillRect(r.x,r.y,r.w,r.h);ox.strokeRect(r.x,r.y,r.w,r.h)}$('seatCount').textContent=seats.filter(s=>!s.deleted).length;$('selCount').textContent=selected.size;updateJson()}function hit(p){return [...seats].reverse().find(s=>!s.deleted&&p.x>=s.x&&p.x<=s.x+s.w&&p.y>=s.y&&p.y<=s.y+s.h)}function save(){localStorage.setItem('small_seats',JSON.stringify(seats))}function updateJson(){const data={type:'SMALL_THEATER',background:{image:'small_originalImage',width:W,height:H},seats:seats.filter(s=>!s.deleted)};$('json').textContent=JSON.stringify(data,null,2).slice(0,4500);return data}
    $('upload').onclick=()=>$('file').click();$('file').onchange=e=>{const f=e.target.files[0];if(!f)return;const im=new Image();im.onload=()=>{imgUrl=im.src;localStorage.setItem('small_originalImage',imgUrl);seats=[];selected.clear();load(imgUrl)};im.src=URL.createObjectURL(f)};$('pick').onclick=()=>{pick=true;toast('이미지에서 좌석 색상을 클릭하세요')};$('analyze').onclick=analyze;$('manualSeat').onclick=()=>{manual=true;toast('좌석 범위를 드래그하세요')};o.onpointerdown=e=>{const p=pos(e);if(pick){const d=ctx.getImageData(Math.floor(p.x),Math.floor(p.y),1,1).data;samples.push({r:d[0],g:d[1],b:d[2]});renderSamples();pick=false;return}const s=hit(p);if(s){selected.has(s.id)?selected.delete(s.id):selected.add(s.id);draw();return}if(manual){drag={type:'box',start:p,rect:{x:p.x,y:p.y,w:0,h:0}};manual=false}};window.onpointermove=e=>{if(drag){const p=pos(e);drag.rect={x:Math.min(drag.start.x,p.x),y:Math.min(drag.start.y,p.y),w:Math.abs(p.x-drag.start.x),h:Math.abs(p.y-drag.start.y)};draw()}};window.onpointerup=()=>{if(drag){const r=drag.rect;if(r.w>4&&r.h>4)seats.push({id:'small-seat'+(++nextSeat),floor:$('floor').value,section:$('section').value,rowNo:'',colNo:seats.length+1,grade:$('grade').value,price:+$('price').value||0,x:r.x,y:r.y,w:r.w,h:r.h,deleted:false,status:'AVAILABLE'});drag=null;save();draw()}};$('deleteSel').onclick=()=>{seats.forEach(s=>{if(selected.has(s.id))s.deleted=true});selected.clear();save();draw()};$('download').onclick=()=>{const data=updateJson();const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'}));a.download='small-final-layout.json';a.click()};if(imgUrl)load(imgUrl);renderSamples();draw();
</script></body></html>