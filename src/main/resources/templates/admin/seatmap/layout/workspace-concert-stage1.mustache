<!-- Stage1 Part2 / Part3 교체용 조각 -->
<!-- 기존 Part2(이미지 확대/색상 단순화)와 기존 Part3(색상 선택 추출) 섹션을 이 구조로 교체하세요. -->

<section id="part2" class="seatmap-step" data-step="2">
    <button type="button" class="seatmap-step__header" id="tab2">
        <span class="seatmap-step__check" data-step="2"></span>
        <span class="seatmap-step__text">
            <b>파트 2</b>
            <small>제거 색상 선택</small>
        </span>
        <span class="seatmap-step__status">대기</span>
        <span class="seatmap-step__arrow">⌄</span>
    </button>

    <div class="seatmap-step__body">
        <div class="seatmap-step__system">
            <div class="box active">
                <h3>제거할 색상 선택</h3>
                <p class="help">
                    이미지 위에서 흰색, 검은색, 회색, 글자, 무대처럼 필요 없는 색상을 클릭하세요.
                    선택한 색상은 배경색으로 제거되고, 남은 영역은 도형색으로 정리됩니다.
                </p>

                <div class="form-grid">
                    <label>
                        제거 허용 오차
                        <input type="range" id="tol" min="0" max="120" value="45">
                    </label>
                    <label>
                        배경색
                        <input type="color" id="backgroundColor" value="#f7f7f7">
                    </label>
                    <label>
                        도형색
                        <input type="color" id="shapeColor" value="#000000">
                    </label>
                    <label>
                        빈 구멍 메우기
                        <input type="range" id="hole" min="0" max="2000" value="0">
                        <span id="holeValue">0</span>
                    </label>
                </div>

                <div id="samples" class="samples"></div>

                <div class="button-row">
                    <button type="button" class="btn" id="clearRemoveSamples">제거 색상 비우기</button>
                    <button type="button" class="btn btn--purple" id="go3">다음 · 결과 확인</button>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="part3" class="seatmap-step" data-step="3">
    <button type="button" class="seatmap-step__header" id="tab3">
        <span class="seatmap-step__check" data-step="3"></span>
        <span class="seatmap-step__text">
            <b>파트 3</b>
            <small>제거 결과 확인</small>
        </span>
        <span class="seatmap-step__status">대기</span>
        <span class="seatmap-step__arrow">⌄</span>
    </button>

    <div class="seatmap-step__body">
        <div class="seatmap-step__system">
            <div class="box active">
                <h3>결과 확인</h3>
                <p class="help">배경색과 도형색이 정확히 분리됐는지 확인하세요.</p>

                <label>
                    보기 방식
                    <select id="viewMode">
                        <option value="clean">추출 결과만 보기</option>
                        <option value="mix">원본 + 추출 미리보기</option>
                    </select>
                </label>

                <input type="hidden" id="alpha" value="100">

                <div class="button-row">
                    <button type="button" class="btn" id="restoreOriginal">원본 복구</button>
                    <button type="button" class="btn" id="invertExtract">결과 반전</button>
                    <button type="button" class="btn btn--purple" id="go4">다음 · 다듬기</button>
                </div>
            </div>
        </div>
    </div>
</section>
