<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SeatTrace - 05 예매 버튼 생성</title>

    <link rel="stylesheet" href="/css/admin/seatmap-header.css">
    <link rel="stylesheet" href="/css/admin/seatmap-workspace.css">
    <link rel="stylesheet" href="/css/admin/seatmap-stage5.css">
</head>

<body class="seatmap-page seatmap-page--stage5">
{{> admin/seatmap/common/header}}
{{> admin/seatmap/common/work-toolbar}}

<div class="seatmap-workspace seatmap-workspace--stage5"
     id="stage5App"
     data-project-id="{{projectId}}"
     data-stage4-url="{{stage4Url}}"
     data-stage6-url="{{stage6Url}}"
     data-prev-stage-url="{{stage4Url}}"
     data-next-stage-url="{{stage6Url}}"
     data-seatmap-image-url="{{seatmapImageUrl}}"
     data-button-image-url="{{buttonImageUrl}}"
     data-final-image-url="{{finalImageUrl}}"
     data-stage5-image-url="{{stage5ImageUrl}}"
     data-debug-image-url="{{debugImageUrl}}"
     data-cropped-image-url="{{croppedImageUrl}}"
     data-sections-url="{{sectionJsonUrl}}"
     data-seats-url="{{seatJsonUrl}}"
     data-decorations-url="{{decorationJsonUrl}}"
     data-booking-buttons-url="{{bookingButtonsJsonUrl}}"
     data-save-url="/admin/seatmap/temp-save">

    {{> admin/seatmap/workspace/workspace-stage5}}

</div>

<div class="toast" id="toast"></div>

<script defer src="/js/admin/seatmap-header.js"></script>
<script defer src="/js/admin/seatmap-workspace.js"></script>
<script defer src="/js/admin/seatmap-stage5.js"></script>
</body>
</html>
