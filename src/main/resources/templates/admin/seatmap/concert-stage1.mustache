{{> admin/seatmap/layout/header}}

<link href="/css/admin/seatmap-workspace.css" rel="stylesheet">
<link href="/css/admin/seatmap-concert-stage1.css" rel="stylesheet">

<body>
<div class="seatmap-workspace seatmap-workspace--stage1">

    {{> admin/seatmap/layout/workspace-concert-stage1}}

    <!-- 가운데: 메인 캔버스 + 공용 작업 도구 -->
    <main class="seatmap-main">

        <div class="seatmap-command-bar" aria-label="공용 작업 명령">
            <button type="button" class="seatmap-command-btn" id="undoAction" title="이전 작업 Ctrl+Z">
                ↶ 이전
            </button>

            <button type="button" class="seatmap-command-btn" id="redoAction" title="다음 작업 Ctrl+Y">
                ↷ 다음
            </button>

            <button type="button" class="seatmap-command-btn" id="zoomTool" title="오른쪽 드래그 확대 / 왼쪽 드래그 축소">
                🔍 확대
            </button>

            <button type="button" class="seatmap-command-btn" id="zoomReset" title="확대 초기화">
                100%
            </button>

            <span class="seatmap-zoom-value" id="zoomValue">100%</span>
        </div>

        <div class="canvas-wrap">
            <div class="canvas-head">
                <span id="title">원본 / 자르기</span>
                <span id="size">-</span>
            </div>

            <div class="canvas-box" id="box">
                <canvas class="base" id="canvas"></canvas>
                <canvas id="overlay"></canvas>
                <div id="eraserCursor" class="eraser-cursor"></div>

                <!-- Part2 색상 선택 확대경 -->
                <div class="color-loupe" id="colorLoupe" aria-hidden="true">
                    <div class="color-loupe__lens">
                        <canvas id="loupeCanvas" width="132" height="132"></canvas>
                    </div>

                    <div class="color-loupe__info">
                        <div class="color-loupe__top">
                            <span class="color-loupe__chip" id="loupeChip"></span>
                            <strong id="loupeHex">#------</strong>
                        </div>
                        <div id="loupeRgb">RGB -</div>
                        <div id="loupePoint">X -, Y -</div>
                    </div>
                </div>
            </div>
        </div>

    </main>

</div>

<div class="toast" id="toast"></div>

<script src="/js/admin/seatmap-workspace.js" defer></script>
<script src="/js/admin/seatmap-concert-stage1.js"></script>
</body>
</html>
