<aside class="seatmap-side seatmap-side--left stage6-tool-side">
    <div class="stage6-side-title">
        <span class="stage6-step-badge">STEP 06</span>
        <strong>최종 꾸미기</strong>
        <small>Stage 5 이미지를 꾸미기만 합니다. 클릭 영역은 booking-buttons.json 그대로 유지됩니다.</small>
    </div>

    <section class="stage6-panel stage6-panel--tools">
        <h3>도구</h3>
        <div class="stage6-tool-grid" id="stage6ToolGrid">
            <button type="button" class="stage6-tool is-active" data-tool="select" title="선택 / 이동">
                <span>↕</span><b>선택</b>
            </button>
            <button type="button" class="stage6-tool" data-tool="text" title="텍스트 추가">
                <span>T</span><b>텍스트</b>
            </button>
            <button type="button" class="stage6-tool" data-tool="rect" title="사각형 추가">
                <span>▭</span><b>사각형</b>
            </button>
            <button type="button" class="stage6-tool" data-tool="ellipse" title="원형 추가">
                <span>◯</span><b>원형</b>
            </button>
            <button type="button" class="stage6-tool" data-tool="line" title="선 추가">
                <span>╱</span><b>선</b>
            </button>
            <button type="button" class="stage6-tool" data-tool="arrow" title="화살표 추가">
                <span>➜</span><b>화살표</b>
            </button>
            <button type="button" class="stage6-tool" data-tool="erase" title="선택 요소 삭제">
                <span>⌫</span><b>삭제</b>
            </button>
        </div>
    </section>

    <details class="stage6-panel stage6-fold" open>
        <summary>빠른 추가</summary>
        <div class="stage6-action-grid">
            <button type="button" class="stage6-quick" id="addStageLabel">STAGE</button>
            <button type="button" class="stage6-quick" id="addEntranceLabel">입구</button>
            <button type="button" class="stage6-quick" id="addGuideBox">안내 박스</button>
            <button type="button" class="stage6-quick" id="importButtonLabels">버튼명 라벨</button>
        </div>
    </details>

    <details class="stage6-panel stage6-fold" open>
        <summary>배경 / 효과</summary>
        <div class="stage6-field-grid">
            <label><span>배경</span>
                <select id="backgroundType">
                    <option value="none">기본</option>
                    <option value="solid">단색</option>
                    <option value="gradient">그라데이션</option>
                </select>
            </label>
            <label><span>색상 1</span><input type="color" id="backgroundColor" value="#ffffff"></label>
            <label><span>색상 2</span><input type="color" id="backgroundColor2" value="#f1f5f9"></label>
        </div>
        <label class="stage6-check-row"><input type="checkbox" id="toggleCanvasBorder"><span>외곽 테두리</span></label>
        <label class="stage6-check-row"><input type="checkbox" id="toggleSoftShadow"><span>은은한 그림자</span></label>
        <button type="button" class="stage6-quick stage6-quick--full" id="applyBackground">적용</button>
    </details>

    <details class="stage6-panel stage6-fold">
        <summary>정렬</summary>
        <div class="stage6-align-grid">
            <button type="button" id="alignLeft">좌</button>
            <button type="button" id="alignCenterX">가운데</button>
            <button type="button" id="alignRight">우</button>
            <button type="button" id="alignTop">상</button>
            <button type="button" id="alignCenterY">중앙</button>
            <button type="button" id="alignBottom">하</button>
        </div>
    </details>

    <details class="stage6-panel stage6-fold">
        <summary>확인</summary>
        <label class="stage6-check-row"><input type="checkbox" id="showBookingDebug"><span>booking polygon 보기</span></label>
        <label class="stage6-check-row"><input type="checkbox" id="showDebugImage"><span>debug 확인 모드</span></label>
        <button type="button" class="stage6-quick stage6-quick--full stage6-quick--danger" id="clearDecorations">꾸미기 초기화</button>
    </details>
</aside>

<main class="seatmap-main stage6-canvas-main">
    <div class="stage6-canvas-head">
        <div>
            <strong>최종 도면 캔버스</strong>
            <span id="stage6CanvasInfo">seatmap-stage5.png를 불러오는 중...</span>
        </div>
        <div class="stage6-canvas-head__tools">
            <button type="button" id="resetCanvasView">100%</button>
            <button type="button" id="fitCanvasViewInline">화면 맞춤</button>
        </div>
    </div>

    <div class="stage6-canvas-viewport" id="stage6CanvasViewport">
        <div class="stage6-canvas-board" id="stage6CanvasBoard">
            <canvas id="canvas"></canvas>
        </div>
    </div>
</main>

<aside class="seatmap-side seatmap-side--right stage6-right-side">
    <section class="stage6-panel">
        <div class="stage6-panel-head">
            <h3>선택 요소</h3>
            <button type="button" class="stage6-inline-btn" id="clearSelection">해제</button>
        </div>
        <div class="stage6-selected-box" id="selectedObjectInfo">
            선택된 레이어가 없습니다.
        </div>
    </section>

    <section class="stage6-panel">
        <div class="stage6-panel-head">
            <h3>레이어</h3>
            <button type="button" class="stage6-inline-btn" id="deleteSelectedLayer">삭제</button>
        </div>
        <div class="stage6-layer-list" id="layerList">
            <div class="stage6-empty-layer">추가된 꾸미기 레이어가 없습니다.</div>
        </div>
    </section>

    <section class="stage6-panel stage6-panel--mini">
        <h3>미니맵</h3>
        <div class="stage6-minimap-wrap">
            <canvas id="stage6MiniMap" width="260" height="160"></canvas>
        </div>
        <p class="stage6-help">저장 시 seatmap-final.png와 seatmap-style.json만 생성합니다. booking-buttons.json은 수정하지 않습니다.</p>
    </section>
</aside>
