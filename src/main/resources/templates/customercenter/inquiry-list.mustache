{{> layout/header}}

<link rel="stylesheet" href="/css/customercenter-faq.css">
<link rel="stylesheet" href="/css/customercenter-inquiry.css">

<div class="cc-container cc-main">

    <h1 class="cc-customer__title">고객센터</h1>

    <div class="cc-customer">

        <aside class="cc-side-menu">
            <a href="/customercenter/faqs" class="cc-side-menu__item">FAQ</a>
            <a href="/customercenter/inquiries/save" class="cc-side-menu__item">1:1 문의하기</a>
            <a href="/customercenter/inquiries" class="cc-side-menu__item is-active">1:1 문의 내역</a>
            <a href="/customercenter/notices" class="cc-side-menu__item">공지사항</a>
        </aside>

        <main class="cc-inquiry-content">

            <div class="cc-content-header">
                <h2>1:1 문의 내역</h2>
                <a class="cc-btn cc-btn--primary" href="/customercenter/inquiries/save">문의하기</a>
            </div>

            <table class="cc-inquiry-table">
                <thead>
                <tr>
                    <th style="width:100px">유형</th>
                    <th>제목</th>
                    <th style="width:110px">상태</th>
                    <th style="width:150px">등록일</th>
                </tr>
                </thead>
                <tbody>
                {{#inquiries}}
                <tr class="cc-inquiry-row{{^isPublic}} cc-inquiry-row--private{{/isPublic}}"
                    {{#isPublic}}onclick="location.href='/customercenter/inquiries/{{id}}'"{{/isPublic}}>
                    <td><span class="cc-inquiry-category">{{categoryLabel}}</span></td>
                    <td class="cc-inquiry-title">
                        {{^isPublic}}<svg class="cc-inquiry-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>{{/isPublic}}
                        {{title}}
                        {{^isPublic}}<span class="cc-inquiry-private-badge">비공개</span>{{/isPublic}}
                    </td>
                    <td>
                        <span class="cc-inquiry-status {{statusClass}}">{{statusLabel}}</span>
                    </td>
                    <td class="cc-inquiry-date">{{createdAt}}</td>
                </tr>
                {{/inquiries}}
                {{^inquiries}}
                <tr>
                    <td colspan="4" class="cc-empty-message">문의 내역이 없습니다.</td>
                </tr>
                {{/inquiries}}
                </tbody>
            </table>

        </main>

    </div>
</div>

{{> layout/footer}}