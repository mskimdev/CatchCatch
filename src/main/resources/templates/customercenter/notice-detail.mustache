{{> layout/header}}

<link rel="stylesheet" href="/css/customercenter-faq.css">
<link rel="stylesheet" href="/css/customercenter-notice.css">

<div class="customer-center-container">

    <h1 class="page-title">고객센터</h1>

    <div class="customer-layout">

        <aside class="side-menu">
            <a href="/customercenter/faqs" class="side-menu-item">FAQ</a>
            <a href="/customercenter/inquiries/save" class="side-menu-item">1:1 문의하기</a>
            <a href="/customercenter/inquiries" class="side-menu-item">1:1 문의 내역</a>
            <a href="/customercenter/notices" class="side-menu-item active">공지사항</a>
        </aside>

        <main class="notice-content">

            <div class="content-header">
                <h2>공지사항</h2>
                <a class="notice-back-btn" href="/customercenter/notices">목록으로</a>
            </div>

            {{#notice}}
            <div class="notice-detail">
                <div class="notice-detail__header">
                    {{#isPinned}}<span class="notice-badge">공지</span>{{/isPinned}}
                    <h3 class="notice-detail__title">{{title}}</h3>
                    <div class="notice-detail__meta">
                        <span class="notice-detail__date">{{createdAt}}</span>
                        <span class="notice-detail__view">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            {{viewCount}}
                        </span>
                    </div>
                </div>
                <div class="notice-detail__body">{{content}}</div>
            </div>
            {{/notice}}

        </main>

    </div>
</div>

{{> layout/footer}}
