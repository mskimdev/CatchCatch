{{> layout/header}}

<link rel="stylesheet" href="/css/customercenter-faq.css">
<link rel="stylesheet" href="/css/customercenter-inquiry.css">

<div class="customer-center-container">

    <h1 class="page-title">고객센터</h1>

    <div class="customer-layout">

        <aside class="side-menu">
            <a href="/customercenter/faqs" class="side-menu-item">FAQ</a>
            <a href="/customercenter/inquiries/save" class="side-menu-item">1:1 문의하기</a>
            <a href="/customercenter/inquiries" class="side-menu-item active">1:1 문의 내역</a>
            <a href="/customercenter/notices" class="side-menu-item">공지사항</a>
        </aside>

        <main class="inquiry-content">

            <div class="content-header">
                <h2>문의 상세</h2>
                <a class="inquiry-btn inquiry-btn--outline" href="/customercenter/inquiries">목록으로</a>
            </div>

            {{#inquiry}}
            <div class="inquiry-detail">
                <div class="inquiry-detail__header">
                    <div class="inquiry-detail__meta">
                        <span class="inquiry-category">{{categoryLabel}}</span>
                        <span class="inquiry-status {{statusClass}}">{{statusLabel}}</span>
                    </div>
                    <h3 class="inquiry-detail__title">{{title}}</h3>
                    <div class="inquiry-detail__info">
                        <span class="inquiry-detail__author">{{username}}</span>
                        <span class="inquiry-detail__date">{{createdAt}}</span>
                    </div>
                </div>

                <div class="inquiry-detail__body">{{content}}</div>

                {{#hasReply}}
                <div class="inquiry-detail__reply">
                    <div class="inquiry-detail__reply-label">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        관리자 답변
                    </div>
                    <div class="inquiry-detail__reply-body">{{reply}}</div>
                </div>
                {{/hasReply}}
                {{^hasReply}}
                <div class="inquiry-detail__reply--pending">
                    아직 답변이 등록되지 않았습니다.
                </div>
                {{/hasReply}}
            </div>
            {{/inquiry}}

        </main>

    </div>
</div>

{{> layout/footer}}
