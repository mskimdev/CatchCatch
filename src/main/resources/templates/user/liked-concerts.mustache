{{> layout/header}}
<link rel="stylesheet" href="/css/user-mypage.css">
<main class="cc-main">
    <div class="cc-container cc-mypage-layout">

        <!-- 사이드바 -->
        {{> components/mypage-sidebar}}

        <!-- 메인 콘텐츠 -->
        <section class="cc-mypage-content">
            <div class="cc-mypage-head">
                <h2>관심 공연</h2>
            </div>

            <div class="cc-concert-grid">
                {{#concerts}}
                    <article class="cc-card cc-concert-card">
                        <a class="cc-concert-card__poster" href="/concerts/{{id}}">
                            <img src="{{posterUrl}}" alt="{{title}} 포스터">
                        </a>
                        <div class="cc-concert-card__body">
                            <span class="cc-concert-card__category">{{#genreLabel}}{{genreLabel}}{{/genreLabel}}{{^genreLabel}}콘서트{{/genreLabel}}</span>
                            <h3 class="cc-concert-card__title"><a href="/concerts/{{id}}">{{title}}</a></h3>
                            <p class="cc-concert-card__meta">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;vertical-align:-2px;margin-right:3px"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                                <span>{{artist}}</span>
                            </p>
                            <p class="cc-concert-card__meta">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;vertical-align:-2px;margin-right:3px"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                <span>{{startDate}} ~ {{endDate}}</span>
                            </p>
                            <p class="cc-concert-card__meta">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;vertical-align:-2px;margin-right:3px"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                <span>{{venue.name}}</span>
                            </p>
                        </div>
                        <button class="cc-heart is-liked" type="button" data-concert-id="{{id}}" aria-label="관심 공연 취소" aria-pressed="true">
                            <svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </article>
                {{/concerts}}
                {{^concerts}}
                    <div class="cc-empty-state" style="grid-column:1/-1">
                        <p>관심 공연이 없습니다.</p>
                        <a class="cc-btn cc-btn--primary" href="/concerts">콘서트 둘러보기</a>
                    </div>
                {{/concerts}}
            </div>
        </section>

    </div>
</main>

<script src="/js/user/liked-concerts.js"></script>
{{> layout/footer}}
