{{> layout/header}}
<link rel="stylesheet" href="/css/user-login.css">
<main class="cc-login-main">
    <section class="cc-login-shell cc-login-shell--single">
        <div class="cc-login-form">
            <h1>CatchCatch</h1>
            <p class="cc-login-form__desc">아이디(이메일)를<br>잊으셨나요?</p>
            <p class="cc-verify-status" id="findIdStatus" aria-live="polite"></p>

            <form id="findIdForm">
                <div class="cc-input-wrap">
                    <span class="cc-input-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>
                    </span>
                    <input class="cc-input" id="username" type="text" name="username" placeholder="가입 시 등록한 아이디" autocomplete="username">
                </div>
                <div class="cc-input-wrap">
                    <span class="cc-input-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.7.6 2.5a2 2 0 0 1-.5 2.1L8 9.5a16 16 0 0 0 6.5 6.5l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.6.5 2.5.6a2 2 0 0 1 1.7 2Z"/></svg>
                    </span>
                    <input class="cc-input" id="phone" type="tel" name="phone" placeholder="휴대폰 번호 ('-' 없이 입력 가능)" autocomplete="tel" maxlength="13">
                </div>
                <button class="cc-btn cc-btn--primary cc-btn--full" type="submit">아이디 찾기</button>
            </form>

            <div class="cc-login-links">
                <a href="/login">로그인으로 돌아가기</a><span>|</span><a href="/find-password">비밀번호 찾기</a>
            </div>
        </div>
    </section>
</main>
<script src="/js/user/find-id.js"></script>
{{> layout/footer}}
