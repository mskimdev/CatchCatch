{{> layout/header-login}}
<link rel="stylesheet" href="/css/user-login.css">
<link rel="stylesheet" href="/css/user-join.css">
<main class="cc-login-main">
    <section class="cc-login-shell cc-register-shell">
        <div class="cc-login-form cc-register-form">
            <h1>CatchCatch</h1>
            <p class="cc-login-form__desc">회원가입하고<br>특별한 공연을 예매하세요</p>
            {{#errorMessage}}<p class="cc-badge" style="margin-bottom:16px;color:var(--cc-danger);background:#fff0f0;border-color:var(--cc-danger)">{{errorMessage}}</p>{{/errorMessage}}
            <form action="/join" method="post" enctype="multipart/form-data">
                {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}">{{/_csrf}}

                <div class="cc-profile-upload">
                    <label class="cc-profile-upload__preview" for="profileImage" aria-label="프로필 이미지 선택">
                        <img data-profile-preview alt="">
                        <span class="cc-profile-upload__fallback" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>
                        </span>
                    </label>
                    <div class="cc-profile-upload__text">
                        <strong>프로필 이미지</strong>
                        <span>나중에 마이페이지에서도 변경할 수 있어요</span>
                        <label class="cc-profile-upload__button" for="profileImage">이미지 선택</label>
                    </div>
                    <input id="profileImage" type="file" name="profileImage" accept="image/*" data-profile-input>
                </div>

                <div class="cc-register-row">
                    <div class="cc-field">
                        <label for="username">아이디</label>
                        <div class="cc-input-wrap">
                            <span class="cc-input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>
                            </span>
                            <input class="cc-input" id="username" type="text" name="username" placeholder="영문, 숫자 조합" autocomplete="username" value="{{!username}}">
                        </div>
                    </div>
                    <div class="cc-field">
                        <label for="email">이메일</label>
                        <div class="cc-input-wrap">
                            <span class="cc-input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                            </span>
                            <input class="cc-input" id="email" type="email" name="email" placeholder="example@email.com" autocomplete="email" value="{{!email}}">
                        </div>
                    </div>
                </div>

                <div class="cc-register-row">
                    <div class="cc-field">
                        <label for="password">비밀번호</label>
                        <div class="cc-input-wrap">
                            <span class="cc-input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                            </span>
                            <input class="cc-input" id="password" type="password" name="password" placeholder="8자 이상" autocomplete="new-password">
                            <button class="cc-input-eye" type="button" data-toggle-pw="password" aria-label="비밀번호 보기" aria-pressed="false">
                                <svg class="cc-eye-icon cc-eye-icon--show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                                <svg class="cc-eye-icon cc-eye-icon--hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 3 18 18"/><path d="M10.6 10.6a3 3 0 0 0 4.2 4.2"/><path d="M9.9 5.2A10.7 10.7 0 0 1 12 5c6.5 0 10 7 10 7a18.5 18.5 0 0 1-2.4 3.3"/><path d="M6.4 6.4C3.6 8.2 2 12 2 12s3.5 7 10 7c1.5 0 2.8-.3 4-.8"/></svg>
                            </button>
                        </div>
                    </div>
                    <div class="cc-field">
                        <label for="passwordConfirm">비밀번호 확인</label>
                        <div class="cc-input-wrap">
                            <span class="cc-input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                            </span>
                            <input class="cc-input" id="passwordConfirm" type="password" name="passwordConfirm" placeholder="비밀번호 재입력" autocomplete="new-password">
                            <button class="cc-input-eye" type="button" data-toggle-pw="passwordConfirm" aria-label="비밀번호 확인 보기" aria-pressed="false">
                                <svg class="cc-eye-icon cc-eye-icon--show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                                <svg class="cc-eye-icon cc-eye-icon--hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 3 18 18"/><path d="M10.6 10.6a3 3 0 0 0 4.2 4.2"/><path d="M9.9 5.2A10.7 10.7 0 0 1 12 5c6.5 0 10 7 10 7a18.5 18.5 0 0 1-2.4 3.3"/><path d="M6.4 6.4C3.6 8.2 2 12 2 12s3.5 7 10 7c1.5 0 2.8-.3 4-.8"/></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="cc-field">
                    <label for="phone">전화번호 <span style="font-weight:700;color:var(--cc-muted)">(선택)</span></label>
                    <div class="cc-input-wrap">
                        <span class="cc-input-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.7.6 2.5a2 2 0 0 1-.5 2.1L8 9.5a16 16 0 0 0 6.5 6.5l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.6.5 2.5.6a2 2 0 0 1 1.7 2Z"/></svg>
                        </span>
                        <input class="cc-input" id="phone" type="tel" name="phone" placeholder="010-0000-0000" autocomplete="tel" value="{{!phone}}">
                    </div>
                </div>

                <div class="cc-register-agree">
                    <label class="cc-check">
                        <input type="checkbox" id="agreeAll"> 전체 동의
                    </label>
                    <div class="cc-register-agree__items">
                        <label class="cc-check">
                            <input type="checkbox" name="agreeTerms" class="agree-item" required>
                            [필수] 이용약관 동의
                            <a href="/terms" class="cc-register-agree__link" target="_blank">보기</a>
                        </label>
                        <label class="cc-check">
                            <input type="checkbox" name="agreePrivacy" class="agree-item" required>
                            [필수] 개인정보 처리방침 동의
                            <a href="/privacy" class="cc-register-agree__link" target="_blank">보기</a>
                        </label>
                        <label class="cc-check">
                            <input type="checkbox" name="agreeMarketing" class="agree-item">
                            [선택] 마케팅 정보 수신 동의
                        </label>
                    </div>
                </div>

                <button class="cc-btn cc-btn--primary cc-btn--full" type="submit" style="margin-top:8px">
                    회원가입
                </button>
            </form>

            <div class="cc-divider">또는</div>
            <div class="cc-social-row">
                <a class="cc-social cc-social--kakao" href="/oauth2/authorization/kakao">카카오로 가입</a>
                <a class="cc-social cc-social--naver" href="/oauth2/authorization/naver">네이버로 가입</a>
                <a class="cc-social" href="/oauth2/authorization/google">Google 가입</a>
            </div>
            <div class="cc-login-links">
                <a href="/login">이미 계정이 있으신가요? 로그인</a>
            </div>
        </div>
    </section>
</main>

{{> layout/footer}}
