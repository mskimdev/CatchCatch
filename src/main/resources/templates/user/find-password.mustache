{{> layout/header}}
<link rel="stylesheet" href="/css/user-login.css">
<main class="cc-login-main">
    <section class="cc-login-shell cc-login-shell--single">
        <div class="cc-login-form">
            <h1>CatchCatch</h1>
            <p class="cc-login-form__desc">비밀번호를<br>재설정하세요</p>

            <form id="resetPasswordForm">
                <div class="cc-email-verify-wrap">
                    <div class="cc-input-wrap" style="flex:1">
                        <span class="cc-input-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                        </span>
                        <input class="cc-input" id="email" type="email" name="email" placeholder="가입한 이메일" autocomplete="email">
                    </div>
                    <button class="cc-btn cc-btn--outline cc-email-send-btn" type="button" id="sendCodeBtn">인증코드 발송</button>
                </div>
                <div class="cc-email-verify-wrap" id="verifyCodeRow" style="display:none;margin-top:8px">
                    <div class="cc-input-wrap" style="flex:1">
                        <span class="cc-input-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                        </span>
                        <input class="cc-input" id="verifyCode" type="text" maxlength="6" placeholder="인증 코드 6자리" inputmode="numeric">
                    </div>
                    <button class="cc-btn cc-btn--outline cc-email-send-btn" type="button" id="verifyCodeBtn">인증 확인</button>
                </div>
                <p class="cc-verify-status" id="verifyStatus" aria-live="polite"></p>

                <div id="newPasswordSection" style="display:none">
                    <div class="cc-input-wrap" style="margin-top:8px">
                        <span class="cc-input-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                        </span>
                        <input class="cc-input" id="newPassword" type="password" placeholder="새 비밀번호 (8자 이상)" autocomplete="new-password">
                        <button class="cc-input-eye" type="button" data-toggle-pw="newPassword" aria-label="비밀번호 보기" aria-pressed="false">
                            <svg class="cc-eye-icon cc-eye-icon--show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="cc-eye-icon cc-eye-icon--hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 3 18 18"/><path d="M10.6 10.6a3 3 0 0 0 4.2 4.2"/><path d="M9.9 5.2A10.7 10.7 0 0 1 12 5c6.5 0 10 7 10 7a18.5 18.5 0 0 1-2.4 3.3"/><path d="M6.4 6.4C3.6 8.2 2 12 2 12s3.5 7 10 7c1.5 0 2.8-.3 4-.8"/></svg>
                        </button>
                    </div>
                    <div class="cc-input-wrap" style="margin-top:8px">
                        <span class="cc-input-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                        </span>
                        <input class="cc-input" id="newPasswordConfirm" type="password" placeholder="새 비밀번호 확인" autocomplete="new-password">
                        <button class="cc-input-eye" type="button" data-toggle-pw="newPasswordConfirm" aria-label="비밀번호 확인 보기" aria-pressed="false">
                            <svg class="cc-eye-icon cc-eye-icon--show" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                            <svg class="cc-eye-icon cc-eye-icon--hide" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 3 18 18"/><path d="M10.6 10.6a3 3 0 0 0 4.2 4.2"/><path d="M9.9 5.2A10.7 10.7 0 0 1 12 5c6.5 0 10 7 10 7a18.5 18.5 0 0 1-2.4 3.3"/><path d="M6.4 6.4C3.6 8.2 2 12 2 12s3.5 7 10 7c1.5 0 2.8-.3 4-.8"/></svg>
                        </button>
                    </div>
                    <p class="cc-verify-status" id="resetStatus" aria-live="polite"></p>
                    <button class="cc-btn cc-btn--primary cc-btn--full" type="submit" style="margin-top:8px">비밀번호 변경</button>
                </div>
            </form>

            <div class="cc-login-links">
                <a href="/login">로그인으로 돌아가기</a><span>|</span><a href="/find-id">아이디 찾기</a>
            </div>
        </div>
    </section>
</main>
<script src="/js/user/find-password.js"></script>
{{> layout/footer}}
