<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>CatchCatch | 결제 상세내역</title>
    <link rel="stylesheet" href="/css/payment-detail.css">
</head>
<body>

<div class="popup-wrap">
    <div class="popup-card">

        <header class="popup-header">
            <div class="small">CatchCatch Payment Detail</div>
            <h1>결제 상세내역</h1>
            <p>결제번호, 예매번호, 공연 정보와 결제 상태를 확인할 수 있습니다.</p>
        </header>

        <!-- 결제 정보 -->
        <section class="section">
            <h2>결제 정보</h2>

            <table class="detail-table">
                <tbody>
                <tr>
                    <th>결제번호</th>
                    <td>{{payment.paymentId}}</td>
                </tr>

                <tr>
                    <th>PG 거래번호</th>
                    <td>{{payment.pgTxIdText}}</td>
                </tr>

                <tr>
                    <th>예매번호</th>
                    <td>{{payment.bookingNumber}}</td>
                </tr>

                <tr>
                    <th>결제수단</th>
                    <td>{{payment.method}}</td>
                </tr>

                <tr>
                    <th>결제상태</th>
                    <td>{{payment.statusLabel}}</td>
                </tr>

                <tr>
                    <th>결제요청일</th>
                    <td>{{payment.createdAtText}}</td>
                </tr>

                <tr>
                    <th>결제완료일</th>
                    <td>{{payment.paidAtText}}</td>
                </tr>
                </tbody>
            </table>
        </section>

        <!-- 예매 정보 -->
        <section class="section">
            <h2>예매 정보</h2>

            <table class="detail-table">
                <tbody>
                <tr>
                    <th>공연명</th>
                    <td>{{payment.concertTitle}}</td>
                </tr>

                <tr>
                    <th>공연날짜</th>
                    <td>{{payment.sessionDateText}}</td>
                </tr>

                <tr>
                    <th>좌석</th>
                    <td>{{payment.seatText}}</td>
                </tr>
                </tbody>
            </table>
        </section>

        <!-- 금액 정보 -->
        <section class="price-box">
            <div class="price-row">
                <span class="price-label">공연 금액</span>
                <span class="price-value">{{payment.originalAmountText}}</span>
            </div>
            <div class="price-row">
                <span class="price-label">예매 수수료</span>
                <span class="price-value">{{payment.ticketFeeText}}</span>
            </div>
            <div class="price-row">
                <span class="price-label">최종 결제 금액</span>
                <span class="price-value">{{payment.amountText}}</span>
            </div>
        </section>

        <div class="notice">
            결제 취소 및 환불은 공연일, 예매 상태, 취소 시점에 따라 제한될 수 있습니다.
            자세한 내용은 취소/환불 안내를 확인해주세요.
        </div>

        <div style="background: #f4f4f4; padding: 10px; margin-bottom: 10px; font-size: 12px;">
            데이터 확인: <br>
            결제상태: {{payment.statusLabel}} (원래 상태값: {{payment.status}}) <br>
            공연까지 남은 일수: {{payment.daysUntilSession}}일 <br>
            결제후 경과일수: {{payment.daysSincePayment}}일
        </div>

        <div class="button-area">
            <button type="button" class="btn btn-outline" onclick="window.print()">인쇄</button>

            {{#payment.cancelable}}
                <button type="button"
                        class="btn btn-danger"
                        onclick="document.getElementById('refundModal').style.display='flex'">
                    환불 신청
                </button>
            {{/payment.cancelable}}

            <button type="button" class="btn btn-primary" onclick="window.close()">닫기</button>
        </div>

    </div>
</div>
<!-- 환불 모달 (body 끝 부분에 위치) -->
<div id="refundModal" class="cc-modal-overlay" style="display: none;">
    <div class="cc-modal-content">
        <div class="cc-modal-header">
            <h3>결제 취소 및 환불</h3>
        </div>
        <div class="cc-modal-body">
            <div class="cc-refund-info-box">
                <p><strong>공연 남은 기간:</strong> <span class="cc-highlight">{{payment.daysUntilSession}}일</span></p>
                <p><strong>결제 경과일:</strong> {{payment.daysSincePayment}}일</p>
            </div>
            <form id="refundForm">
                <input type="hidden" id="targetPaymentId" value="{{payment.paymentId}}">
                <div class="cc-form-group">
                    <label for="refundReason">취소 사유</label>
                    <textarea id="refundReason" name="reason" rows="3" placeholder="취소 사유를 입력해주세요" required></textarea>
                </div>
            </form>
        </div>
        <div class="cc-modal-footer">
            <button type="button" class="btn btn-outline" id="btnCancelRefund"
                    onclick="document.getElementById('refundModal').style.display='none'">닫기</button>
            <button type="button" class="btn btn-danger" id="btnSubmitRefund">환불 확정하기</button>
        </div>
    </div>
</div>
</body>
</html>
<script>
    document.getElementById('btnSubmitRefund').addEventListener('click', function() {
        const paymentId = document.getElementById('targetPaymentId').value;
        const reason = document.getElementById('refundReason').value;

        if (!reason.trim()) {
            alert('취소 사유를 입력해주세요.');
            return;
        }

        // 서버로 보낼 데이터 (예: 부분 환불액을 10000원으로 고정하거나, input을 만들어 유동적으로 변경 가능)
        const requestData = {
            paymentId: paymentId,
            amount: 10000, // 👈 실제 서비스에서는 사용자가 입력한 금액이나 티켓 환불 규정 금액 계산값 대입
            reason: reason
        };

        // 로딩 표시 및 버튼 비활성화
        this.disabled = true;
        this.innerText = '처리 중...';

        // 백엔드 컨트롤러 호출
        fetch(`/api/payments/${paymentId}/cancel`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestData)
        })
        .then(response => {
            if (response.ok) {
                alert('환불 처리가 성공적으로 완료되었습니다.');
                window.close(); // 성공 시 팝업창 닫기
                if (window.opener) {
                    window.opener.location.reload(); // 부모 창(마이페이지 등) 새로고침
                }
            } else {
                response.text().then(errorMessage => {
                    alert('환불 실패: ' + errorMessage);
                });
                // 버튼 원상복구
                this.disabled = false;
                this.innerText = '환불 확정하기';
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('네트워크 오류가 발생했습니다.');
            this.disabled = false;
            this.innerText = '환불 확정하기';
        });
    });
</script>