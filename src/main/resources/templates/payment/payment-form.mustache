{{> layout/header-booking}}

<link rel="stylesheet" href="/css/booking-payment.css">

<main class="cc-main">
<input type="hidden" id="bookingExpiresAt" value="{{payment.expiresAtMillis}}">

<div class="cc-timer cc-payment-timer">
    <span>좌석 점유 보관 시간</span>
    <b id="paymentCountdown">10:00</b>
</div>

<section class="cc-payment-layout">
    <!-- 왼쪽: 예매 정보 요약 + 결제 수단 -->
    <div class="cc-payment-main">
        <div class="cc-card cc-payment-section">
            <h3>예매 정보 확인</h3>

            <div class="cc-payment-concert">
                <img class="cc-payment-poster"
                     src="{{#payment.posterUrl}}{{payment.posterUrl}}{{/payment.posterUrl}}{{^payment.posterUrl}}/images/sample/poster-legend-seoul.svg{{/payment.posterUrl}}"
                     alt="공연 포스터">

                <div class="cc-payment-concert__info">
                    <p class="cc-payment-concert__title">
                        {{#payment.concertTitle}}{{payment.concertTitle}}{{/payment.concertTitle}}{{^payment.concertTitle}}2026 무명전설 전국투어 콘서트 - 서울{{/payment.concertTitle}}
                    </p>
                    <p class="cc-payment-concert__line">
                        📅 {{#payment.sessionText}}{{payment.sessionText}}{{/payment.sessionText}}{{^payment.sessionText}}2026.06.27 (토) 18:00{{/payment.sessionText}}
                    </p>
                    <p class="cc-payment-concert__line">
                        📍 {{#payment.venueText}}{{payment.venueText}}{{/payment.venueText}}{{^payment.venueText}}서울 · 올림픽공원 올림픽홀{{/payment.venueText}}
                    </p>
                </div>
            </div>

            <table class="cc-payment-table">
                <thead>
                <tr>
                    <th>좌석</th>
                    <th>등급</th>
                    <th>금액</th>
                </tr>
                </thead>
                <tbody>
                {{#payment.selectedSeats}}
                    <tr>
                        <td>{{seatNumber}}</td>
                        <td><i class="cc-dot cc-dot--{{gradeClass}}"></i>{{grade}}</td>
                        <td>{{priceText}}</td>
                    </tr>
                {{/payment.selectedSeats}}

                {{^payment.selectedSeats}}
                    <tr>
                        <td>나구역 12열 15번</td>
                        <td><i class="cc-dot cc-dot--vip"></i>VIP</td>
                        <td>154,000원</td>
                    </tr>
                    <tr>
                        <td>나구역 12열 16번</td>
                        <td><i class="cc-dot cc-dot--vip"></i>VIP</td>
                        <td>154,000원</td>
                    </tr>
                {{/payment.selectedSeats}}
                </tbody>
            </table>
        </div>

        <div class="cc-card cc-payment-section">
            <h3>예매자 정보</h3>

            <div class="cc-info-list">
                <div class="cc-info-row">
                    <span class="cc-info-row__label">이름</span>
                    <span>{{#payment.userName}}{{payment.userName}}{{/payment.userName}}{{^payment.userName}}홍길동{{/payment.userName}}</span>
                </div>

                <div class="cc-info-row">
                    <span class="cc-info-row__label">연락처</span>
                    <span>{{#payment.userPhone}}{{payment.userPhone}}{{/payment.userPhone}}{{^payment.userPhone}}010-1234-5678{{/payment.userPhone}}</span>
                </div>

                <div class="cc-info-row">
                    <span class="cc-info-row__label">이메일</span>
                    <span>{{#payment.userEmail}}{{payment.userEmail}}{{/payment.userEmail}}{{^payment.userEmail}}user@example.com{{/payment.userEmail}}</span>
                </div>
            </div>
        </div>

        <div class="cc-card cc-payment-section">
            <h3>결제 수단</h3>

            <form id="paymentForm">
                {{#_csrf}}
                    <input type="hidden" name="{{parameterName}}" value="{{token}}">
                    <input type="hidden" id="csrfHeaderName" value="{{headerName}}">
                    <input type="hidden" id="csrfToken" value="{{token}}">
                {{/_csrf}}


                <input type="hidden" name="bookingId" value="{{payment.bookingId}}">
                <input type="hidden" name="customerName" value="{{payment.userName}}">
                <input type="hidden" name="customerEmail" value="{{payment.userEmail}}">
                <input type="hidden" name="customerPhone" value="{{payment.userPhone}}">

                <div class="cc-pay-methods">
                    <label class="cc-pay-method is-active">
                        <input type="radio" name="method" value="card" checked>
                        <span class="cc-pay-method__icon">💳</span>
                        <span>신용/체크카드</span>
                    </label>

                    <label class="cc-pay-method">
                        <input type="radio" name="method" value="kakaopay">
                        <span class="cc-pay-method__icon">
                            <img src="/images/payment/kakao_pay.png" alt="카카오페이">
                        </span>
                        <span>카카오페이</span>
                    </label>

                    <label class="cc-pay-method">
                        <input type="radio" name="method" value="tosspay">
                        <span class="cc-pay-method__icon">
                            <img src="/images/payment/toss_pay.png" alt="토스페이">
                        </span>
                        <span>토스페이</span>
                    </label>

                </div>

                <div class="cc-pay-agree">
                    <label class="cc-check">
                        <input type="checkbox" id="payAgreeAll">
                        <span>구매조건 전체 동의</span>
                    </label>

                    <div class="cc-pay-agree__items">
                        <label class="cc-check">
                            <input type="checkbox" class="pay-agree-item" required>
                            <span>[필수] 개인정보 수집·이용 동의</span>
                        </label>

                        <label class="cc-check">
                            <input type="checkbox" class="pay-agree-item" required>
                            <span>[필수] 결제 서비스 이용약관 동의</span>
                        </label>
                    </div>
                </div>

                <div class="cc-pay-sms">
                    <label class="cc-check">
                        <input type="checkbox" id="notifySms">
                        <span>예매 내용 문자로 받기</span>
                    </label>

                    <div id="smsPhoneWrap" class="cc-sms-phone-wrap">
                        <input class="cc-input cc-sms-phone-input"
                               type="tel"
                               id="smsPhone"
                               value="{{payment.userPhone}}"
                               placeholder="010-0000-0000"
                               maxlength="13">

                        {{^payment.userPhone}}
                        <label class="cc-check cc-sms-update-check">
                            <input type="checkbox" id="updateProfile">
                            <span>이 번호로 프로필 업데이트</span>
                        </label>
                        {{/payment.userPhone}}
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- 오른쪽: 결제 금액 요약 -->
    <aside>
        <div class="cc-card cc-payment-summary">
            <h3>결제 금액</h3>

            <div class="cc-price-box__row">
                <span>티켓 금액</span>
                <b>
                    {{#payment.originalAmountText}}{{payment.originalAmountText}}{{/payment.originalAmountText}}
                    {{^payment.originalAmountText}}308,000원{{/payment.originalAmountText}}
                </b>
            </div>

            <div class="cc-price-box__row">
                <span>예매 수수료</span>
                <b>
                    {{#payment.ticketFeeText}}{{payment.ticketFeeText}}{{/payment.ticketFeeText}}
                    {{^payment.ticketFeeText}}0원{{/payment.ticketFeeText}}
                </b>
            </div>

            <div class="cc-price-box__row">
                <span>보유 포인트</span>
                <b>
                    {{#payment.userPointText}}{{payment.userPointText}}{{/payment.userPointText}}
                    {{^payment.userPointText}}0P{{/payment.userPointText}}
                </b>
            </div>

            <div class="cc-point-use">
                <div class="cc-point-use__head">
                    <label for="usedPointInput">사용 포인트</label>
                    <span>최대 사용 가능: <b id="maxPointText">{{payment.usablePointText}}</b></span>
                </div>

                <div class="cc-point-control">
                    <input type="number"
                           id="usedPointInput"
                           name="usedPoint"
                           form="paymentForm"
                           min="0"
                           step="100"
                           value="0"
                           inputmode="numeric"
                           autocomplete="off"
                           data-user-point="{{payment.userPoint}}"
                           data-original-amount="{{payment.originalAmount}}"
                           data-ticket-fee="{{payment.ticketFee}}">

                    <button type="button" id="btnUseMaxPoint">
                        최대
                    </button>
                </div>
            </div>

            <div class="cc-price-box__row cc-price-box__row--point">
                <span>포인트 사용</span>
                <b id="usedPointText">-0P</b>
            </div>

            <div class="cc-payment-total">
                <span>최종 결제 금액</span>
                <strong class="cc-total__price" id="finalAmountText">
                    {{#payment.amountText}}{{payment.amountText}}{{/payment.amountText}}
                    {{^payment.amountText}}308,000원{{/payment.amountText}}
                </strong>
            </div>

            <button class="cc-btn cc-btn--primary cc-btn--full" id="payment-btn" type="button">
                결제하기
            </button>

            <button type="button" class="cc-btn cc-btn--outline cc-btn--full" id="booking-cancel-btn">
                예약취소
            </button>
        </div>

        <div class="cc-card cc-notice-card">
            <h3>ⓘ 유의사항</h3>
            <ul>
                <li>예매 완료 후 취소 시 취소 수수료가 발생할 수 있습니다.</li>
                <li>무통장 입금 선택 시 당일 23:59까지 입금해야 예매가 완료됩니다.</li>
                <li>본인 명의 결제 수단만 사용 가능합니다.</li>
            </ul>
        </div>
    </aside>
</section>
</main>
<script src="https://cdn.portone.io/v2/browser-sdk.js"></script>
<script src="/js/payment/payment.js"></script>
{{> layout/footer}}