 {{> layout/header}}

<div class="cc-stepper" aria-label="예매 진행 단계">
    <div class="cc-step is-done">
        <span class="cc-step__num">✓</span>좌석선택
    </div>
    <span class="cc-step-line"></span>

    <div class="cc-step is-done">
        <span class="cc-step__num">✓</span>결제
    </div>
    <span class="cc-step-line"></span>

    <div class="cc-step is-active">
        <span class="cc-step__num">3</span>완료
    </div>
</div>

<section class="cc-complete-wrap">
    <div class="cc-complete-icon">✓</div>

    <h2 class="cc-complete-title">예매가 완료되었습니다!</h2>
    <p class="cc-complete-sub">예매 확인서는 마이페이지에서 확인하실 수 있습니다.</p>

    <div class="cc-card cc-complete-ticket">
        <div class="cc-complete-ticket__left">
            <img src="{{#booking.posterUrl}}{{booking.posterUrl}}{{/booking.posterUrl}}{{^booking.posterUrl}}/images/sample/poster-legend-seoul.svg{{/booking.posterUrl}}"
                 alt="공연 포스터">
        </div>

        <div class="cc-complete-ticket__right">
            <div class="cc-complete-ticket__number">
                예매번호
                <strong>
                    {{#booking.bookingNumber}}{{booking.bookingNumber}}{{/booking.bookingNumber}}{{^booking.bookingNumber}}
                    CC2026-000001{{/booking.bookingNumber}}
                </strong>
            </div>

            <h3>
                {{#booking.concertTitle}}{{booking.concertTitle}}{{/booking.concertTitle}}{{^booking.concertTitle}}
                2026 무명전설 전국투어 콘서트 - 서울{{/booking.concertTitle}}
            </h3>

            <div class="cc-info-list">
                <div class="cc-info-row">
                    <span class="cc-info-row__label">📅 공연일시</span>
                    <span>
                        {{#booking.sessionText}}{{booking.sessionText}}{{/booking.sessionText}}{{^booking.sessionText}}
                        2026.06.27 (토) 18:00{{/booking.sessionText}}
                    </span>
                </div>

                <div class="cc-info-row">
                    <span class="cc-info-row__label">📍 공연장소</span>
                    <span>
                        {{#booking.venueText}}{{booking.venueText}}{{/booking.venueText}}{{^booking.venueText}}
                        서울 · 올림픽공원 올림픽홀{{/booking.venueText}}
                    </span>
                </div>

                <div class="cc-info-row cc-info-row--seats">
                    <span class="cc-info-row__label">💺 좌석</span>

                    <div class="cc-complete-seat-box">
                        <div class="cc-complete-seat-count">
                            총 {{bookingCount}}석
                        </div>

                        <div class="cc-complete-seat-scroll">
                            {{#payment.selectedSeats}}
                                <div class="cc-complete-seat-item">
                                    <span class="cc-complete-seat-name">{{seatNumber}}</span>
                                    <span class="cc-complete-seat-grade">{{grade}}</span>
                                    <span class="cc-complete-seat-price">{{priceText}}</span>
                                </div>
                            {{/payment.selectedSeats}}

                            {{^payment.selectedSeats}}
                                <div class="cc-complete-seat-empty">
                                    좌석 정보가 없습니다.
                                </div>
                            {{/payment.selectedSeats}}
                        </div>
                    </div>
                </div>

                <div class="cc-info-row">
                    <span class="cc-info-row__label">💳 결제금액</span>
                    <strong class="cc-complete-price">
                        {{#payment.totalPriceText}}{{payment.totalPriceText}}{{/payment.totalPriceText}}{{^payment.totalPriceText}}{{booking.totalPriceText}}{{/payment.totalPriceText}}
                    </strong>
                </div>

                <div class="cc-info-row">
                    <span class="cc-info-row__label">🕒 예매일시</span>
                    <span>
                        {{#booking.createdAt}}{{booking.createdAt}}{{/booking.createdAt}}{{^booking.createdAt}}
                        2026.05.29 14:32{{/booking.createdAt}}
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="cc-complete-actions">
        <button type="button" class="cc-btn cc-btn--primary" onclick="closeBookingWindow()">
            예매 종료
        </button>

        <button type="button" class="cc-btn cc-btn--outline" onclick="openMyBookingAndClose()">
            예매 내역 확인
        </button>
    </div>
</section>

{{> layout/footer}}